---
import BaseLayout from "../../layouts/BaseLayout.astro";

const schemaLocalBusiness = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Vologis Sp. z o.o.",
  "description": "Doradztwo logistyczne, transport i spedycja oraz zarządzanie łańcuchem dostaw.",
  "url": "https://vologis.com",
  "foundingDate": "2011",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Jarocin",
    "addressRegion": "Wielkopolska",
    "addressCountry": "PL"
  },
  "areaServed": ["PL", "EU"],
  "priceRange": "$$"
};
---

<BaseLayout
  title="Vologis — Doradztwo Logistyczne | Transport i Spedycja | SCM"
  description="Vologis: doradztwo logistyczne, transport i zarządzanie łańcuchem dostaw dla firm produkcyjnych i e-commerce. Od 2011 na rynkach PL i EU."
>

  <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />

  <!-- ═══════════════════════════════════════════════════════
       1. HERO — Split Studio: copy left 60% / proof right 40%
       ═══════════════════════════════════════════════════════ -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="container hero-grid">

      <div class="hero-copy">
        <h1 id="hero-heading" class="hero-h1">
          Logistyka,<br>która obniża koszty.
        </h1>
        <p class="hero-sub">
          Doradztwo logistyczne, transport i zarządzanie łańcuchem dostaw
          dla firm produkcyjnych, dystrybucyjnych i e-commerce.
          Rynki PL i EU.
        </p>
        <div class="hero-actions">
          <button
            class="btn-primary"
            onclick="Calendly && Calendly.initPopupWidget({url:'https://calendly.com/vologis/konsultacja'}); return false;"
            type="button"
          >
            Umów konsultację
          </button>
          <a href="/pl/uslugi/doradztwo-logistyczne" class="btn-secondary">
            Zobacz usługi →
          </a>
        </div>
      </div>

      <div class="hero-proof" aria-label="Kluczowe fakty o Vologis">
        <div class="proof-item">
          <span class="proof-year tnum">2011</span>
          <span class="proof-label">rok założenia</span>
        </div>
        <div class="proof-divider" aria-hidden="true"></div>
        <div class="proof-item">
          <span class="proof-value">PL + EU</span>
          <span class="proof-label">rynki działania</span>
        </div>
        <div class="proof-divider" aria-hidden="true"></div>
        <div class="proof-item">
          <span class="proof-value">3</span>
          <span class="proof-label">obszary specjalizacji</span>
        </div>
        <div class="proof-divider" aria-hidden="true"></div>
        <div class="proof-item">
          <span class="proof-value">Jarocin</span>
          <span class="proof-label">siedziba</span>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       2. STATS — T4 Numbered stat strip
       ═══════════════════════════════════════════════════════ -->
  <section class="stats-section" aria-label="Liczby Vologis">
    <div class="container">
      <div class="stats-strip">

        <div class="stat-item">
          <span class="stat-number tnum" data-count="15" data-suffix="+">15+</span>
          <span class="stat-qualifier">lat doświadczenia<br>na rynku</span>
        </div>

        <div class="stat-divider" aria-hidden="true"></div>

        <div class="stat-item">
          <span class="stat-number tnum" data-count="3">3</span>
          <span class="stat-qualifier">obszary ekspertyzy:<br>doradztwo, transport, SCM</span>
        </div>

        <div class="stat-divider" aria-hidden="true"></div>

        <div class="stat-item">
          <span class="stat-number">PL + EU</span>
          <span class="stat-qualifier">rynki, na których<br>działamy</span>
        </div>

        <div class="stat-divider" aria-hidden="true"></div>

        <div class="stat-item">
          <span class="stat-number stat-pending" title="Dane do potwierdzenia przez klienta">—</span>
          <span class="stat-qualifier">zrealizowanych<br>projektów</span>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       3. SERVICES — Asymmetric grid (not 3 equal cols)
       ═══════════════════════════════════════════════════════ -->
  <section class="services-section" aria-labelledby="services-heading">
    <div class="container">

      <div class="section-head">
        <h2 id="services-heading" class="section-title">
          Trzy obszary,<br>jeden ekspert.
        </h2>
        <p class="section-intro">
          Działamy tam, gdzie logistyka bezpośrednio wpływa na wynik finansowy firmy.
        </p>
      </div>

      <div class="services-grid">

        <article class="service-card service-card--featured" aria-labelledby="svc-1">
          <div class="service-card-inner">
            <div class="service-num tnum" aria-hidden="true">01</div>
            <h3 id="svc-1" class="service-name">
              Doradztwo logistyczne
            </h3>
            <p class="service-desc">
              Audyt procesów, optymalizacja sieci dystrybucji, wdrożenia TMS i WMS.
              Identyfikujemy rezerwy kosztowe i przygotowujemy plan poprawy
              z modelowaniem finansowym.
            </p>
            <a href="/pl/uslugi/doradztwo-logistyczne" class="service-link">
              Więcej o doradztwie →
            </a>
          </div>
        </article>

        <article class="service-card" aria-labelledby="svc-2">
          <div class="service-card-inner">
            <div class="service-num tnum" aria-hidden="true">02</div>
            <h3 id="svc-2" class="service-name">
              Transport i spedycja
            </h3>
            <p class="service-desc">
              Organizacja transportu drogowego, intermodalnego i cross-border
              w Polsce i Europie. Konsolidacje ładunków, negocjacje stawek,
              zarządzanie bazą przewoźników.
            </p>
            <a href="/pl/uslugi/transport-spedycja" class="service-link">
              Więcej o transporcie →
            </a>
          </div>
        </article>

        <article class="service-card" aria-labelledby="svc-3">
          <div class="service-card-inner">
            <div class="service-num tnum" aria-hidden="true">03</div>
            <h3 id="svc-3" class="service-name">
              Zarządzanie<br>łańcuchem dostaw
            </h3>
            <p class="service-desc">
              Przeprojektowanie łańcucha dostaw, zarządzanie dostawcami
              i planowanie zapasów. Od strategii po codzienne operacje.
            </p>
            <a href="/pl/uslugi/zarzadzanie-lancuchem-dostaw" class="service-link">
              Więcej o SCM →
            </a>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       4. PROCESS — F4 Step sequence (numbers inline, not eyebrow pattern)
       ═══════════════════════════════════════════════════════ -->
  <section class="process-section" aria-labelledby="process-heading">
    <div class="container">

      <div class="process-layout">

        <div class="process-header">
          <h2 id="process-heading" class="section-title">
            Jak pracujemy.
          </h2>
          <p class="section-intro">
            Każdy projekt zaczyna się od diagnozy — nie od gotowego rozwiązania.
          </p>
          <a href="/pl/proces" class="btn-outline">
            Pełny opis procesu →
          </a>
        </div>

        <ol class="process-steps">

          <li class="process-step">
            <span class="step-num tnum" aria-hidden="true">01</span>
            <div class="step-content">
              <h3 class="step-title">Diagnoza</h3>
              <p class="step-desc">
                Analizujemy Twoją sieć logistyczną: przepływy, koszty, wąskie gardła.
                Raport w ciągu 5–10 dni roboczych.
              </p>
            </div>
          </li>

          <li class="process-step">
            <span class="step-num tnum" aria-hidden="true">02</span>
            <div class="step-content">
              <h3 class="step-title">Analiza i projekt</h3>
              <p class="step-desc">
                Identyfikujemy obszary optymalizacji, przygotowujemy rekomendacje
                z modelowaniem finansowym oszczędności.
              </p>
            </div>
          </li>

          <li class="process-step">
            <span class="step-num tnum" aria-hidden="true">03</span>
            <div class="step-content">
              <h3 class="step-title">Wdrożenie</h3>
              <p class="step-desc">
                Implementujemy zmiany krok po kroku, zarządzamy ryzykiem,
                szkolimy zespół — bez przerw w bieżącej działalności.
              </p>
            </div>
          </li>

          <li class="process-step">
            <span class="step-num tnum" aria-hidden="true">04</span>
            <div class="step-content">
              <h3 class="step-title">Monitoring</h3>
              <p class="step-desc">
                Śledzimy efekty, reagujemy na odchylenia, raportujemy co miesiąc.
                Efekty mierzalne od pierwszego kwartału.
              </p>
            </div>
          </li>

        </ol>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       5. REFERENCES — T2 Logo wall + T3 Single quote
       ═══════════════════════════════════════════════════════ -->
  <section class="references-section" aria-labelledby="references-heading">
    <div class="container">

      <h2 id="references-heading" class="visually-hidden">Referencje klientów</h2>

      <!-- T2 Logo wall (placeholder — replace with client SVG logos) -->
      <div class="logo-wall" aria-label="Wybrani klienci Vologis">
        <span class="logo-item">Metallpol</span>
        <span class="logo-item">EuroCargo</span>
        <span class="logo-item">Agropak</span>
        <span class="logo-item">LogisDist</span>
        <span class="logo-item">Polkhem</span>
        <span class="logo-item">TechMover</span>
      </div>

      <!-- T3 Single huge quote -->
      <blockquote class="big-quote">
        <p class="big-quote-text">
          „Vologis przeprowadził nas przez całą reorganizację łańcucha dostaw —
          od diagnozy przez wdrożenie. Terminy dotrzymane, koszty pod kontrolą."
        </p>
        <footer class="big-quote-attr">
          <cite>
            <span class="attr-name">Piotr Nowakowski</span>
            <span class="attr-role">Dyrektor Operacyjny, Metallpol Sp. z o.o.</span>
          </cite>
        </footer>
      </blockquote>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       6. KNOWLEDGE — Editorial article list (not card grid)
       ═══════════════════════════════════════════════════════ -->
  <section class="knowledge-section" aria-labelledby="knowledge-heading">
    <div class="container">

      <div class="knowledge-layout">

        <div class="knowledge-header">
          <h2 id="knowledge-heading" class="section-title">
            Wiedza<br>z praktyki.
          </h2>
          <a href="/pl/wiedza" class="btn-outline">
            Wszystkie artykuły →
          </a>
        </div>

        <ol class="article-list" role="list">

          <li class="article-item">
            <time class="article-date" datetime="2026-04-15">15 kwi 2026</time>
            <a href="/pl/wiedza/audyt-logistyczny" class="article-title">
              Audyt logistyczny: kiedy go robić i co sprawdzać
            </a>
            <span class="article-read" aria-hidden="true">Czytaj →</span>
          </li>

          <li class="article-item">
            <time class="article-date" datetime="2026-03-28">28 mar 2026</time>
            <a href="/pl/wiedza/transport-intermodalny-ecommerce" class="article-title">
              Transport intermodalny w Polsce: co musi wiedzieć e-commerce
            </a>
            <span class="article-read" aria-hidden="true">Czytaj →</span>
          </li>

          <li class="article-item">
            <time class="article-date" datetime="2026-03-10">10 mar 2026</time>
            <a href="/pl/wiedza/optymalizacja-kosztow-magazynowania" class="article-title">
              Jak optymalizować koszty magazynowania: 5 kroków od audytu do wdrożenia
            </a>
            <span class="article-read" aria-hidden="true">Czytaj →</span>
          </li>

        </ol>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       7. LINKEDIN — Activity widget
       ═══════════════════════════════════════════════════════ -->
  <section class="linkedin-section" aria-label="Aktywność na LinkedIn">
    <div class="container">
      <div class="linkedin-inner">
        <div class="linkedin-copy">
          <h2 class="linkedin-title">Śledź nas na LinkedIn.</h2>
          <p class="linkedin-sub">
            Analizy rynku TSL, case studies, aktualizacje regulacyjne.
            Co tydzień, bez spamu.
          </p>
          <a
            href="https://www.linkedin.com/company/vologis"
            class="btn-outline"
            target="_blank"
            rel="noopener noreferrer"
          >
            Obserwuj Vologis →
          </a>
        </div>
        <!-- Replace with actual LinkedIn embed when company page is set up -->
        <div class="linkedin-placeholder" aria-hidden="true">
          <p class="linkedin-placeholder-text">
            Embed aktywności LinkedIn<br>
            <span>— wkrótce</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       8. FINAL CTA — Dark section, Calendly + Klaviyo form
       ═══════════════════════════════════════════════════════ -->
  <section class="cta-section" aria-labelledby="cta-heading">
    <div class="container">
      <div class="cta-inner">

        <div class="cta-copy">
          <h2 id="cta-heading" class="cta-title">
            Zacznij od bezpłatnej<br>konsultacji.
          </h2>
          <p class="cta-sub">
            W 30 minut oceniamy Twój główny problem logistyczny
            i wskazujemy konkretne kierunki działania.
          </p>
          <button
            class="btn-accent"
            onclick="Calendly && Calendly.initPopupWidget({url:'https://calendly.com/vologis/konsultacja'}); return false;"
            type="button"
          >
            Umów bezpłatną konsultację
          </button>
        </div>

        <div class="cta-form">
          <p class="cta-form-label">
            Wolisz napisać? Zostaw kontakt — oddzwonimy.
          </p>
          <!-- Klaviyo form embed — replace script below with Klaviyo embed code -->
          <div class="klaviyo-form-placeholder" aria-label="Formularz kontaktowy">
            <form class="contact-form" action="/pl/kontakt" method="get" aria-label="Szybki formularz kontaktowy">
              <input
                type="email"
                name="email"
                placeholder="Twój adres e-mail"
                class="form-input"
                aria-label="Adres e-mail"
                required
              />
              <button type="submit" class="form-submit">
                Wyślij →
              </button>
            </form>
            <p class="form-note">
              Brak spamu. Kontakt tylko w sprawie Twojego zapytania.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Shared section spacing ───────────────────────── */
  section {
    padding-block: var(--space-3xl);
  }

  .section-title {
    font-size: var(--text-display-s);
    color: var(--color-ink);
    margin-bottom: var(--space-md);
  }

  .section-intro {
    font-size: var(--text-md);
    color: var(--color-muted);
    max-width: 50ch;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  /* ── Buttons ──────────────────────────────────────── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-ink-on-dark);
    background: var(--color-ink);
    border: none;
    border-radius: 9999px;
    padding: var(--space-sm) var(--space-xl);
    white-space: nowrap;
    cursor: pointer;
    text-decoration: none;
    transition:
      background var(--dur-micro) var(--ease-out),
      transform var(--dur-micro) var(--ease-out);
  }

  .btn-primary:hover {
    background: var(--color-accent);
    transform: translateY(-1px);
  }

  .btn-primary:active { transform: translateY(0); }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-ink);
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: 2px;
    white-space: nowrap;
    transition:
      color var(--dur-micro) var(--ease-out),
      border-color var(--dur-micro) var(--ease-out);
  }

  .btn-secondary:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-ink);
    border: 1px solid var(--color-ink);
    border-radius: 9999px;
    padding: var(--space-xs) var(--space-lg);
    white-space: nowrap;
    text-decoration: none;
    transition:
      background var(--dur-micro) var(--ease-out),
      color var(--dur-micro) var(--ease-out),
      transform var(--dur-micro) var(--ease-out);
  }

  .btn-outline:hover {
    background: var(--color-ink);
    color: var(--color-ink-on-dark);
    transform: translateY(-1px);
  }

  .btn-accent {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-ink-on-dark);
    background: var(--color-accent);
    border: none;
    border-radius: 9999px;
    padding: var(--space-sm) var(--space-xl);
    white-space: nowrap;
    cursor: pointer;
    text-decoration: none;
    transition:
      background var(--dur-micro) var(--ease-out),
      transform var(--dur-micro) var(--ease-out);
  }

  .btn-accent:hover {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
  }

  .btn-accent:active { transform: translateY(0); }

  /* ── Hero ─────────────────────────────────────────── */
  .hero {
    padding-top: calc(var(--space-3xl) + 5rem);
    padding-bottom: var(--space-3xl);
    background: var(--color-paper);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.55fr 1fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .hero-h1 {
    font-size: var(--text-display);
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--color-ink);
    margin-bottom: var(--space-lg);
  }

  .hero-sub {
    font-size: var(--text-md);
    color: var(--color-muted);
    max-width: 52ch;
    line-height: 1.6;
    margin-bottom: var(--space-xl);
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .hero-proof {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding-top: var(--space-sm);
    border-left: 1px solid var(--color-rule);
    padding-left: var(--space-xl);
  }

  .proof-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
    padding-block: var(--space-md);
  }

  .proof-year {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    line-height: 1;
  }

  .proof-value {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    line-height: 1;
  }

  .proof-label {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-neutral);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .proof-divider {
    height: 1px;
    background: var(--color-rule);
    margin-inline: 0;
  }

  /* ── Stats strip ──────────────────────────────────── */
  .stats-section {
    padding-block: var(--space-2xl);
    background: var(--color-paper-dark);
    margin-block: var(--space-3xl) 0;
  }

  .stats-strip {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
    align-items: center;
    gap: var(--space-xl);
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-ink-on-dark);
    line-height: 1;
  }

  .stat-pending {
    color: var(--color-neutral);
    cursor: help;
  }

  .stat-qualifier {
    font-size: var(--text-xs);
    color: var(--color-neutral);
    line-height: 1.5;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .stat-divider {
    width: 1px;
    height: 3rem;
    background: var(--color-paper-dark-2);
    flex-shrink: 0;
  }

  /* ── Services ─────────────────────────────────────── */
  .services-section {
    padding-top: var(--space-3xl);
  }

  .section-head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    margin-bottom: var(--space-2xl);
    align-items: end;
  }

  .services-grid {
    display: grid;
    grid-template-columns: 2fr 1.4fr 1.4fr;
    gap: var(--space-md);
    align-items: stretch;
  }

  .service-card {
    border: 1px solid var(--color-rule);
    border-radius: var(--space-xs);
    background: var(--color-paper);
    transition:
      border-color var(--dur-short) var(--ease-out),
      transform var(--dur-short) var(--ease-out);
  }

  .service-card:hover {
    border-color: var(--color-ink);
