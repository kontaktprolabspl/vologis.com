---
import BaseLayout from "../../layouts/BaseLayout.astro";

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",         "item": "https://vologis.com/en/" },
    { "@type": "ListItem", "position": 2, "name": "Work with us", "item": "https://vologis.com/en/work-with-us/" }
  ]
};
---

<BaseLayout
  title="Work With Us | Vologis"
  description="Join forces with Vologis. We're looking for experts and partners in logistics, transport and warehousing."
  canonical="https://vologis.com/en/work-with-us/"
  hreflangPL="/pl/wspolpraca/"
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />

  <!-- ── Hero ───────────────────────────────────────── -->
  <section class="coop-hero" aria-labelledby="coop-heading">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol class="breadcrumb-list" role="list">
          <li><a href="/en/">Home</a></li>
          <li aria-hidden="true" class="breadcrumb-sep">›</li>
          <li aria-current="page">Work with us</li>
        </ol>
      </nav>
      <p class="eyebrow">WORK WITH US</p>
      <h1 id="coop-heading" class="coop-h1">
        Become a freelance<br>collaborator
      </h1>
      <p class="coop-sub">
        We deliver consulting and implementation projects in logistics, transport and warehousing. We continuously expand our network of independent experts and partners — if you have industry experience, send us your CV or portfolio.
      </p>
    </div>
  </section>

  <!-- ── Cards ──────────────────────────────────────── -->
  <section class="coop-cards" aria-label="Collaboration types">
    <div class="container">
      <div class="cards-grid">
        <article class="coop-card">
          <h2 class="card-title">Expert / Consultant</h2>
          <p class="card-text">
            Specializing in logistics, transport, warehousing or supply chain management? We collaborate with independent consultants on consulting projects, process audits and operations optimization for our clients.
          </p>
        </article>
        <article class="coop-card">
          <h2 class="card-title">Project partner</h2>
          <p class="card-text">
            Running a company or freelancing in TSL, forwarding, logistics IT or related fields? We're looking for partners for joint project execution and tenders.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- ── Form ───────────────────────────────────────── -->
  <section class="coop-body" aria-label="Collaboration application form">
    <div class="container">
      <div class="coop-grid">
        <div class="form-wrap">

          <div class="success-msg hidden" id="success-message" role="status" aria-live="polite">
            <div class="success-inner">
              <span class="success-icon" aria-hidden="true">✉</span>
              <h2 class="success-title">Finish sending in your email client</h2>
              <p class="success-text">
                We've opened a new message to <strong>biuro@vologis.com</strong> with your details.
                Attach your CV or portfolio and send the email. If the window didn't open,
                write directly to <a href="mailto:biuro@vologis.com">biuro@vologis.com</a>.
              </p>
            </div>
          </div>

          <h2 class="col-label" id="form-label">Submit your application</h2>

          <form id="partner-form" class="coop-form" novalidate>
            <div class="form-row">
              <div class="field">
                <label class="field-label" for="name">Full name <span class="req" aria-hidden="true">*</span></label>
                <input class="field-input" type="text" id="name" name="name" autocomplete="name" required aria-required="true" />
                <span class="field-error" aria-live="polite"></span>
              </div>
              <div class="field">
                <label class="field-label" for="email">Email address <span class="req" aria-hidden="true">*</span></label>
                <input class="field-input" type="email" id="email" name="email" autocomplete="email" required aria-required="true" />
                <span class="field-error" aria-live="polite"></span>
              </div>
            </div>

            <div class="field">
              <label class="field-label" for="phone">Phone number <span class="optional">(optional)</span></label>
              <input class="field-input" type="tel" id="phone" name="phone" autocomplete="tel" />
            </div>

            <div class="field">
              <label class="field-label" for="specialization">Area of specialization <span class="req" aria-hidden="true">*</span></label>
              <div class="select-wrap">
                <select class="field-input field-select" id="specialization" name="specialization" required aria-required="true">
                  <option value="" disabled selected>Choose an area…</option>
                  <option value="logistics-warehousing">Logistics &amp; warehousing</option>
                  <option value="transport-forwarding">Transport &amp; forwarding</option>
                  <option value="scm">Supply chain management (SCM)</option>
                  <option value="it-wms-tms">IT / WMS/TMS systems</option>
                  <option value="consulting-audit">Consulting &amp; audit</option>
                  <option value="other">Other</option>
                </select>
                <span class="select-arrow" aria-hidden="true">›</span>
              </div>
              <span class="field-error" aria-live="polite"></span>
            </div>

            <div class="field">
              <label class="field-label" for="about">Tell us about yourself <span class="req" aria-hidden="true">*</span></label>
              <textarea class="field-input field-textarea" id="about" name="about" rows="5" minlength="20" required aria-required="true" placeholder="Your experience, specialization, what you could contribute to Vologis projects…"></textarea>
              <span class="field-error" aria-live="polite"></span>
            </div>

            <div class="field">
              <label class="field-label" for="attachment">Attach CV or portfolio <span class="req" aria-hidden="true">*</span></label>
              <div class="file-field">
                <input class="file-input" type="file" id="attachment" name="attachment" accept=".pdf,.doc,.docx,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document" required aria-required="true" aria-describedby="file-hint" />
                <label for="attachment" class="file-button">Choose file</label>
                <span class="file-name" id="file-name" aria-live="polite">No file selected</span>
              </div>
              <span class="file-hint" id="file-hint">PDF, DOC or DOCX — maximum 10 MB. You'll attach the file in your email client after submitting.</span>
              <span class="field-error" aria-live="polite"></span>
            </div>

            <div class="field field-checkbox">
              <label class="checkbox-label">
                <input class="checkbox-input" type="checkbox" name="consent" required aria-required="true" />
                <span class="checkbox-text">
                  I consent to my personal data being processed by Vologis Sp. z o.o. for the purpose of reviewing this collaboration application. Data will be processed in accordance with the <a href="/en/privacy-policy/">Privacy Policy</a>.
                  <span class="req" aria-hidden="true">*</span>
                </span>
              </label>
              <span class="field-error" aria-live="polite"></span>
            </div>

            <p class="form-req-note"><span class="req" aria-hidden="true">*</span> Required fields</p>
            <span class="form-error" id="form-error" aria-live="assertive"></span>

            <button type="submit" class="btn-submit" id="submit-btn">
              Send application →
            </button>

            <p class="mailto-note">
              After clicking, your email client will open with a pre-filled message — attach your CV and send. Prefer to write directly?
              <a href="mailto:biuro@vologis.com">biuro@vologis.com</a>
            </p>
          </form>

        </div>

        <!-- RIGHT: CEO card -->
        <aside class="ceo-sidebar">
          <div class="ceo-card">
            <img src="/pawel-wojtczak.webp" alt="Paweł Wojtczak — CEO &amp; President of the Management Board, Vologis" width="120" height="120" class="ceo-card__photo" loading="lazy" decoding="async" />
            <div class="ceo-card__info">
              <p class="ceo-card__name">Paweł Wojtczak</p>
              <p class="ceo-card__role">CEO &amp; President of the Management Board</p>
              <p class="ceo-card__company">Vologis Sp. z o.o.</p>
              <a href="https://www.linkedin.com/company/vologis/" class="ceo-card__linkedin" target="_blank" rel="noopener noreferrer" aria-label="Vologis on LinkedIn">LinkedIn →</a>
            </div>
            <p class="ceo-card__note">
              Applications go directly to Paweł. He responds personally — usually within 48 hours.
            </p>
          </div>
        </aside>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .breadcrumb { margin-bottom: var(--space-lg); }
  .breadcrumb-list { display: flex; align-items: center; gap: var(--space-xs); list-style: none; font-size: var(--text-sm); color: var(--color-muted); }
  .breadcrumb-list a { color: var(--color-muted); text-decoration: none; transition: color var(--dur-micro) var(--ease-out); }
  .breadcrumb-list a:hover { color: var(--color-ink); }
  .breadcrumb-sep { color: var(--color-neutral); user-select: none; }
  .breadcrumb-list [aria-current="page"] { color: var(--color-ink); font-weight: 500; }
  .coop-hero { padding-top: calc(var(--space-3xl) + 5rem); padding-bottom: var(--space-2xl); }
  .eyebrow { font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 500; letter-spacing: 0.12em; color: var(--color-accent); margin-bottom: var(--space-md); text-transform: uppercase; }
  .coop-h1 { font-size: var(--text-display); font-weight: 700; letter-spacing: -0.03em; line-height: 1.05; color: var(--color-ink); margin-bottom: var(--space-lg); }
  .coop-sub { font-size: var(--text-md); color: var(--color-muted); max-width: 62ch; line-height: 1.6; }
  .coop-cards { padding-bottom: var(--space-2xl); }
  .cards-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); }
  .coop-card { background: var(--color-paper-2); border: 1px solid var(--color-rule); border-radius: var(--space-xs); padding: var(--space-xl); }
  .card-title { font-family: var(--font-display); font-size: var(--text-lg); font-weight: 700; letter-spacing: -0.02em; color: var(--color-ink); margin-bottom: var(--space-sm); }
  .card-text { font-size: var(--text-base); color: var(--color-muted); line-height: 1.65; }
  .coop-body { padding-bottom: var(--space-3xl); }
  .coop-grid { display: grid; grid-template-columns: 1fr 18rem; gap: var(--space-3xl); align-items: start; }
  .form-wrap { min-width: 0; }
  .ceo-sidebar { position: sticky; top: calc(4.25rem + 3px + var(--space-lg)); }
  .ceo-card { display: flex; flex-direction: column; align-items: center; gap: var(--space-md); padding: var(--space-xl); background: var(--color-paper-2); border: 1px solid var(--color-rule); border-top: 4px solid var(--color-secondary); border-radius: var(--radius-lg); text-align: center; }
  .ceo-card__photo { width: 7rem; height: 7rem; border-radius: var(--radius-pill); object-fit: cover; object-position: center top; }
  .ceo-card__info { display: flex; flex-direction: column; gap: 2px; }
  .ceo-card__name { font-family: var(--font-display); font-size: var(--text-base); font-weight: 700; color: var(--color-ink); }
  .ceo-card__role { font-size: var(--text-sm); color: var(--color-secondary); font-weight: 500; }
  .ceo-card__company { font-size: var(--text-sm); color: var(--color-muted); }
  .ceo-card__linkedin { font-size: var(--text-sm); font-weight: 600; color: var(--color-secondary); text-decoration: none; margin-top: var(--space-2xs); display: inline-block; transition: color var(--dur-micro) var(--ease-out); }
  .ceo-card__linkedin:hover { color: var(--color-ink); }
  .ceo-card__note { font-size: var(--text-sm); color: var(--color-muted); line-height: 1.55; border-top: 1px solid var(--color-rule); padding-top: var(--space-md); margin-top: var(--space-xs); }
  .col-label { font-family: var(--font-display); font-size: var(--text-xl); font-weight: 700; letter-spacing: -0.02em; color: var(--color-ink); margin-bottom: var(--space-xl); }
  .coop-form { display: flex; flex-direction: column; gap: var(--space-lg); }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-md); }
  .field { display: flex; flex-direction: column; gap: var(--space-2xs); }
  .field-label { font-size: var(--text-sm); font-weight: 500; color: var(--color-ink); }
  .req { color: var(--color-accent); margin-left: 1px; }
  .optional { font-size: var(--text-xs); font-weight: 400; color: var(--color-neutral); }
  .field-input { font-family: var(--font-body); font-size: var(--text-base); color: var(--color-ink); background: var(--color-paper); border: 1px solid var(--color-rule); border-radius: var(--space-2xs); padding: var(--space-sm) var(--space-md); width: 100%; outline: none; transition: border-color var(--dur-micro) var(--ease-out), box-shadow var(--dur-micro) var(--ease-out); appearance: none; }
  .field-input::placeholder { color: var(--color-neutral); }
  .field-input:focus { border-color: var(--color-secondary); box-shadow: 0 0 0 3px oklch(56% 0.078 238 / 0.20); }
  .field-input.is-invalid { border-color: var(--color-accent); }
  .field-textarea { resize: vertical; min-height: 7rem; line-height: 1.6; }
  .select-wrap { position: relative; }
  .field-select { cursor: pointer; padding-right: var(--space-xl); }
  .select-arrow { position: absolute; right: var(--space-md); top: 50%; transform: translateY(-50%) rotate(90deg); font-size: var(--text-base); color: var(--color-muted); pointer-events: none; }
  .file-field { display: flex; align-items: center; gap: var(--space-md); flex-wrap: wrap; }
  .file-input { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0; }
  .file-button { font-family: var(--font-body); font-size: var(--text-sm); font-weight: 600; color: var(--color-ink); background: var(--color-paper); border: 1px solid var(--color-rule); border-radius: var(--space-2xs); padding: var(--space-sm) var(--space-lg); cursor: pointer; white-space: nowrap; transition: border-color var(--dur-micro) var(--ease-out), background var(--dur-micro) var(--ease-out); }
  .file-button:hover { border-color: var(--color-secondary); background: var(--color-paper-2); }
  .file-input:focus-visible + .file-button { border-color: var(--color-secondary); box-shadow: 0 0 0 3px oklch(56% 0.078 238 / 0.20); }
  .file-field.is-invalid .file-button { border-color: var(--color-accent); }
  .file-name { font-size: var(--text-sm); color: var(--color-muted); overflow-wrap: anywhere; }
  .file-name.has-file { color: var(--color-ink); font-weight: 500; }
  .file-hint { font-size: var(--text-xs); color: var(--color-neutral); }
  .field-checkbox { gap: var(--space-xs); }
  .checkbox-label { display: flex; align-items: flex-start; gap: var(--space-sm); cursor: pointer; }
  .checkbox-input { width: 1.125rem; height: 1.125rem; flex-shrink: 0; margin-top: 0.125rem; accent-color: var(--color-ink); cursor: pointer; }
  .checkbox-text { font-size: var(--text-sm); color: var(--color-muted); line-height: 1.5; }
  .checkbox-text a { color: var(--color-secondary); text-decoration: underline; text-underline-offset: 3px; }
  .checkbox-text a:hover { color: var(--color-ink); }
  .field-error { font-size: var(--text-xs); color: var(--color-accent); min-height: 1em; display: block; }
  .form-error { font-size: var(--text-sm); color: var(--color-accent); min-height: 1em; }
  .form-error:empty { display: none; }
  .mailto-note { font-size: var(--text-sm); color: var(--color-muted); line-height: 1.6; max-width: 52ch; }
  .mailto-note a { color: var(--color-secondary); text-decoration: underline; text-underline-offset: 3px; }
  .mailto-note a:hover { color: var(--color-ink); }
  .form-req-note { font-size: var(--text-xs); color: var(--color-neutral); }
  .btn-submit { font-family: var(--font-display); font-size: var(--text-base); font-weight: 700; color: var(--color-ink-on-dark); background: var(--color-ink); border: none; border-radius: 9999px; padding: var(--space-sm) var(--space-xl); cursor: pointer; align-self: flex-start; transition: background var(--dur-micro) var(--ease-out), transform var(--dur-micro) var(--ease-out); }
  .btn-submit:hover { background: var(--color-secondary); transform: translateY(-1px); }
  .btn-submit:active { transform: translateY(0); }
  .btn-submit:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
  .success-msg { border: 1px solid oklch(56% 0.078 238 / 0.30); background: var(--color-blue-tint); border-radius: var(--space-xs); padding: var(--space-2xl); text-align: center; }
  .success-inner { display: flex; flex-direction: column; align-items: center; gap: var(--space-md); }
  .success-icon { display: flex; align-items: center; justify-content: center; width: 3rem; height: 3rem; background: var(--color-secondary); color: #fff; border-radius: 9999px; font-size: var(--text-xl); font-weight: 700; }
  .success-title { font-size: var(--text-2xl); font-weight: 700; color: var(--color-ink); letter-spacing: -0.02em; }
  .success-text { font-size: var(--text-md); color: var(--color-muted); max-width: 50ch; }
  .success-text a { color: var(--color-secondary); text-decoration: underline; text-underline-offset: 3px; }
  .success-text a:hover { color: var(--color-ink); }
  .hidden { display: none; }
  @media (max-width: 52rem) {
    .coop-grid { grid-template-columns: 1fr; }
    .ceo-sidebar { position: static; order: -1; }
    .ceo-card { flex-direction: row; text-align: left; align-items: flex-start; }
    .ceo-card__photo { width: 4rem; height: 4rem; flex-shrink: 0; }
    .ceo-card__note { display: none; }
  }
  @media (max-width: 60rem) { .cards-grid { grid-template-columns: 1fr; } .form-row { grid-template-columns: 1fr; } .btn-submit { width: 100%; justify-content: center; } }
  @media (max-width: 40rem) { .coop-h1 { font-size: var(--text-display-s); } }
</style>

<script>
  const form = document.getElementById('partner-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const formError = document.getElementById('form-error');
  const successEl = document.getElementById('success-message');

  const ALLOWED = ['application/pdf', 'application/msword', 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'];
  const ALLOWED_EXT = ['pdf', 'doc', 'docx'];
  const MAX_SIZE = 10 * 1024 * 1024;

  const MESSAGES: Record<string, string> = {
    valueMissing: 'This field is required.',
    typeMismatch: 'Please enter a valid email address.',
    tooShort: 'Description must be at least 20 characters.',
  };

  function errorElFor(el: Element): HTMLElement | null {
    return (el.closest('.field')?.querySelector('.field-error') as HTMLElement | null) ?? null;
  }

  function validateField(el: HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement): boolean {
    if (el instanceof HTMLInputElement && el.type === 'checkbox') {
      const ok = el.checked;
      const errorEl = errorElFor(el);
      if (errorEl) errorEl.textContent = ok ? '' : MESSAGES.valueMissing;
      return ok;
    }
    let msg = '';
    if (!el.validity.valid) {
      if (el.validity.valueMissing) msg = MESSAGES.valueMissing;
      else if (el.validity.typeMismatch) msg = MESSAGES.typeMismatch;
      else if (el.validity.tooShort) msg = MESSAGES.tooShort;
      else msg = el.validationMessage;
    }
    el.classList.toggle('is-invalid', !el.validity.valid);
    const errorEl = errorElFor(el);
    if (errorEl) errorEl.textContent = msg;
    return el.validity.valid;
  }

  const fileInput = document.getElementById('attachment') as HTMLInputElement | null;
  const fileName = document.getElementById('file-name');
  const fileField = fileInput?.closest('.file-field') as HTMLElement | null;

  function setFileError(msg: string) {
    const errorEl = fileInput ? errorElFor(fileInput) : null;
    if (errorEl) errorEl.textContent = msg;
    fileField?.classList.toggle('is-invalid', Boolean(msg));
  }

  function validateFile(silent = false): boolean {
    const file = fileInput?.files?.[0];
    if (!file) {
      if (!silent) setFileError(MESSAGES.valueMissing);
      return false;
    }
    const ext = file.name.split('.').pop()?.toLowerCase() ?? '';
    const typeOk = ALLOWED.includes(file.type) || ALLOWED_EXT.includes(ext);
    if (!typeOk) {
      setFileError('Allowed formats: PDF, DOC, DOCX.');
      if (fileInput) fileInput.value = '';
      if (fileName) { fileName.textContent = 'No file selected'; fileName.classList.remove('has-file'); }
      return false;
    }
    if (file.size > MAX_SIZE) {
      setFileError('File cannot exceed 10 MB.');
      if (fileInput) fileInput.value = '';
      if (fileName) { fileName.textContent = 'No file selected'; fileName.classList.remove('has-file'); }
      return false;
    }
    setFileError('');
    if (fileName) { fileName.textContent = file.name; fileName.classList.add('has-file'); }
    return true;
  }

  fileInput?.addEventListener('change', () => validateFile());

  if (form) {
    form.querySelectorAll('input:not([type="file"]):not([type="checkbox"]), textarea, select').forEach((el) => {
      el.addEventListener('blur', () => validateField(el as HTMLInputElement));
      el.addEventListener('input', () => validateField(el as HTMLInputElement));
    });
    form.querySelector('input[type="checkbox"]')?.addEventListener('change', (e) => validateField(e.target as HTMLInputElement));

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (formError) formError.textContent = '';

      const fields = Array.from(form.querySelectorAll('input:not([type="file"]), textarea, select')) as (HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement)[];
      const fieldsValid = fields.map((el) => validateField(el)).every(Boolean);
      const fileValid = validateFile();

      if (!fieldsValid || !fileValid) {
        const firstInvalid = form.querySelector('.is-invalid, .file-field.is-invalid') as HTMLElement | null;
        (firstInvalid?.querySelector('input, textarea, select') as HTMLElement | null)?.focus();
        firstInvalid?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }

      const val = (id: string) => (document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | null)?.value.trim() ?? '';
      const name = val('name');
      const specEl = document.getElementById('specialization') as HTMLSelectElement;
      const spec = specEl.options[specEl.selectedIndex]?.text ?? '';
      const file = fileInput?.files?.[0];

      const subject = `Collaboration application – ${name}`;
      const body = [
        `Full name: ${name}`,
        `Email: ${val('email')}`,
        `Phone: ${val('phone') || '—'}`,
        `Area of specialization: ${spec}`,
        '',
        'About me:',
        val('about'),
        '',
        '────────────',
        file ? `⚠️ Remember to attach: ${file.name}` : '⚠️ Remember to attach your CV or portfolio to this message.',
      ].join('\n');

      window.location.href = `mailto:biuro@vologis.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

      form.classList.add('hidden');
      document.getElementById('form-label')?.classList.add('hidden');
      successEl?.classList.remove('hidden');
      successEl?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  }
</script>
