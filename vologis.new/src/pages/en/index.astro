---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { localBusinessSchema, speakableSchema } from "../../utils/schema";
import Eyebrow from "../../components/Eyebrow.astro";
import HeroCTAs from "../../components/HeroCTAs.astro";

const serviceCards = [
  {
    num: "01",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="19" r="2.5"/><circle cx="18" cy="5" r="2.5"/><path d="M8.5 19H15a3.5 3.5 0 0 0 0-7H9a3.5 3.5 0 0 1 0-7h6.5"/></svg>`,
    title: "Logistics brokerage &amp; fulfillment",
    desc: "We identify and vet warehouse operators, fulfillment partners and carriers — independently, with no supplier commissions.",
    bullets: [
      "operator verification: warehouses, cold storage, ADR, GDP",
      "SLA and contract negotiation on the client's behalf",
      "e-commerce fulfillment and marketplace integrations",
    ],
    effect: "You get the right logistics partner without months of your own research.",
    href: "/en/services/logistics-brokerage/",
  },
  {
    num: "02",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 15l4-5 3 3 5-7"/></svg>`,
    title: "Operational consulting &amp; audit",
    desc: "We identify bottlenecks, design warehouse processes and select WMS systems — with full implementation.",
    bullets: [
      "warehouse and transport process audit",
      "bottleneck identification and quick wins",
      "WMS and automation selection, implementation roadmap",
    ],
    effect: "You know where money is leaking — and you have a concrete plan to fix it.",
    href: "/en/services/operational-consulting/",
  },
  {
    num: "03",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21V8l9-5 9 5v13"/><path d="M3 21h18"/><path d="M8 21v-6h8v6"/><path d="M8 12h8"/></svg>`,
    title: "Greenfield projects",
    desc: "We run logistics investments end-to-end: from site analysis through masterplan and technology selection to operational launch.",
    bullets: [
      "site analysis and masterplan with CAPEX/OPEX/ROI",
      "independent supplier and technology selection",
      "project supervision and operational start",
    ],
    effect: "An investment without costly mistakes — one partner, full accountability.",
    href: "/en/services/greenfield-projects/",
  },
  {
    num: "04",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="6" height="6" rx="1"/><path d="M9 9 5 5M15 9l4-4M9 15l-4 4M15 15l4 4"/><circle cx="4" cy="4" r="2"/><circle cx="20" cy="4" r="2"/><circle cx="4" cy="20" r="2"/><circle cx="20" cy="20" r="2"/></svg>`,
    title: "Drone services",
    desc: "Land surveys, orthophotomaps, construction monitoring and marketing materials — integrated with logistics projects.",
    bullets: [
      "site surveys and orthophotomaps of investment plots",
      "aerial construction progress monitoring",
      "photo/video materials for property commercialization",
    ],
    effect: "Precise aerial data — faster and cheaper than traditional methods.",
    href: "/en/services/drone-services/",
  },
  {
    num: "05",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 4 14h7l-1 8 9-12h-7l1-8Z"/></svg>`,
    title: "Interim Management",
    desc: "An experienced logistics manager joins your company immediately — stabilizes operations, achieves recovery goals and hands over the reins.",
    bullets: [
      "C-level management support within days",
      "firefighting and operations stabilization",
      "restructuring and change management",
    ],
    effect: "Logistics stabilized — without months of recruitment and the risk of a wrong hire.",
    href: "/en/services/interim-management/",
  },
  {
    num: "06",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17 12h-5M12 7v5"/><path d="M7 17h10a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2Z"/><path d="m15 21-3-3-3 3"/></svg>`,
    title: "Commercialization &amp; sales",
    desc: "Space commercialization, market entry and operator selection — we connect both sides of the logistics market.",
    bullets: [
      "commercialization of vacant pallet volumes (success fee)",
      "market representation and location advisory (market entry)",
      "free logistics partner selection for manufacturing companies",
    ],
    effect: "Sell vacant space or find a partner without your own sales team.",
    href: "/en/services/commercialization-and-sales/",
  },
  {
    num: "07",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/></svg>`,
    title: "Operational security",
    desc: "Loss Prevention, CCTV/access control/IAS and anti-fraud processes for large logistics facilities.",
    bullets: [
      "CCTV, access control and IAS system design",
      "Loss Prevention processes and anti-fraud audit",
      "investigative procedures and evidence preservation",
    ],
    effect: "Protect your margin from losses, collusion and theft that standard security can't see.",
    href: "/en/services/operational-security/",
  },
];

const processSteps = [
  { num: "01", title: "Diagnosis",         desc: "We analyze costs, processes, data, suppliers and the biggest risk sources.",                    output: "problem map and quick recommendations" },
  { num: "02", title: "Analysis & design", desc: "We design the target operating model and change priorities.",                                    output: "action plan, business case and timeline" },
  { num: "03", title: "Implementation",    desc: "We help drive change operationally — not just describe it in a report.",                         output: "new processes, responsibilities and performance control" },
  { num: "04", title: "Monitoring",        desc: "We measure results, correct actions and ensure outcomes are sustained.",                          output: "dashboard, review cycle and further recommendations" },
];

const caseScope = [
  "designing fulfillment operations for B2B and e-commerce channels",
  "implementing a returnable packaging system and managing the return cycle",
  "restructuring order picking and fulfillment processes",
  "supply chain cost optimization (3 years)",
];

const caseMetrics = [
  { val: "12+ mln PLN", label: "savings generated (3 years)" },
  { val: "62%",         label: "reduction in order handling errors" },
  { val: "< 6 months",  label: "ROI on returnable packaging implementation" },
  { val: "0.5 mln PLN/year", label: "recurring savings on packaging" },
];

const audienceChips = [
  "Manufacturing companies",
  "E-commerce",
  "Distributors",
  "TSL operators",
  "Retail & FMCG",
  "Companies expanding in PL + EU",
  "Operators with vacant space",
  "Foreign companies (market entry)",
  "Facilities requiring Loss Prevention",
];

const articles = [
  {
    date: "2026-06-18",
    label: "18 Jun 2026",
    title: "AI and automation in logistics — where it's genuinely worth investing, and where it's just hype",
    href: "/en/insights/ai-automation-logistics/",
  },
  {
    date: "2026-06-12",
    label: "12 Jun 2026",
    title: "Logistics audit — how to objectively identify where your company loses time, money and efficiency",
    href: "/en/insights/logistics-audit/",
  },
  {
    date: "2026-05-28",
    label: "28 May 2026",
    title: "How to choose a logistics partner — and why the lowest price is almost always a trap",
    href: "/en/insights/choosing-a-logistics-partner/",
  },
];

const schemaLocalBusiness = localBusinessSchema();
const schemaSpeakable = speakableSchema("/en/", [
  "[data-speakable='headline']",
  "[data-speakable='summary']",
]);

const schemaArticleList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Latest Vologis articles",
  "itemListElement": articles.map((a, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "Article",
      "headline": a.title,
      "url": `https://vologis.com${a.href}`,
      "datePublished": a.date,
      "publisher": { "@type": "Organization", "name": "Vologis Sp. z o.o.", "url": "https://vologis.com" },
    },
  })),
};
---

<BaseLayout
  title="Vologis — Independent End-to-End Logistics Consulting"
  description="Vologis: logistics brokerage, space commercialization, operational consulting, Greenfield projects, operational security, drone services and Interim Management. From analysis to implementation — independently. Poland and EU."
  canonical="https://vologis.com/en/"
  hreflangPL="/pl/"
  preloadImage="/hero-bg.webp"
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaSpeakable)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaArticleList)} />

  <!-- 1. HERO -->
  <section class="hero" aria-labelledby="hero-h1">
    <div class="container hero-grid">
      <div class="hero-copy">
        <Eyebrow text="LOGISTICS CONSULTING, END TO END" bg="light" />
        <h1 id="hero-h1" class="hero-h1" data-speakable="headline">
          Regain control<br>of your logistics —<br>before it eats your margin.
        </h1>
        <p class="hero-sub" data-speakable="summary">
          Logistics brokerage, space commercialization, operational consulting, Greenfield projects, operational security, drone services and Interim Management — for manufacturing, trading and e-commerce companies. From analysis to implementation, with full accountability for results.
        </p>
        <HeroCTAs
          bg="light"
          primaryHref="/en/contact/"
          primaryLabel="Book a consultation"
          secondaryHref="/en/process/"
          secondaryLabel="See how we work"
        />
        <p class="hero-microproof">
          Audit, recommendations and implementation — no reports gathering dust.
        </p>
      </div>
    </div>
  </section>

  <!-- 2. STATS BAR -->
  <section class="stats-section" aria-label="Vologis team experience">
    <div class="container">
      <div class="stats-strip">
        <div class="stat-item">
          <span class="stat-number tnum">20 years</span>
          <span class="stat-rule" aria-hidden="true"></span>
          <span class="stat-qualifier">of experience in logistics and restructuring</span>
        </div>
        <div class="stat-item">
          <span class="stat-number tnum">90,000 m²</span>
          <span class="stat-rule" aria-hidden="true"></span>
          <span class="stat-qualifier">of warehouse space managed</span>
        </div>
        <div class="stat-item">
          <span class="stat-number tnum">12+ mln PLN</span>
          <span class="stat-rule" aria-hidden="true"></span>
          <span class="stat-qualifier">generated in supply chain savings</span>
        </div>
        <div class="stat-item">
          <span class="stat-number tnum">100+</span>
          <span class="stat-rule" aria-hidden="true"></span>
          <span class="stat-qualifier">branches and locations managed</span>
        </div>
      </div>
      <p class="stats-frame">Vologis team experience from logistics projects over the past 20 years.</p>
    </div>
  </section>

  <!-- 3. PROBLEM -->
  <section class="problem-section" aria-labelledby="problem-heading">
    <div class="container">
      <div class="section-head section-head--center">
        <h2 id="problem-heading" class="section-title">
          Logistics rarely breaks results overnight.<br>Usually it does it quietly.
        </h2>
        <p class="section-intro">
          Rising costs, delays, fragmented suppliers and decisions made without data gradually erode margin and block company growth.
        </p>
      </div>
      <div class="problem-grid">
        {[
          { title: "Transport costs keep rising, but no one knows why",     text: "There's no clear picture of rates, routes, suppliers and real cost drivers." },
          { title: "The warehouse runs, but keeps slowing down",            text: "Processes can't keep up with sales volume, seasonality or scale changes." },
          { title: "Suppliers are fragmented and hard to control",          text: "The company has more and more partners, but less and less visibility." },
          { title: "Decisions are made without data",                       text: "Reports are inconsistent and operations run on gut feeling rather than facts." },
          { title: "The company grows faster than its processes",           text: "What used to work is now generating delays, costs and chaos." },
          { title: "Seasonal peaks break operations",                       text: "Every peak brings chaos, overtime and errors — instead of a predictable process." },
        ].map((c) => (
          <div class="problem-card">
            <h3 class="problem-card__title">{c.title}</h3>
            <p class="problem-card__text">{c.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. SERVICES -->
  <section class="services-section" aria-labelledby="services-heading">
    <div class="container">
      <div class="section-head section-head--center">
        <p class="eyebrow eyebrow--accent">What we do</p>
        <h2 id="services-heading" class="section-title">
          Seven areas, one goal:<br>logistics that drives growth.
        </h2>
        <p class="section-intro">
          From logistics brokerage and space commercialization through operational consulting and Greenfield projects to operational security, drones and Interim Management — we combine them into one accountability for results.
        </p>
      </div>
      <div class="services-grid">
        {serviceCards.map((s) => (
          <article class="svc-card">
            <div class="svc-card__top">
              <div class="svc-icon" aria-hidden="true" set:html={s.icon} />
              <span class="svc-num tnum" aria-hidden="true">{s.num}</span>
            </div>
            <h3 class="svc-title" set:html={s.title} />
            <p class="svc-desc">{s.desc}</p>
            <ul class="svc-bullets" role="list">
              {s.bullets.map((b) => (
                <li class="svc-bullet">
                  <svg class="svc-check" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m4 10.5 4 4 8-9" /></svg>
                  {b}
                </li>
              ))}
            </ul>
            <div class="svc-effect">
              <span class="svc-effect__label">Result</span>
              <p class="svc-effect__text">{s.effect}</p>
            </div>
            <a class="svc-link" href={s.href}>Explore service <span aria-hidden="true">→</span></a>
          </article>
        ))}
        <article class="hp-cta-tile" aria-label="Free consultation — not sure where to start?">
          <div class="hp-cta-tile__head">
            <span class="hp-cta-tile__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
            </span>
          </div>
          <h3 class="hp-cta-tile__title">Not sure where to start?</h3>
          <p class="hp-cta-tile__body">Tell us where it hurts. We'll identify which service will genuinely solve your problem — or whether you need several combined into one project. Free consultation, no commitment.</p>
          <a class="btn-primary hp-cta-tile__btn" href="/en/contact/">Book a consultation <span aria-hidden="true">→</span></a>
        </article>
      </div>
    </div>
  </section>

  <!-- 5. PROCESS -->
  <section class="process-section" aria-labelledby="process-heading">
    <div class="container">
      <div class="section-head section-head--center section-head--on-dark">
        <p class="eyebrow eyebrow--on-dark">How we work</p>
        <h2 id="process-heading" class="section-title">From diagnosis to measurable results.</h2>
        <p class="section-intro">
          Every project starts with understanding the problem — not with a ready-made solution.
        </p>
      </div>
      <div class="process-visual">
        <img
          src="/process-visual.webp"
          alt="Visual representation of the Vologis process: diagnosis, analysis, implementation and monitoring of logistics operations"
          class="process-visual__img"
          width="1536"
          height="512"
          loading="lazy"
          decoding="async"
        />
      </div>
      <ol class="process-steps">
        {processSteps.map((step) => (
          <li class="process-step">
            <span class="step-num tnum" aria-hidden="true">{step.num}</span>
            <h3 class="step-title">{step.title}</h3>
            <p class="step-desc">{step.desc}</p>
            <p class="step-output">
              <span class="step-output__label">Output:</span>
              {step.output}
            </p>
          </li>
        ))}
      </ol>
      <div class="process-cta">
        <a href="/en/process/" class="btn-outline btn-outline--on-dark">Full process description →</a>
      </div>
    </div>
  </section>

  <!-- 6. CASE / PROOF -->
  <section class="case-section" aria-labelledby="case-heading">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow eyebrow--accent">Proof in practice</p>
          <h2 id="case-heading" class="section-title">Results you can measure.</h2>
        </div>
      </div>
      <p class="case-intro">
        We don't stop at recommendations. We help translate analysis into decisions, implementation and outcome control.
      </p>
      <div class="case-grid">
        <div class="case-card">
          <div class="case-card__header">
            <p class="case-card__type">B2B / e-commerce operator (international)</p>
            <span class="case-badge">Anonymized</span>
          </div>
          <h3 class="case-card__title">European Fulfillment Hub — operational transformation</h3>
          <p class="case-frame">Project delivered by Vologis founder in a previous management role.</p>
          <div class="case-cols">
            <div>
              <p class="case-cols__label">Scope</p>
              <ul class="case-list" role="list">
                {caseScope.map((item) => (
                  <li class="case-list__item">
                    <svg class="case-list__icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m4 10.5 4 4 8-9" /></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
            <div>
              <p class="case-cols__label">Results</p>
              <ul class="case-metrics" role="list">
                {caseMetrics.map((m) => (
                  <li class="case-metric">
                    <span class="case-metric__val tnum">{m.val}</span>
                    <span class="case-metric__label">{m.label}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
        <div class="case-track" aria-label="Vologis founder experience">
          <p class="case-track__eyebrow">The experience behind the project</p>
          <p class="case-track__intro">The project is part of the Vologis founder's 20 years of operational experience — including managing branch networks, fulfillment projects and facility relocations across the EU.</p>
          <ul class="case-track__stats" role="list">
            <li class="case-track__stat"><span class="case-track__val tnum">100+</span><span class="case-track__label">branches and locations managed</span></li>
            <li class="case-track__stat"><span class="case-track__val tnum">400+</span><span class="case-track__label">people in managed teams</span></li>
            <li class="case-track__stat"><span class="case-track__val tnum">15</span><span class="case-track__label">logistics facility audits and relocations</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. FOR WHOM -->
  <section class="audience-section" aria-labelledby="audience-heading">
    <div class="container">
      <div class="section-head section-head--center">
        <p class="eyebrow eyebrow--accent">Who it's for</p>
        <h2 id="audience-heading" class="section-title">
          For companies where logistics<br>has a direct impact on results.
        </h2>
        <p class="section-intro">
          We work with organizations that want to bring order to operations, reduce costs and make data-driven decisions.
        </p>
      </div>
      <div class="audience-chips" role="list" aria-label="Target groups">
        {audienceChips.map((chip) => (
          <span class="audience-chip" role="listitem">{chip}</span>
        ))}
      </div>
      <p class="audience-note">
        We deliver the greatest value where growth scale starts to expose problems in costs, processes and supplier management.
      </p>
    </div>
  </section>

  <!-- 8. ARTICLES -->
  <section class="knowledge-section" aria-labelledby="knowledge-heading">
    <div class="container">
      <div class="knowledge-header">
        <div>
          <p class="eyebrow eyebrow--accent">Practical insights</p>
          <h2 id="knowledge-heading" class="section-title">Analysis and commentary.</h2>
          <p class="knowledge-sub">
            Analysis, case studies and commentary on logistics, costs, transport and supply chain.
          </p>
        </div>
        <a href="/en/insights/" class="btn-outline">All articles →</a>
      </div>
      <ol class="article-list" role="list">
        {articles.map((art) => (
          <li class="article-item">
            <time class="article-date" datetime={art.date}>{art.label}</time>
            <a href={art.href} class="article-title">{art.title}</a>
            <span class="article-read" aria-hidden="true">Read →</span>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- 9. LINKEDIN -->
  <section class="linkedin-section" aria-label="LinkedIn activity">
    <div class="container">
      <div class="linkedin-head">
        <div class="linkedin-copy">
          <p class="eyebrow eyebrow--accent">LinkedIn</p>
          <h2 class="linkedin-title">Follow us on LinkedIn.</h2>
          <p class="linkedin-sub">
            TSL market analysis, case studies, regulatory updates and practical insights from projects.
          </p>
        </div>
        <a
          href="https://www.linkedin.com/company/vologis"
          class="btn-outline"
          target="_blank"
          rel="noopener noreferrer"
        >
          Follow Vologis →
        </a>
      </div>
      <div class="linkedin-widget" id="linkedin-widget-container">
        <div class="sk-ww-linkedin-profile-post" data-embed-id="25688916"></div>
      </div>
    </div>
  </section>

  <!-- 10. FINAL CTA -->
  <section class="cta-section" aria-labelledby="cta-heading">
    <div class="container">
      <div class="cta-inner">
        <div class="cta-copy">
          <p class="eyebrow eyebrow--on-dark">Free consultation</p>
          <h2 id="cta-heading" class="cta-title">Start with diagnosis,<br>not guesswork.</h2>
          <p class="cta-sub">
            In 30 minutes we'll assess where logistics is generating your biggest costs, risks or growth blockers — and what actions are worth taking first.
          </p>
          <button class="btn-accent" data-calendly="popup" type="button">
            Book a consultation
          </button>
        </div>
        <div class="cta-form">
          <p class="cta-form-label">Prefer to write? Leave your details.</p>
          <form
            class="contact-form"
            action="https://formspree.io/f/mjgdvnav"
            method="post"
            aria-label="Quick contact form"
          >
            <input type="hidden" name="_subject" value="New enquiry — Vologis (homepage EN)" />
            <input type="text"  name="name"    placeholder="Full name"    class="form-input" aria-label="Full name" />
            <input type="email" name="email"   placeholder="Email address" class="form-input" aria-label="Email address" required />
            <textarea name="message" placeholder="Your biggest logistics challenge" class="form-input form-textarea" aria-label="Message" rows="3"></textarea>
            <button type="submit" class="form-submit">Send enquiry →</button>
          </form>
          <p class="form-note">We'll respond with a concrete proposal for next steps.</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  section { padding-block: var(--space-3xl); }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: var(--space-md);
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
  }
  .eyebrow::before { content: ""; width: 1.5rem; height: 2px; background: currentColor; border-radius: 2px; flex-shrink: 0; }
  .eyebrow--accent { color: oklch(50% 0.210 22); }
  .eyebrow--on-dark { color: var(--color-blue-on-dark); }
