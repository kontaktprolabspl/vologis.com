---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProcessStep from "../../components/ProcessStep.astro";
import PricingCard from "../../components/PricingCard.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";
import FaqAccordion from "../../components/FaqAccordion.astro";
import Eyebrow from "../../components/Eyebrow.astro";
import HeroCTAs from "../../components/HeroCTAs.astro";

const SITE = "https://vologis.com";

const heroSteps = [
  { num: "01", name: "Needs analysis & identification" },
  { num: "02", name: "Quick Wins" },
  { num: "03", name: "Location & partner selection" },
  { num: "04", name: "Operational implementation" },
  { num: "05", name: "Optimization & KPIs" },
];

const steps = [
  {
    number: "01",
    title: "Needs analysis & identification",
    hook: "We start by listening, not presenting.",
    description: "We go on-site, observe processes, talk to people at every level. We assume nothing upfront — we verify. For larger projects we prepare a full business analysis or pre-investment documentation.",
    deliverables: [
      "Precise problem definition and its scale",
      "Pre-investment documentation (large projects)",
      "Action plan with prioritized areas",
      "Realistic timeline and billing model",
    ],
    callout: "At this stage it often turns out the real problem is somewhere completely different from where the client thought. That's why we don't send a questionnaire — we show up in person.",
  },
  {
    number: "02",
    title: "Quick Wins / Rapid optimization",
    hook: "First results — before the main project is complete.",
    description: "Most consulting firms skip this stage entirely. For us it's standard. Based on the initial analysis we immediately implement low-cost process changes — so-called low-hanging fruit. The client sees results within weeks, not months.",
    deliverables: [
      "Immediate release of blocked resources",
      "Elimination of the most pressing operational errors",
      "First, measurable KPI improvements",
      "Proof that the collaboration works — before you invest more",
    ],
    callout: "Clients can't wait 6 months for results. Quick Wins is our way of building trust backed by numbers — not promises.",
  },
  {
    number: "03",
    title: "Location & partner selection",
    hook: "No operator pays us. No developer sponsors us.",
    description: "We carry out rigorous market research — analyze infrastructure, compare operators, select technologies and negotiate terms on the client's behalf. We have no ties to any partner network — we recommend what's best for your ROI.",
    deliverables: [
      "Concept design with variants",
      "Objective location or operator comparison",
      "Hard bid comparison and negotiated terms",
      "Optimal solution recommendation with rationale",
    ],
    callout: "A real estate agency will find you a warehouse. A WMS vendor will sell you software. We combine location, operations, technology and drones into one ecosystem — with no conflict of interest.",
  },
  {
    number: "04",
    title: "Operational implementation",
    hook: "We coordinate everyone. We're accountable for everything.",
    description: "We take on the full project coordination burden — from facility preparation oversight through system and infrastructure rollout to team training and recruitment. The client has one point of contact instead of dozens of suppliers.",
    deliverables: [
      "Fully launched operations on the agreed date",
      "Deployed systems (WMS, TMS) and infrastructure",
      "Trained and ready-to-work team",
      "Process and operational standards documentation",
    ],
    callout: "Most logistics projects run 30–50% over schedule due to lack of coordination between suppliers. We take that coordination on. It's not optional — it's our standard.",
  },
  {
    number: "05",
    title: "Optimization & operational development",
    hook: "The project ends when KPIs are achieved — not before.",
    description: "After the operational launch we monitor processes, measure actual KPIs and compare them against the goals set at the project start. If something isn't working as it should — we correct it. The project ends for us when we see the numbers: faster picking, lower cost per line, less frozen capital.",
    deliverables: [
      "KPIs achieved as agreed at the start of engagement",
      "Measurable reduction in operational costs",
      "Stable, scalable process ready for growth",
      "Ongoing consultation and support after project close",
    ],
    callout: "We don't end the engagement on handover day. We're available. If the market changes or new challenges emerge — we come back.",
  },
];

const valueProps = [
  {
    value: "Confidence that the problem will be solved, not just described",
    deliver: "Full implementation accountability — not just recommendations",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3 4 6v5c0 5 3.5 8 8 10 4.5-2 8-5 8-10V6l-8-3Z"/><path d="m8.5 12 2.5 2.5 4.5-5"/></svg>`,
  },
  {
    value: "Objective decisions free from supplier pressure",
    deliver: "100% independence — no hidden commissions or partner ties",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18M5 7h14M6 7l-3 7a4 4 0 0 0 6 0L6 7Zm12 0-3 7a4 4 0 0 0 6 0l-3-7Z"/></svg>`,
  },
  {
    value: "First results while the project is still running",
    deliver: "Quick Wins in phase 2 — before the main work is done",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 4 14h7l-1 8 9-12h-7l1-8Z"/></svg>`,
  },
];

const pricing = [
  { title: "Fixed-scope billing", desc: "Fixed price for a defined scope. Ideal for audits and projects with a clearly defined deliverable.", tag: "Audits · Greenfield projects" },
  { title: "Milestone-based billing", desc: "Payments tied to completing successive phases. Transparent milestones, zero surprises.", tag: "Implementations · Multi-phase projects" },
  { title: "Success fee", desc: "Compensation tied to outcomes. We share the risk — we earn when the project delivers results.", tag: "Cost optimization · Restructuring" },
];

const comparison = [
  { feature: "Scope of work", vologis: "End-to-end: analysis → implementation → KPIs", other: "Report or one process fragment" },
  { feature: "Independence", vologis: "100% — zero supplier commissions", other: "Often tied to operators or vendors" },
  { feature: "Response time", vologis: "We start from Monday", other: "Weeks of onboarding" },
  { feature: "Quick Wins", vologis: "Standard in phase 2", other: "Rare or absent" },
  { feature: "Cost model", vologis: "Project-based / success fee — OPEX only when needed", other: "Fixed OPEX or expensive retainer" },
  { feature: "Perspective", vologis: "External, objective, no internal politics", other: "Entangled in internal structures" },
  { feature: "Technology", vologis: "Drones + WMS + operations = integrated ecosystem", other: "Specialized silos" },
];

const faqs = [
  { q: "How long does a typical project take?", a: "Every project is different. A quick audit with quick wins: 2–4 weeks. A full Greenfield project from analysis to launch: 3–12 months. We set the timeline at the first meeting based on scope and the client's available resources." },
  { q: "What does the free consultation look like?", a: "30 minutes online or by phone. We listen, ask questions, assess whether we can help. No sales presentations. If your problem is outside our expertise — we'll say so directly and point you to the right partner." },
  { q: "Can I commission just one stage, e.g. only an audit?", a: "Yes. Each stage can be commissioned separately. Many clients start with an audit and after reviewing the findings decide to implement the recommendations. There's no obligation to continue." },
  { q: "Does Vologis favour specific WMS vendors or operators?", a: "No. We are 100% independent — zero supplier commissions, zero partner ties. We select solutions solely based on client ROI." },
  { q: "How do drone services differ from standard consulting?", a: "Drone services are a tool integrated with investment projects — not a standalone photography service. Orthophotomaps, land surveys and aerial marketing materials are delivered directly as part of Greenfield and investment projects." },
  { q: "How does success fee billing work?", a: "We jointly define a baseline metric (e.g. operational cost per unit) and the target improvement level. Compensation is tied to the actual change in that metric measured over an agreed period. Details are negotiated individually." },
];

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",        "item": `${SITE}/en/` },
    { "@type": "ListItem", "position": 2, "name": "How we work", "item": `${SITE}/en/process/` },
  ],
};

const schemaHowTo = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Vologis 5-step process — from analysis to KPIs",
  "description": "Five-stage logistics consulting and implementation process: needs analysis, quick wins, partner selection, operational implementation, and optimization.",
  "step": steps.map((s, i) => ({
    "@type": "HowToStep",
    "position": i + 1,
    "name": s.hook,
    "text": s.description,
    "supply": s.deliverables.map((d) => ({ "@type": "HowToSupply", "name": d })),
    "url": `${SITE}/en/process#step-${s.number}`,
  })),
};

const schemaFaq = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((f) => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
};
---

<BaseLayout
  title="How We Work — End-to-End Process | Vologis"
  description="Vologis 5-step process — from analysis to implementation. We don't leave you with a report. The project ends when results show in the KPIs."
  canonical="https://vologis.com/en/process/"
  hreflangPL="/pl/proces/"
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaHowTo)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFaq)} />

  <!-- 1. Hero -->
  <section class="hero" aria-labelledby="hero-h">
    <div class="container hero__grid">
      <div class="hero__copy">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <ol class="breadcrumb-list" role="list">
            <li><a href="/en/">Home</a></li>
            <li aria-hidden="true" class="breadcrumb-sep">›</li>
            <li aria-current="page">How we work</li>
          </ol>
        </nav>
        <Eyebrow text="HOW WE WORK" />
        <h1 id="hero-h" class="hero__h1">The project ends<br>when the numbers show —<br>not when we hand over the report.</h1>
        <p class="hero__sub">Five stages. Full accountability. From first analysis to KPI achievement — without leaving you halfway.</p>
        <HeroCTAs primaryLabel="Book a consultation" primaryHref="/en/contact/" secondaryLabel="See our services" secondaryHref="/en/services/" />
      </div>
      <ol class="hero__steps" aria-label="Process stages">
        {heroSteps.map((s) => (
          <li class="hero__pill">
            <span class="hero__pill-num tnum" aria-hidden="true">{s.num}</span>
            <span class="hero__pill-name">{s.name}</span>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- 2. Value proposition strip -->
  <section class="vps" aria-label="What we deliver">
    <div class="container">
      <div class="vps__grid">
        {valueProps.map((v) => (
          <div class="vps__col">
            <span class="vps__icon" aria-hidden="true" set:html={v.icon}></span>
            <p class="vps__label">Value:</p>
            <p class="vps__value">{v.value}</p>
            <p class="vps__label vps__label--deliver">We deliver:</p>
            <p class="vps__deliver">{v.deliver}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. Process steps -->
  <section class="steps-section" aria-labelledby="steps-h">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow eyebrow--accent">Step by step</p>
        <h2 id="steps-h" class="section-title">Five stages. One accountability.</h2>
      </div>
      <div class="psteps">
        {steps.map((s, i) => (
          <div id={`step-${s.number}`}>
            <ProcessStep
              number={s.number}
              title={s.title}
              hook={s.hook}
              description={s.description}
              deliverables={s.deliverables}
              callout={s.callout}
              reverse={i % 2 === 1}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. Billing models -->
  <section class="pricing" aria-labelledby="pricing-h">
    <div class="container">
      <div class="section-head">
        <h2 id="pricing-h" class="section-title">Transparent billing — three models</h2>
        <p class="section-intro">We don't impose a billing model. We choose the one that aligns your interests with ours.</p>
      </div>
      <div class="pricing__grid">
        {pricing.map((p) => (
          <PricingCard title={p.title} desc={p.desc} tag={p.tag} />
        ))}
      </div>
    </div>
  </section>

  <!-- 5. Comparison -->
  <section class="compare" aria-labelledby="compare-h">
    <div class="container">
      <div class="section-head">
        <h2 id="compare-h" class="section-title">Vologis vs. a standard consulting firm</h2>
        <p class="section-intro">Why an external partner beats an in-house team — and how we differ from large consulting firms.</p>
      </div>
      <ComparisonTable rows={comparison} />
    </div>
  </section>

  <!-- 6. FAQ -->
  <section class="faq-section" aria-labelledby="faq-h">
    <div class="container">
      <div class="section-head">
        <h2 id="faq-h" class="section-title">FAQ — How we work</h2>
      </div>
      <FaqAccordion items={faqs} single />
    </div>
  </section>

  <!-- 7. CTA -->
  <section class="cta-section" aria-labelledby="cta-h">
    <div class="container">
      <div class="cta-section__inner">
        <h2 id="cta-h" class="cta-section__title">Ready to start?</h2>
        <p class="cta-section__sub">Tell us what you're dealing with. We'll be direct about whether we can help — and how.</p>
        <div class="cta-section__actions">
          <a href="/en/contact/" class="cta cta--primary">Book a free consultation <span aria-hidden="true">→</span></a>
          <a href="/en/services/" class="cta cta--ghost-light">See our services <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .eyebrow { font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: var(--space-md); }
  .eyebrow--accent { color: oklch(50% 0.210 22); }
  .section-head { margin-bottom: var(--space-2xl); max-width: 60ch; }
  .section-title { font-family: var(--font-display); font-size: var(--text-3xl); font-weight: 700; letter-spacing: -0.03em; line-height: 1.1; color: var(--color-ink); }
  .section-intro { margin-top: var(--space-md); font-size: var(--text-md); color: var(--color-muted); line-height: 1.6; }
  .cta { display: inline-flex; align-items: center; gap: var(--space-2xs); font-family: var(--font-display); font-size: var(--text-base); font-weight: 700; border-radius: var(--radius-pill); padding: var(--space-sm) var(--space-xl); text-decoration: none; border: 1px solid transparent; transition: background var(--dur-micro) var(--ease-out), border-color var(--dur-micro) var(--ease-out), color var(--dur-micro) var(--ease-out), transform var(--dur-micro) var(--ease-out); }
  .cta span { display: inline-block; transition: transform var(--dur-short) var(--ease-out); }
  .cta:hover span { transform: translateX(4px); }
  .cta--primary { background: var(--color-blue); color: #fff; }
  .cta--primary:hover { background: var(--color-secondary); transform: translateY(-1px); }
  .cta--ghost-light { color: var(--color-ink-on-dark); border-color: var(--color-glass-border); }
  .cta--ghost-light:hover { background: var(--color-ink-on-dark); color: var(--color-ink); }

  .hero { background: var(--color-paper-dark); color: var(--color-ink-on-dark); min-height: 100vh; display: flex; align-items: center; padding-top: calc(var(--space-3xl) + 5rem); padding-bottom: var(--space-3xl); }
  .hero__grid { display: grid; grid-template-columns: 3fr 2fr; gap: var(--space-3xl); align-items: center; width: 100%; }
  .hero .eyebrow { color: var(--color-blue-on-dark); }
  .hero__h1 { font-family: var(--font-display); font-size: var(--text-display-s); font-weight: 700; letter-spacing: -0.03em; line-height: 1.08; color: var(--color-ink-on-dark); margin-bottom: var(--space-lg); }
  .hero__sub { font-size: var(--text-md); color: var(--color-muted-on-dark); line-height: 1.6; max-width: 34rem; margin-bottom: var(--space-xl); }
  .hero__steps { list-style: none; display: flex; flex-direction: column; gap: 0; position: relative; }
  .hero__pill { display: flex; align-items: center; gap: var(--space-md); padding: var(--space-md) var(--space-lg); background: oklch(100% 0 0 / 0.04); border: 1px solid var(--color-glass-border); border-radius: var(--radius-md); position: relative; }
  .hero__pill + .hero__pill { margin-top: var(--space-md); }
  .hero__pill:not(:last-child)::after { content: ""; position: absolute; left: calc(var(--space-lg) + 0.75rem); top: 100%; height: var(--space-md); border-left: 2px solid var(--color-glass-border); }
  .hero__pill-num { font-family: var(--font-display); font-weight: 700; font-size: var(--text-md); color: var(--color-blue-on-dark); flex-shrink: 0; }
  .hero__pill-name { font-size: var(--text-base); font-weight: 500; color: var(--color-ink-on-dark); }

  .vps { background: var(--color-paper-2); padding-block: var(--space-3xl); }
  .vps__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-2xl); }
  .vps__icon { display: grid; place-items: center; width: 3rem; height: 3rem; border-radius: var(--radius-md); background: var(--color-paper); color: var(--color-blue); margin-bottom: var(--space-lg); }
  .vps__icon :global(svg) { width: 1.5rem; height: 1.5rem; }
  .vps__label { font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-accent); margin-bottom: var(--space-2xs); }
  .vps__label--deliver { color: var(--color-blue); margin-top: var(--space-md); }
  .vps__value { font-family: var(--font-display); font-size: var(--text-lg); font-weight: 700; letter-spacing: -0.02em; line-height: 1.2; color: var(--color-ink); }
  .vps__deliver { font-size: var(--text-base); color: var(--color-muted); line-height: 1.6; }

  .steps-section { padding-block: var(--space-3xl); }
  .psteps { position: relative; max-width: 64rem; margin-inline: auto; }
  .psteps::before { content: ""; position: absolute; left: 50%; top: 2rem; bottom: 2rem; border-left: 2px dashed var(--color-blue); opacity: 0.4; transform: translateX(-50%); }
  .psteps > div { position: relative; }
  .psteps > div + div { margin-top: var(--space-3xl); }

  .pricing { background: var(--color-paper-2); padding-block: var(--space-3xl); }
  .pricing .section-head { text-align: center; margin-inline: auto; }
  .pricing__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-lg); }

  .compare { padding-block: var(--space-3xl); }

  .faq-section { background: var(--color-paper-2); padding-block: var(--space-3xl); }

  .cta-section { background: var(--color-paper-dark); padding-block: var(--space-3xl); }
  .cta-section__inner { text-align: center; max-width: 44rem; margin-inline: auto; }
  .cta-section__title { font-family: var(--font-display); font-size: var(--text-3xl); font-weight: 700; letter-spacing: -0.03em; color: var(--color-ink-on-dark); margin-bottom: var(--space-md); }
  .cta-section__sub { font-size: var(--text-md); color: var(--color-muted-on-dark); line-height: 1.6; margin-bottom: var(--space-xl); }
  .cta-section__actions { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }

  .breadcrumb { margin-bottom: var(--space-lg); }
  .breadcrumb-list { display: flex; align-items: center; gap: var(--space-xs); list-style: none; font-size: var(--text-sm); color: var(--color-muted-on-dark); }
  .breadcrumb-list a { color: var(--color-muted-on-dark); text-decoration: none; transition: color var(--dur-micro) var(--ease-out); }
  .breadcrumb-list a:hover { color: var(--color-ink-on-dark); }
  .breadcrumb-sep { color: var(--color-muted-on-dark); opacity: 0.6; user-select: none; }
  .breadcrumb-list [aria-current="page"] { color: var(--color-ink-on-dark); font-weight: 500; }

  @media (max-width: 60rem) {
    .hero { min-height: 0; }
    .hero__grid { grid-template-columns: 1fr; gap: var(--space-2xl); }
    .hero__steps { order: 2; }
    .vps__grid { grid-template-columns: 1fr; gap: var(--space-2xl); }
    .pricing__grid { grid-template-columns: 1fr; }
    .psteps::before { display: none; }
  }
</style>
