---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FaqAccordion from "../../components/FaqAccordion.astro";
import Eyebrow from "../../components/Eyebrow.astro";
import HeroCTAs from "../../components/HeroCTAs.astro";

const SITE = "https://vologis.com";

const trustItems = [
  "Operating since March 2011",
  "Logistics, forwarding, transport and consulting",
  "Domestic and international transport",
  "Supporting companies in Poland and Europe",
  "Approach tailored to each client's situation",
];

const briefItems = [
  { key: "What Vologis is:", val: "a logistics consulting firm supporting businesses in logistics, forwarding, transport and operational process management." },
  { key: "Who it helps:", val: "manufacturing, trading, distribution, e-commerce companies and organizations that want to better manage transport and processes." },
  { key: "Since:", val: "Vologis has been operating since March 2011." },
  { key: "How it works:", val: "we build the scope of cooperation around the client's situation and needs, avoiding ad hoc actions." },
];

const philosophyCards = [
  { title: "Logistics must support the business", text: "Transport, warehousing and forwarding should be aligned with the company's operating model — not function as a separate area disconnected from sales, production or finance." },
  { title: "Cost means more than the transport rate", text: "The cheapest quote can generate hidden costs: delays, complaints, downtime, extra team workload or a loss of predictability." },
  { title: "Process matters more than intervention", text: "A one-off fix only helps for a moment. That's why we look for root causes, recurring patterns and decisions that improve the organization over the long term." },
  { title: "Partners must be vetted", text: "In transport and forwarding, trust in subcontractors has a direct impact on cargo safety, on-time delivery and client communication." },
  { title: "Data enables better decisions", text: "Without data it's hard to distinguish a real problem from a feeling. That's why in consulting and logistics projects, facts, KPIs and process analysis matter." },
  { title: "Long-term relationships deliver greater impact", text: "The greatest value emerges when a logistics partner understands the company's rhythm, its customers, constraints and growth objectives." },
];

const expertiseCards = [
  { num: "01", title: "Logistics", text: "We help optimize logistics costs and processes, design more ordered goods, information and responsibility flows, and build solutions tailored to the company's real needs." },
  { num: "02", title: "Forwarding", text: "We support shipment organization, mode of transport selection, documentation, pre-advising, consignment preparation, dispatch, collection and order coordination with a dedicated account manager." },
  { num: "03", title: "Domestic & international transport", text: "We organize transport across Poland and Europe, including full-truck FTL and part-load LTL, matching the solution to the cargo, timeline and client requirements." },
  { num: "04", title: "Logistics consulting", text: "We analyze processes, costs, risks and bottlenecks. We help companies make decisions about logistics organization, warehousing, transport and partner management." },
  { num: "05", title: "Management consulting", text: "We help companies improve organization, process control, budgeting, analysis and implementing actions that increase operational efficiency." },
  { num: "06", title: "Audits & improvements", text: "We help objectively assess the current state of the organization, identify the sources of problems and build an action plan that separates quick wins from strategic projects." },
];

const processSteps = [
  { num: "01", title: "We start by understanding the situation", text: "First we establish what the company genuinely needs: transport, forwarding support, audit, consulting or ordering a specific process." },
  { num: "02", title: "We analyze real constraints", text: "We factor in deadlines, costs, cargo type, recipient requirements, available data, current processes and the client team's capacity." },
  { num: "03", title: "We select the solution", text: "We don't propose random actions. We tailor the scope of work to the client's situation so the solution is implementable and business-justified." },
  { num: "04", title: "We coordinate and communicate", text: "In logistics, communication quality is as important as the service itself. We ensure clear agreements, clear accountability and good information flow." },
  { num: "05", title: "We draw conclusions", text: "In an ongoing relationship, we analyze recurring issues, costs and improvement opportunities so each successive decision gets better." },
];

const principleCards = [
  { title: "Diagnosis first, then action", text: "Not every company needs the same solution. That's why we start by understanding the problem, and only then recommend action." },
  { title: "Partnership over transaction", text: "The greatest value comes from collaboration built on trust, knowledge of the client's operations and long-term thinking about efficiency." },
  { title: "Accountability for the details", text: "In logistics, details determine the outcome: a document, a deadline, a pre-advice, carrier selection, loading method and communication when problems arise." },
  { title: "Practice over theory", text: "Consulting only makes sense when it leads to decisions that can be implemented in the company's real environment." },
  { title: "We understand cost as more than price", text: "We look at the total cost of a decision: the rate, team time, risk, delays, complaints and impact on the end customer." },
  { title: "Solutions tailored to the client", text: "We build the scope of activities around the company's situation and needs, rather than imposing one ready-made collaboration model." },
];

const timelineItems = [
  { year: "2011", title: "Vologis launches", text: "Vologis begins operations in advisory and direct management support for business entities." },
  { year: "Following years", title: "Building logistics competencies", text: "The company develops support in logistics, forwarding, transport and logistics consulting, responding to client needs around operational efficiency." },
  { year: "Today", title: "Logistics and advisory partner for companies", text: "Vologis supports clients in Poland and Europe, helping organize transport, optimize processes and make better logistics decisions." },
];

const whyVologis = [
  "We combine transport, forwarding, logistics and consulting in one partnership.",
  "We work individually, tailored to the client's situation.",
  "We help reduce random decisions in logistics.",
  "We support both day-to-day operations and long-term improvements.",
  "We look at cost, risk, quality and predictability.",
  "We understand logistics as part of the whole organization, not just a transport service.",
  "We work with companies that want to grow without increasing operational chaos.",
];

const clientTypes = [
  "Manufacturing companies",
  "Trading companies",
  "Distributors",
  "E-commerce and D2C",
  "Importers and exporters",
  "Companies expanding into new markets",
  "Organizations planning to bring order to logistics",
  "Companies needing transport or forwarding support",
];

const faqs = [
  { q: "What does Vologis do?", a: "Vologis supports companies in logistics, forwarding, transport, logistics consulting and management consulting. It helps organize transport, bring order to processes, optimize costs and make better operational decisions." },
  { q: "How long has Vologis been operating?", a: "Vologis has been providing services since March 2011. From the start, the company has focused on consulting, management support and helping businesses in areas affecting operational efficiency." },
  { q: "What types of companies does Vologis work with?", a: "Vologis works with manufacturing, trading, distribution and e-commerce companies, as well as organizations that need support in transport, forwarding, logistics or process optimization." },
  { q: "Does Vologis handle domestic and international transport?", a: "Yes. Vologis supports domestic and international transport, including European Union routes, FTL full-truck and LTL part-load shipments." },
  { q: "Does Vologis provide logistics consulting?", a: "Yes. Logistics consulting is one of Vologis's core activities. The firm helps analyze processes, costs, work organization and decisions affecting company logistics." },
  { q: "What does working with Vologis look like?", a: "Cooperation starts with understanding the client's situation. Vologis then tailors the scope of activities, organizes the service or recommends solutions suited to needs, costs, timelines and operational risk." },
  { q: "Does Vologis only operate locally?", a: "Vologis is headquartered in Jarocin, but supports clients throughout Poland and Europe, particularly in transport, forwarding, logistics and consulting." },
];

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE}/en/` },
    { "@type": "ListItem", "position": 2, "name": "About", "item": `${SITE}/en/about/` },
  ],
};

const schemaAboutPage = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About — Vologis",
  "description": "Meet Vologis — an independent consulting firm specializing in logistics brokerage, operational consulting, Greenfield projects, drone services and Interim Management.",
  "url": `${SITE}/en/about/`,
  "inLanguage": "en",
  "publisher": {
    "@type": "Organization",
    "name": "Vologis Sp. z o.o.",
    "url": SITE,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "ul. Wrocławska 79B",
      "postalCode": "63-200",
      "addressLocality": "Jarocin",
      "addressCountry": "PL",
    },
    "email": "biuro@vologis.com",
    "telephone": "+48533037996",
    "areaServed": ["Poland", "Europe"],
  },
};

const schemaPerson = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Paweł Wojtczak",
  "jobTitle": "CEO & President of the Management Board",
  "worksFor": { "@type": "Organization", "name": "Vologis Sp. z o.o.", "url": SITE },
};

const schemaFaq = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((f) => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
};
---

<BaseLayout
  title="About | Vologis — Independent End-to-End Logistics Partner"
  description="Meet Vologis — an independent consulting firm specializing in logistics brokerage, operational consulting, Greenfield projects, drone services and Interim Management. Poland and EU."
  canonical="https://vologis.com/en/about/"
  hreflangPL="/pl/o-nas/"
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaAboutPage)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaPerson)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFaq)} />

  <!-- 1. HERO -->
  <section class="on-hero" aria-labelledby="on-h1">
    <div class="container">
      <nav class="on-bc" aria-label="Breadcrumb">
        <ol class="on-bc__list" role="list">
          <li><a href="/en/">Home</a></li>
          <li class="on-bc__sep" aria-hidden="true">›</li>
          <li aria-current="page">About</li>
        </ol>
      </nav>
      <Eyebrow text="ABOUT VOLOGIS" />
      <h1 id="on-h1" class="on-h1">
        Logistics starts with good decisions.<br>Vologis helps you make them.
      </h1>
      <p class="on-lead">
        Vologis is a logistics consulting firm that supports businesses in logistics, forwarding, transport and operational process management. We help companies bring order to operations, reduce risk, optimize costs and make logistics decisions grounded in experience, data and well-designed procedures.
      </p>
      <HeroCTAs primaryLabel="Book a consultation" primaryHref="/en/contact/" secondaryLabel="See how we work" secondaryHref="/en/process/" />
      <ul class="on-trust" role="list" aria-label="Key facts about Vologis">
        {trustItems.map((item) => (
          <li class="on-trust__item">
            <svg class="on-trust__icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m4 10.5 4 4 8-9" /></svg>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- 2. WHO WE ARE -->
  <section class="on-section on-who" aria-labelledby="on-who-h">
    <div class="container on-two-col">
      <div class="on-copy">
        <h2 class="on-h2" id="on-who-h">Who we are</h2>
        <p class="on-body">Vologis was built on the conviction that logistics shouldn't be a collection of random decisions, phone calls and reactive fixes. In a well-run company, transport, warehousing, forwarding, deliveries, documentation and communication must form a coherent system.</p>
        <p class="on-body">Since March 2011 we've been supporting companies in areas that directly impact their operational efficiency: logistics, forwarding, transport, logistics consulting and management consulting. Our role is not only to organize the service, but to help the client better understand which decisions will be safe, cost-effective and implementable in their reality.</p>
        <p class="on-body">We build the scope of cooperation around the client's situation, needs and constraints. This allows us to avoid random moves and focus on solutions that genuinely support the organization.</p>
      </div>
      <aside class="on-brief" aria-label="Vologis in brief">
        <p class="on-brief__label">Vologis in brief</p>
        <ul class="on-brief__list" role="list">
          {briefItems.map((item) => (
            <li class="on-brief__item">
              <span class="on-brief__key">{item.key}</span>
              <span class="on-brief__val">{item.val}</span>
            </li>
          ))}
        </ul>
      </aside>
    </div>
  </section>

  <!-- 3. HISTORY -->
  <section class="on-section on-history" aria-labelledby="on-history-h">
    <div class="container on-history-inner">
      <h2 class="on-h2" id="on-history-h">Vologis started with a practical problem</h2>
      <div class="on-history-body">
        <p class="on-body">Many companies develop their sales, products and customer relationships faster than their operational processes. Initially, a few carrier contacts, basic procedures, spreadsheets and the experience of one or two people are enough. Over time, however, orders, destinations, exceptions, documents and daily decisions multiply.</p>
        <p class="on-body">That's when logistics starts determining whether a company can keep growing. A delayed shipment, the wrong carrier, no cost visibility, an overloaded warehouse or unclear communication between departments can halt growth just as effectively as a lack of sales.</p>
        <p class="on-body on-body--highlight">Vologis was built to help companies at exactly that point: where operations start demanding more order, more experience and a responsible partner.</p>
        <p class="on-body">We don't look at logistics through the lens of a single shipment. We see it as part of the whole company system: purchasing, sales, production, warehousing, finance, customer service and management.</p>
      </div>
    </div>
  </section>

  <!-- 4. FOUNDER -->
  <section class="on-section on-founder" aria-labelledby="on-founder-h">
    <div class="container">
      <div class="on-founder-grid">
        <div class="on-founder-copy">
          <h2 class="on-h2" id="on-founder-h">Experience that bridges logistics and management</h2>
          <p class="on-body">Behind Vologis is experience working with companies that need not just a transport service, but genuine support in making logistics and organizational decisions. This approach combines operational practice with management consulting.</p>
          <p class="on-body">In logistics it's easy to promise a quick fix. What's harder is understanding why a problem occurs, what risk a given decision carries, and how to design collaboration so it doesn't create new complications. That's why at Vologis three things are critical: diagnosis, accountability and solution fit to the specific client situation.</p>
          <blockquote class="on-quote">
            <p class="on-quote__text">Good logistics isn't about reacting faster to chaos. It's about designing your processes, partners and decisions so that chaos happens less often.</p>
            <footer class="on-quote__attr">
              <cite class="on-quote__name">Paweł Wojtczak, CEO &amp; President of the Management Board, Vologis</cite>
            </footer>
          </blockquote>
        </div>
        <div class="on-founder-right">
          <img src="/pawel-wojtczak.webp" alt="Paweł Wojtczak — CEO &amp; President of Vologis, logistics and operational consulting expert" width="480" height="720" class="on-founder-photo" loading="lazy" decoding="async" />
          <div class="on-founder-bio">
            <p class="on-founder-name">Paweł Wojtczak</p>
            <p class="on-founder-role">CEO &amp; President of the Management Board, Vologis</p>
            <p class="on-founder-bio-text">Supports companies in logistics, forwarding, transport and operational process management. Combines an advisory perspective with practical understanding of the everyday challenges facing manufacturing, trading, distribution and e-commerce companies. Certified GMP/GMP+ Representative (DEKRA Certification) — expertise in the safe transport of feed and bulk products.</p>
            <a href="https://www.linkedin.com/company/vologis/" class="on-founder-linkedin" target="_blank" rel="noopener noreferrer" aria-label="Vologis on LinkedIn">
              <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
              Vologis on LinkedIn
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4b. BY THE NUMBERS -->
  <section class="on-section on-numbers" aria-labelledby="on-numbers-h">
    <div class="container">
      <p class="on-eyebrow">By the numbers</p>
      <h2 class="on-h2" id="on-numbers-h">The experience behind Vologis</h2>
      <p class="on-numbers-intro">Independent Vologis consulting is backed by 20 years of operational practice — managing branch networks, facility relocations, restructurings and fulfillment projects delivered by the founder in previous senior roles.</p>
      <div class="on-numbers-grid">
        <div class="on-number-card"><span class="on-number-val tnum">20 years</span><span class="on-number-label">of experience in logistics and operational management</span></div>
        <div class="on-number-card"><span class="on-number-val tnum">100+</span><span class="on-number-label">branches and locations managed</span></div>
        <div class="on-number-card"><span class="on-number-val tnum">400+</span><span class="on-number-label">people in managed teams</span></div>
        <div class="on-number-card"><span class="on-number-val tnum">90,000 m²</span><span class="on-number-label">of warehouse space managed</span></div>
        <div class="on-number-card"><span class="on-number-val tnum">200+</span><span class="on-number-label">suppliers coordinated</span></div>
        <div class="on-number-card"><span class="on-number-val tnum">15</span><span class="on-number-label">logistics facility audits and relocations</span></div>
      </div>
    </div>
  </section>

  <!-- 5. PHILOSOPHY (dark) -->
  <section class="on-section on-philosophy" aria-labelledby="on-phil-h">
    <div class="container">
      <h2 class="on-h2 on-h2--dark" id="on-phil-h">How we see logistics</h2>
      <p class="on-section-intro on-section-intro--dark">Logistics is not just a cost. It is a system of decisions that affects delivery times, margin, customer service quality, product availability and the company's ability to scale.</p>
      <div class="on-card-grid">
        {philosophyCards.map((c) => (
          <div class="on-glass-card">
            <h3 class="on-glass-card__title">{c.title}</h3>
            <p class="on-glass-card__text">{c.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. EXPERTISE -->
  <section class="on-section on-expertise" aria-labelledby="on-exp-h">
    <div class="container">
      <h2 class="on-h2" id="on-exp-h">Our areas of expertise</h2>
      <p class="on-section-intro">Vologis operates at the intersection of logistics, transport, forwarding and consulting. This lets us support clients both in day-to-day operations and in decisions about growth, costs and processes.</p>
      <div class="on-exp-grid">
        {expertiseCards.map((c) => (
          <div class="on-exp-card">
            <span class="on-exp-card__num tnum" aria-hidden="true">{c.num}</span>
            <h3 class="on-exp-card__title">{c.title}</h3>
            <p class="on-exp-card__text">{c.text}</p>
          </div>
        ))}
      </div>
      <div class="on-expertise-cta">
        <a href="/en/services/" class="on-link">See the full range of services <span aria-hidden="true">→</span></a>
        <a href="/en/services/logistics-brokerage/" class="on-link">Logistics brokerage <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>

  <!-- 7. HOW WE WORK WITH CLIENTS -->
  <section class="on-section on-process" aria-labelledby="on-proc-h">
    <div class="container">
      <h2 class="on-h2" id="on-proc-h">How we work with clients</h2>
      <div class="on-steps">
        {processSteps.map((step, i) => (
          <div class="on-step">
            <div class="on-step__rail">
              <span class="on-step__badge tnum">{step.num}</span>
              {i < processSteps.length - 1 && <span class="on-step__line" aria-hidden="true" />}
            </div>
            <div class="on-step__body">
              <h3 class="on-step__title">{step.title}</h3>
              <p class="on-step__text">{step.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 8. PRINCIPLES (dark) -->
  <section class="on-section on-principles" aria-labelledby="on-prin-h">
    <div class="container">
      <h2 class="on-h2 on-h2--dark" id="on-prin-h">The principles that guide our work</h2>
      <div class="on-card-grid">
        {principleCards.map((c) => (
          <div class="on-glass-card">
            <h3 class="on-glass-card__title">{c.title}</h3>
            <p class="on-glass-card__text">{c.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 9. TIMELINE -->
  <section class="on-section on-timeline" aria-labelledby="on-tl-h">
    <div class="container">
      <h2 class="on-h2" id="on-tl-h">A brief history</h2>
      <div class="on-tl-grid">
        {timelineItems.map((item, i) => (
          <div class="on-tl-item">
            <span class="on-tl-item__year tnum">{item.year}</span>
            <div class="on-tl-item__connector" aria-hidden="true">
              <span class="on-tl-item__dot" />
              {i < timelineItems.length - 1 && <span class="on-tl-item__line" />}
            </div>
            <h3 class="on-tl-item__title">{item.title}</h3>
            <p class="on-tl-item__text">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 10. WHY CLIENTS CHOOSE VOLOGIS -->
  <section class="on-section on-why" aria-labelledby="on-why-h">
    <div class="container on-why-grid">
      <div class="on-why-copy">
        <h2 class="on-h2" id="on-why-h">Why clients choose Vologis</h2>
        <p class="on-body">Clients typically come to us when logistics starts demanding more control: costs are rising, delays are appearing, the team is losing time on transport coordination, or the company needs a partner to take responsibility for a specific area.</p>
        <ul class="on-why-list" role="list">
          {whyVologis.map((item) => (
            <li class="on-why-item">
              <svg class="on-check-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m4 10.5 4 4 8-9" /></svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="on-for-whom">
        <h2 class="on-h2" id="on-whom-h">Which companies do we work with</h2>
        <p class="on-body">We support companies that need more predictable and better-organized logistics. We work with organizations for which transport, warehousing, forwarding and operational processes have a direct impact on sales, customer service, costs and growth.</p>
        <div class="on-chips" role="list" aria-label="Types of companies Vologis works with">
          {clientTypes.map((chip) => (
            <span class="on-chip" role="listitem">{chip}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 11. FAQ -->
  <section class="on-section on-faq" aria-labelledby="on-faq-h">
    <div class="container">
      <h2 class="on-h2 on-h2--center" id="on-faq-h">FAQ — About Vologis</h2>
      <FaqAccordion items={faqs} />
    </div>
  </section>

  <!-- 12. END CTA -->
  <section class="on-endcta" aria-labelledby="on-endcta-h">
    <div class="container">
      <div class="on-endcta-inner">
        <h2 class="on-endcta__h2" id="on-endcta-h">Looking for a partner who sees logistics as more than a single shipment?</h2>
        <p class="on-endcta__text">Let's talk about how transport, forwarding, warehousing or operational processes work in your company. Vologis will help identify where to start: from organizing transport, consulting, auditing or bringing order to a specific logistics area.</p>
        <div class="on-endcta__actions">
          <a href="/en/contact/" class="on-btn on-btn--accent on-btn--lg">Get in touch with Vologis <span aria-hidden="true">→</span></a>
          <a href="/en/services/" class="on-btn on-btn--glass on-btn--lg">See our services</a>
        </div>
        <address class="on-endcta-contact">
          <a href="mailto:biuro@vologis.com" class="on-contact-item">biuro@vologis.com</a>
          <span class="on-contact-sep" aria-hidden="true">·</span>
          <a href="tel:+48533037996" class="on-contact-item">(+48) 533-037-996</a>
          <span class="on-contact-sep" aria-hidden="true">·</span>
          <span class="on-contact-item">ul. Wrocławska 79B, 63-200 Jarocin</span>
        </address>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .on-section { padding-block: var(--space-3xl); }
  .on-h2 { font-family: var(--font-display); font-size: var(--text-xl); font-weight: 700; letter-spacing: -0.025em; line-height: 1.15; color: var(--color-ink); margin-bottom: var(--space-lg); }
  .on-h2--dark { color: var(--color-ink-on-dark); }
  .on-h2--center { text-align: center; }
  .on-body { font-size: var(--text-base); color: var(--color-muted); line-height: 1.75; margin-bottom: var(--space-md); }
