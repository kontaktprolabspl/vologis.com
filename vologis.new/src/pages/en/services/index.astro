---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Eyebrow from "../../../components/Eyebrow.astro";
import HeroCTAs from "../../../components/HeroCTAs.astro";
import programmaticEN from "../../../data/programmatic-en.json";

const icons = {
  route: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="19" r="2.5"/><circle cx="18" cy="5" r="2.5"/><path d="M8.5 19H15a3.5 3.5 0 0 0 0-7H9a3.5 3.5 0 0 1 0-7h6.5"/></svg>`,
  search: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>`,
  warehouse: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21V8l9-5 9 5v13"/><path d="M3 21h18"/><path d="M8 21v-6h8v6"/><path d="M8 12h8"/></svg>`,
  drone: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="6" height="6" rx="1"/><path d="M9 9 5 5M15 9l4-4M9 15l-4 4M15 15l4 4"/><circle cx="4" cy="4" r="2"/><circle cx="20" cy="4" r="2"/><circle cx="4" cy="20" r="2"/><circle cx="20" cy="20" r="2"/></svg>`,
  bolt: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 4 14h7l-1 8 9-12h-7l1-8Z"/></svg>`,
  handshake: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17 12h-5M12 7v5"/><path d="M7 17h10a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2Z"/><path d="m15 21-3-3-3 3"/></svg>`,
  shield: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/></svg>`,
};

const services = [
  {
    number: "01",
    icon: icons.route,
    title: "Logistics brokerage & fulfillment",
    subtitle: "One partner instead of dozens of operator conversations.",
    bullets: [
      "Search and vetting of warehouse operators",
      "Negotiating terms and SLAs on the client's behalf",
      "Specialist sectors: cold storage, ADR, pharma",
      "Bid comparison and optimal solution recommendation",
      "Full independence — no hidden supplier commissions",
    ],
    href: "/en/services/logistics-brokerage/",
    slug: "logistics-brokerage",
  },
  {
    number: "02",
    icon: icons.search,
    title: "Operational consulting & audit",
    subtitle: "We'll identify where your logistics is losing money, time and people.",
    bullets: [
      "Warehouse and transport process audit",
      "Bottleneck identification and quick wins",
      "WMS, automation and robotics selection",
      "Warehouse layout design",
      "Quantifiable recommendations — not generalities",
    ],
    href: "/en/services/operational-consulting/",
    slug: "operational-consulting",
  },
  {
    number: "03",
    icon: icons.warehouse,
    title: "Comprehensive Greenfield projects",
    subtitle: "From bare land to a live operation. One partner, full accountability.",
    bullets: [
      "Pre-investment analysis and site selection",
      "Concept design and supplier selection",
      "Facility preparation oversight",
      "Systems and infrastructure rollout",
      "Team recruitment and operational start",
    ],
    href: "/en/services/greenfield-projects/",
    slug: "greenfield-projects",
  },
  {
    number: "04",
    icon: icons.drone,
    title: "Advanced drone services",
    subtitle: "Innovative technology integrated with logistics projects.",
    bullets: [
      "Land surveys and orthophotomaps",
      "Investment site inspections",
      "Construction progress monitoring",
      "Aerial marketing materials (photo/video)",
      "Documentation for developers and investors",
    ],
    href: "/en/services/drone-services/",
    slug: "drone-services",
  },
  {
    number: "05",
    icon: icons.bolt,
    title: "Interim Management & restructuring",
    subtitle: "Your logistics director just left? Operational crisis? We're in from Monday.",
    bullets: [
      "Rapid diagnosis and firefighting",
      "Temporary C-level management support",
      "Process restructuring and cost reduction",
      "Operations stabilisation in difficult conditions",
      "Flexible collaboration and billing models",
    ],
    href: "/en/services/interim-management/",
    slug: "interim-management",
  },
  {
    number: "06",
    icon: icons.handshake,
    title: "Commercialisation & sales",
    subtitle: "Space commercialisation, market entry and free operator selection for manufacturing.",
    bullets: [
      "Commercialisation of vacant pallet volumes (success fee)",
      "Market representation for companies entering the Polish market",
      "Free logistics partner selection for manufacturing companies",
      "Alternative to inefficient tender procedures",
      "Mid-sized operators — flexibility and partnership",
    ],
    href: "/en/services/commercialization-and-sales/",
    slug: "commercialization-and-sales",
  },
  {
    number: "07",
    icon: icons.shield,
    title: "Operational security & Loss Prevention",
    subtitle: "Protecting margin from losses, collusion and theft that standard security doesn't catch.",
    bullets: [
      "CCTV, access control and IAS system design",
      "Loss Prevention processes and facility zoning",
      "CCTV–WMS correlation and anomaly detection",
      "Licensed investigative procedures",
      "Investigative audit and evidence preservation",
    ],
    href: "/en/services/operational-security/",
    slug: "operational-security",
  },
];

const processSteps = [
  { num: "01", name: "Needs analysis & identification", desc: "We map the situation, define the problem, create the action plan." },
  { num: "02", name: "Quick Wins", desc: "Immediate process changes without waiting for major rollouts." },
  { num: "03", name: "Location & partner selection", desc: "Market research, negotiations, concept design." },
  { num: "04", name: "Operational implementation", desc: "We take over project coordination through to operational launch." },
  { num: "05", name: "Optimisation & development", desc: "We monitor KPIs and implement long-term improvements." },
];

const SITE = "https://vologis.com";

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",     "item": `${SITE}/en/` },
    { "@type": "ListItem", "position": 2, "name": "Services", "item": `${SITE}/en/services/` },
  ],
};

const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Vologis Logistics Services",
  "itemListElement": services.map((s, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "Service",
      "name": s.title,
      "description": s.subtitle,
      "url": `${SITE}${s.href}`,
    },
  })),
};
---

<BaseLayout
  title="Seven End-to-End Logistics Services — Vologis"
  description="Seven ways to make your logistics stop being a cost centre and start working. Each service grounded in operational practice, not theory."
  canonical="https://vologis.com/en/services/"
  hreflangPL="/pl/uslugi/"
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaItemList)} />

  <!-- 1. Hero -->
  <section class="svc-hero" aria-labelledby="svc-heading">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol class="breadcrumb-list" role="list">
          <li><a href="/en/">Home</a></li>
          <li aria-hidden="true" class="breadcrumb-sep">›</li>
          <li aria-current="page">Services</li>
        </ol>
      </nav>
      <Eyebrow text="OUR SERVICES" />
      <h1 id="svc-heading" class="svc-hero__h1">
        End-to-end logistics.<br>We don't leave you with a report.
      </h1>
      <p class="svc-hero__sub">
        Seven areas of support — from first analysis through physical implementation
        and optimisation. We work project-based, billed on results.
      </p>
      <HeroCTAs
        primaryLabel="Book a consultation"
        primaryHref="/en/contact/"
        secondaryLabel="See how we work"
        secondaryHref="/en/process/"
      />
    </div>
  </section>

  <!-- 2. Services grid -->
  <section class="svc-grid-section" aria-labelledby="svc-grid-heading">
    <div class="container">
      <h2 id="svc-grid-heading" class="sr-only">Service scope</h2>
      <div class="svc-grid">
        {services.map((s) => (
          <article class="svc-card" style={`--card-accent: var(--color-ink);`}>
            <div class="svc-card__head">
              <span class="svc-card__icon" aria-hidden="true" set:html={s.icon}></span>
              <span class="svc-card__num tnum" aria-hidden="true">{s.number}</span>
            </div>
            <h3 class="svc-card__title">{s.title}</h3>
            <p class="svc-card__subtitle">{s.subtitle}</p>
            <ul class="svc-card__bullets" role="list">
              {s.bullets.map((b) => (
                <li class="svc-card__bullet">
                  <svg class="svc-card__check" viewBox="0 0 20 20" width="19" height="19" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m4 10.5 4 4 8-9" /></svg>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
            <a class="svc-card__cta" href={s.href}>
              Explore service <span aria-hidden="true">→</span>
            </a>
          </article>
        ))}
        <article class="svc-cta-tile" aria-label="Free consultation — not sure where to start?">
          <div class="svc-cta-tile__head">
            <span class="svc-cta-tile__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
            </span>
          </div>
          <h3 class="svc-cta-tile__title">Not sure where to start?</h3>
          <p class="svc-cta-tile__body">Tell us where it hurts. We'll identify which service will genuinely solve your problem — or whether you need several combined into one project. Free consultation, no commitment.</p>
          <a class="cta-btn cta-btn--primary svc-cta-tile__btn" href="/en/contact/">Book a consultation <span aria-hidden="true">→</span></a>
        </article>
      </div>
    </div>
  </section>

  <!-- 2b. Industry specialisations -->
  <section class="branze-hub" aria-labelledby="branze-hub-h">
    <div class="container">
      <h2 class="branze-hub__title" id="branze-hub-h">Industry specialisations</h2>
      <p class="branze-hub__lead">Each service available with dedicated knowledge for your industry.</p>
      <div class="branze-hub__groups">
        {services.map((svc) => {
          const children = (programmaticEN as any).pages?.filter((p: any) => p.parent === svc.slug) ?? [];
          if (children.length === 0) return null;
          return (
            <div class="branze-hub__group">
              <a href={svc.href} class="branze-hub__parent">{svc.title}</a>
              <ul class="branze-hub__list" role="list">
                {children.map((c: any) => (
                  <li>
                    <a href={`/en/services/${c.slug}/`} class="branze-hub__link">
                      {c.industry.charAt(0).toUpperCase() + c.industry.slice(1)}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- 3. Process strip -->
  <section class="proc-strip" aria-labelledby="proc-heading">
    <div class="container">
      <h2 id="proc-heading" class="proc-strip__title">How we work</h2>
      <ol class="proc-strip__steps">
        {processSteps.map((step) => (
          <li class="proc-step">
            <span class="proc-step__num tnum" aria-hidden="true">{step.num}</span>
            <h3 class="proc-step__name">{step.name}</h3>
            <p class="proc-step__desc">{step.desc}</p>
          </li>
        ))}
      </ol>
      <a href="/en/process/" class="proc-strip__link">
        See the full process description <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <!-- 4. USP strip -->
  <section class="usp-strip" aria-labelledby="usp-heading">
    <div class="container">
      <h2 id="usp-heading" class="sr-only">Why Vologis</h2>
      <div class="usp-grid">
        <div class="usp-col">
          <span class="usp-col__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0Z"/><path d="m8.5 12 2.5 2.5 4.5-5"/></svg>
          </span>
          <h3 class="usp-col__title">Real implementation, not a report</h3>
          <p class="usp-col__desc">
            We don't stop at handing over a document. We take accountability
            for the physical implementation of changes through to achieving agreed KPIs.
          </p>
        </div>
        <div class="usp-col">
          <span class="usp-col__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3 4 6v5c0 5 3.5 8 8 10 4.5-2 8-5 8-10V6l-8-3Z"/></svg>
          </span>
          <h3 class="usp-col__title">100% independent</h3>
          <p class="usp-col__desc">
            We have no ties to any operator, developer or technology vendor.
            We select solutions solely based on your ROI.
          </p>
        </div>
        <div class="usp-col">
          <span class="usp-col__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M18.4 5.6l-2.1 2.1M7.7 16.3l-2.1 2.1"/></svg>
          </span>
          <h3 class="usp-col__title">Single point of contact</h3>
          <p class="usp-col__desc">
            Location, warehouse operations, automation, drone services — we take the
            coordination burden off you. One partner, full scope.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. CTA -->
  <section class="svc-cta" aria-labelledby="svc-cta-heading">
    <div class="container">
      <div class="svc-cta__inner">
        <h2 id="svc-cta-heading" class="svc-cta__title">Planning a logistics project?</h2>
        <p class="svc-cta__sub">
          Free consultation — zero commitment. We respond within 24 hours.
        </p>
        <div class="svc-cta__actions">
          <a href="/en/contact/" class="cta-btn cta-btn--primary">
            Book a consultation <span aria-hidden="true">→</span>
          </a>
          <a href="/en/process/" class="cta-btn cta-btn--ghost">
            See our process <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }

  .breadcrumb { margin-bottom: var(--space-lg); }
  .breadcrumb-list { display: flex; align-items: center; gap: var(--space-xs); list-style: none; font-size: var(--text-sm); color: var(--color-muted-on-dark); }
  .breadcrumb-list a { color: var(--color-muted-on-dark); text-decoration: none; transition: color var(--dur-micro) var(--ease-out); }
  .breadcrumb-list a:hover { color: var(--color-ink-on-dark); }
  .breadcrumb-sep { color: var(--color-muted-on-dark); user-select: none; opacity: 0.6; }
  .breadcrumb-list [aria-current="page"] { color: var(--color-ink-on-dark); font-weight: 500; }

  .svc-hero { background: var(--color-paper-dark); background-image: url('/services/uslugi.webp'); background-size: cover; background-position: bottom right; background-repeat: no-repeat; color: var(--color-ink-on-dark); padding-top: calc(var(--space-3xl) + 5rem); padding-bottom: var(--space-3xl); position: relative; overflow: hidden; }
  .svc-hero::before { content: ""; position: absolute; inset: 0; background: linear-gradient(to right, oklch(26% 0.060 257 / 1.00) 0%, oklch(26% 0.060 257 / 1.00) 32%, oklch(26% 0.060 257 / 0.88) 52%, oklch(26% 0.060 257 / 0.30) 72%, oklch(26% 0.060 257 / 0.00) 100%); pointer-events: none; }
  .svc-hero > * { position: relative; }
  .svc-hero__h1 { font-family: var(--font-display); font-size: var(--text-display-s); font-weight: 700; letter-spacing: -0.03em; line-height: 1.08; color: var(--color-ink-on-dark); margin-bottom: var(--space-lg); }
  .svc-hero__sub { font-size: var(--text-md); color: var(--color-muted-on-dark); max-width: 60ch; line-height: 1.6; margin-bottom: var(--space-xl); }

  .svc-grid-section { padding-block: var(--space-3xl); }
  .svc-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-lg); }

  /* Inline service card styles (ServiceCard component has hardcoded PL text) */
  .svc-card { position: relative; display: flex; flex-direction: column; gap: var(--space-md); background: var(--color-paper); border: 1px solid var(--color-rule); border-left: 4px solid var(--card-accent); border-radius: var(--radius-lg); padding: var(--space-xl); box-shadow: var(--shadow-sm); transition: border-color var(--dur-short) var(--ease-out), transform var(--dur-short) var(--ease-out), box-shadow var(--dur-short) var(--ease-out); }
  .svc-card:hover { border-color: var(--color-blue); transform: translateY(-4px); box-shadow: var(--shadow-lg); }
  .svc-card__head { display: flex; align-items: center; justify-content: space-between; }
  .svc-card__icon { display: grid; place-items: center; width: 3.25rem; height: 3.25rem; border-radius: var(--radius-md); background: var(--color-blue-tint); color: var(--card-accent); }
  .svc-card__icon :global(svg) { width: 1.6rem; height: 1.6rem; }
  .svc-card__num { font-family: var(--font-mono); font-size: var(--text-sm); font-weight: 500; letter-spacing: 0.08em; color: var(--color-neutral); }
  .svc-card__title { font-family: var(--font-display); font-size: var(--text-lg); font-weight: 700; letter-spacing: -0.02em; line-height: 1.15; color: var(--color-ink); }
  .svc-card__subtitle { font-size: var(--text-base); color: var(--color-muted); line-height: 1.55; margin-top: calc(var(--space-md) * -1 + var(--space-2xs)); }
  .svc-card__bullets { display: flex; flex-direction: column; gap: var(--space-sm); list-style: none; }
  .svc-card__bullet { display: flex; align-items: flex-start; gap: var(--space-sm); font-size: var(--text-sm); color: var(--color-ink); line-height: 1.5; }
  .svc-card__check { flex-shrink: 0; width: 1.15rem; height: 1.15rem; margin-top: 0.15rem; color: var(--color-blue); }
  .svc-card__cta { margin-top: auto; align-self: flex-start; font-family: var(--font-display); font-size: var(--text-sm); font-weight: 600; color: var(--color-blue); text-decoration: none; padding-top: var(--space-2xs); transition: color var(--dur-micro) var(--ease-out); }
  .svc-card__cta span { display: inline-block; transition: transform var(--dur-short) var(--ease-out); }
  .svc-card__cta::after { content: ""; position: absolute; inset: 0; border-radius: inherit; }
  .svc-card:hover .svc-card__cta { color: var(--color-ink); }
  .svc-card:hover .svc-card__cta span { transform: translateX(4px); }

  .branze-hub { padding-block: var(--space-3xl); background: var(--color-paper-2); border-top: 1px solid var(--color-rule); }
  .branze-hub__title { font-family: var(--font-display); font-size: var(--text-xl); font-weight: 700; letter-spacing: -0.025em; color: var(--color-ink); margin-bottom: var(--space-sm); }
  .branze-hub__lead { font-size: var(--text-base); color: var(--color-muted); margin-bottom: var(--space-xl); }
  .branze-hub__groups { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: var(--space-xl); }
  .branze-hub__parent { display: block; font-family: var(--font-display); font-size: var(--text-sm); font-weight: 700; color: var(--color-ink); text-decoration: none; margin-bottom: var(--space-sm); padding-bottom: var(--space-sm); border-bottom: 2px solid var(--color-secondary); transition: color var(--dur-micro) var(--ease-out); }
  .branze-hub__parent:hover { color: var(--color-secondary); }
  .branze-hub__list { list-style: none; display: flex; flex-direction: column; gap: var(--space-xs); }
  .branze-hub__link { font-size: var(--text-sm); color: var(--color-muted); text-decoration: none; display: flex; align-items: center; gap: var(--space-xs); line-height: 1.4; transition: color var(--dur-micro) var(--ease-out); }
  .branze-hub__link::before { content: "→"; font-size: 0.7em; color: var(--color-secondary); flex-shrink: 0; opacity: 0.7; }
  .branze-hub__link:hover { color: var(--color-ink); }

  .proc-strip { background: var(--color-paper-dark); color: var(--color-ink-on-dark); padding-block: var(--space-3xl); }
  .proc-strip__title { font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-blue-on-dark); margin-bottom: var(--space-xl); }
  .proc-strip__steps { display: grid; grid-template-columns: repeat(5, 1fr); gap: var(--space-lg); list-style: none; }
  .proc-step { position: relative; padding-top: var(--space-lg); border-top: 1px solid var(--color-glass-border); }
  .proc-step__num { display: block; font-family: var(--font-display); font-size: var(--text-4xl); font-weight: 700; line-height: 1; letter-spacing: -0.04em; color: oklch(85.4% 0.052 199 / 0.45); margin-bottom: var(--space-sm); }
  .proc-step__name { font-family: var(--font-display); font-size: var(--text-base); font-weight: 600; letter-spacing: -0.01em; color: var(--color-ink-on-dark); margin-bottom: var(--space-xs); line-height: 1.25; }
  .proc-step__desc { font-size: var(--text-sm); color: var(--color-muted-on-dark); line-height: 1.5; }
  .proc-strip__link { display: inline-block; margin-top: var(--space-xl); font-family: var(--font-display); font-size: var(--text-sm); font-weight: 600; color: var(--color-blue-on-dark); text-decoration: none; transition: color var(--dur-micro) var(--ease-out); }
  .proc-strip__link span { display: inline-block; transition: transform var(--dur-short) var(--ease-out); }
  .proc-strip__link:hover { color: var(--color-ink-on-dark); }
