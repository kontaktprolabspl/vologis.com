---
import ServicePageLayout from "../../../layouts/ServicePageLayout.astro";
import FaqAccordion from "../../../components/FaqAccordion.astro";
import CalloutBox from "../../../components/CalloutBox.astro";

const SITE = "https://vologis.com";

const trustItems = [
  "Geodetic surveys and orthophotomaps of investment sites",
  "Photogrammetry, 3D models and volume measurements",
  "Drone inventory scanning (RFID/LiDAR) without halting operations",
  "Hall roof and PV installation inspections with thermal imaging and AI",
  "Aerial Greenfield investment progress monitoring",
  "Facility patrol and security — Drone-in-a-Box",
];

const forWhom = [
  { title: "Logistics facility developers and owners", text: "When you need site surveys, construction monitoring, technical condition inspections and completed facility documentation." },
  { title: "Investors and funds", text: "When you want to objectively assess an investment plot or independently track Greenfield project progress." },
  { title: "Warehouse operators and 3PLs", text: "When you need drone inventory scanning in a high-bay warehouse, a hall roof inspection or autonomous facility patrol." },
  { title: "Companies executing Greenfield projects", text: "When drones are to be an integral part of the investment process — from geodetic surveys to construction monitoring and completed facility security." },
  { title: "Companies responsible for facility security", text: "When you're looking for a technology complement to a security and Loss Prevention system — autonomous patrol as part of round-the-clock surveillance." },
];

const scopeCards: Array<{title: string; text: string; img: string; imgAlt: string; link?: {href: string; label: string}}> = [
  {
    title: "Geodetic surveys and orthophotomaps",
    text: "Precise surveys of investment sites and logistics land — accurate to centimetres. Orthophotomaps provide a true-scale aerial view of the site, ready for layout design, accessibility analysis and investment documentation.",
    img: "/services/drony/drony-ortofotomapa.png",
    imgAlt: "Orthophotomap of an investment site — drone aerial view with survey points",
  },
  {
    title: "3D models, photogrammetry and volume measurements",
    text: "Digital twins of land and logistics facilities: 3D models created from drone imagery (photogrammetry). Precise volume measurement of bulk materials and stockpiles — quantity control without manual field measurement. Data supports Greenfield projects from the planning stage.",
    img: "/services/drony/drony-model-3d.png",
    imgAlt: "Photogrammetric 3D terrain model with DEM elevation map — colour gradient from blue to yellow",
    link: { href: "/en/services/greenfield-projects/", label: "See Greenfield projects" },
  },
  {
    title: "Warehouse inventory scanning",
    text: "Drones equipped with barcode readers, RFID and LiDAR scanners autonomously count and locate pallets between high-bay racking — even at night, without halting operations. They eliminate manual counting errors and free up staff from tedious inventory tasks.",
    img: "/services/drony/drony-inwentaryzacja.png",
    imgAlt: "Interior of a high-bay warehouse — drone view between racking with pallets",
  },
  {
    title: "Logistics facility inspections",
    text: "Inspections of warehouse hall roofs, photovoltaic installations and facility technical condition. Thermal cameras and AI algorithms detect micro-damage, insulation defects and PV failures before they become costly repairs or operational disruptions.",
    img: "/services/drony/drony-inspekcja.png",
    imgAlt: "Thermal inspection of a warehouse hall roof with PV panels — drone image in heat palette",
  },
  {
    title: "Construction progress monitoring",
    text: "Regular aerial documentation of construction progress — from first groundwork to facility handover. Objective, date-stamped record for the investor, independent of contractor reports. Integrated with Vologis Greenfield project management.",
    img: "/services/drony/drony-budowa.png",
    imgAlt: "Aerial shot of a logistics centre under construction — steel structure and foundations, drone view",
    link: { href: "/en/services/greenfield-projects/", label: "See Greenfield projects" },
  },
  {
    title: "Facility patrol and security — Drone-in-a-Box",
    text: "Autonomous patrols around logistics centres and warehouses. The drone launches automatically on zone breach detection, streaming live video to the security centre. A Loss Prevention complement that operates 24/7 without extra headcount.",
    img: "/services/drony/drony-patrol.png",
    imgAlt: "Night aerial view of a logistics centre — fenced site with illuminated yard",
    link: { href: "/en/services/operational-security/", label: "Operational security and Loss Prevention" },
  },
];

const faqs = [
  { q: "Can drones inventory stock without halting warehouse operations?", a: "Yes. Drones equipped with RFID readers, barcode scanners and LiDAR conduct autonomous inventory scanning between high-bay racking — often at night or in sections outside active operation, without stopping forklifts or evacuating personnel." },
  { q: "How accurate are geodetic drone surveys?", a: "With appropriate procedures and reference points we achieve accuracy to a few centimetres. The specific accuracy level is agreed depending on the measurement purpose and project requirements." },
  { q: "How does thermal inspection differ from a standard roof inspection?", a: "A thermal camera on a drone detects leaks, insulation defects and PV thermal anomalies that are invisible to the naked eye during a standard inspection. AI algorithms automatically locate and classify anomalies — shortening analysis time and documenting facility condition in a format ready for engineering review." },
  { q: "How does Drone-in-a-Box work?", a: "Drone-in-a-Box is an autonomous docking station with a drone that launches automatically on zone breach detection by the alarm system or on operator request. The drone streams video to the security centre in real time and returns automatically to the station after completing the patrol. It supplements the CCTV system and physical security." },
  { q: "Is construction monitoring a one-off or recurring service?", a: "Most often recurring — regular flights at set intervals provide an objective picture of construction progress over time. A single measurement or documentation at a specific project stage is also possible." },
];

const dronePages = [
  { slug: "drone-services-land-surveying",              industry: "Land surveying",        h1: "Drone Land Surveying",                        description: "Precise geodetic surveys and orthophotomaps of investment sites — accurate to centimetres, delivered faster than traditional methods." },
  { slug: "drone-services-orthophotomaps",              industry: "Orthophotomaps",         h1: "Drone Orthophotomaps",                        description: "True-scale aerial orthophotomaps ready for layout design, masterplan and investment documentation." },
  { slug: "drone-services-warehouse-inspection",        industry: "Warehouse inspection",   h1: "Drone Warehouse Inspection",                  description: "Roof, PV and hall inspections with thermal imaging and AI — detecting defects before they become costly repairs." },
  { slug: "drone-services-logistics-real-estate-marketing", industry: "Logistics RE marketing", h1: "Drone Logistics Real Estate Marketing",   description: "Aerial photo and video for commercialising logistics facilities and investment sites." },
  { slug: "drone-services-construction-monitoring",     industry: "Construction monitoring", h1: "Drone Construction Monitoring",              description: "Regular aerial documentation of Greenfield project progress — independent of contractor reports." },
];

const schemaService = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Drone services for logistics and investments",
  "provider": { "@type": "Organization", "name": "Vologis Sp. z o.o.", "url": SITE, "address": { "@type": "PostalAddress", "addressLocality": "Jarocin", "addressRegion": "Wielkopolska", "addressCountry": "PL" } },
  "areaServed": ["Poland", "Europe"],
  "serviceType": "Drone services for logistics: surveys, inspections, warehouse inventory, Drone-in-a-Box patrol",
  "description": "Drone services exclusively for logistics: land surveying, 3D models, autonomous inventory scanning, AI facility inspections, Greenfield monitoring and Drone-in-a-Box patrol. Vologis integrates drone data directly into logistics projects.",
  "url": `${SITE}/en/services/drone-services/`,
  "inLanguage": "en",
};

const schemaFaq = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((f) => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })),
};
---

<ServicePageLayout
  title="Drones in Logistics — Surveys, Inspections, Inventory &amp; Facility Security | Vologis"
  description="Drone services for logistics: orthophotomaps, 3D models, autonomous inventory scanning, AI facility inspections, Greenfield monitoring and Drone-in-a-Box. Integrated with logistics projects."
  canonical="https://vologis.com/en/services/drone-services/"
  hreflangPL="/pl/uslugi/uslugi-dronowe/"
  ogImage="/og/og-drony.png"
  heroImage="/services/uslugi-dronowe.webp"
  eyebrow="Logistics services / Drone services"
  h1="Drones in Logistics — Surveys, Inspections, Inventory &amp; Facility Security"
  lead="A drone in logistics is a precision analytical tool: it shortens investment timelines, controls inventory without halting operations and strengthens facility security. Vologis uses drones exclusively in logistics applications — from site surveys and photogrammetry, through autonomous inventory scanning in high-bay warehouses, AI-powered facility inspections with thermal imaging, to autonomous Drone-in-a-Box patrols. We integrate data directly into logistics projects."
  trustItems={trustItems}
  ctaPrimaryLabel="Enquire about drone services"
  ctaPrimaryHref="/en/contact/"
  ctaSecondaryLabel="See Greenfield projects"
  ctaSecondaryHref="/en/services/greenfield-projects/"
  breadcrumbs={[{ name: "Drone services" }]}
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaService)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFaq)} />

  <!-- 1. Problem / Value -->
  <section class="ps-problem" aria-labelledby="h-problem">
    <div class="container">
      <div class="ps-problem__grid">
        <div class="ps-problem__copy">
          <h2 class="h2" id="h-problem">
            Three problems a drone solves faster and cheaper than traditional methods
          </h2>
          <p class="body">
            A traditional geodetic survey of a large investment site takes days and engages a multi-person field team. A drone surveys the same site in hours — with centimetre accuracy — and the orthophotomap and 3D model go straight to the layout designers and investment analysts.
          </p>
          <p class="body">
            In high-bay warehouses, manual inventory takes days of downtime and errors reaching several percent. Drones with RFID and LiDAR autonomously scan racking at night, without halting operations — delivering an accurate picture of stock ready by morning.
          </p>
          <p class="body">
            Patrolling a facility by traditional means has blind spots and depends on security availability. Drone-in-a-Box launches automatically on zone breach and immediately streams footage to the security centre. This Loss Prevention complement works round the clock without an extra headcount.
          </p>
        </div>
        <aside class="ps-brief" aria-label="In brief">
          <p class="ps-brief__label">In brief</p>
          <p class="ps-brief__text">
            Vologis drone services cover 6 logistics applications: geodetic surveys and site orthophotomaps, photogrammetry and 3D models with volume measurements, autonomous inventory scanning (RFID/LiDAR), facility inspections with thermal imaging and AI, Greenfield construction progress monitoring, and facility patrol and security (Drone-in-a-Box). Vologis integrates drone data directly into logistics projects — interpreting it in the context of specific investment and operational decisions.
          </p>
          <hr class="ps-brief__rule" />
          <p class="ps-brief__sub">Vologis &middot; Jarocin, Poland &middot; Poland and EU</p>
        </aside>
      </div>
    </div>
  </section>

  <!-- 2. Scope -->
  <section class="ps-scope" aria-labelledby="h-scope">
    <div class="container">
      <h2 class="h2" id="h-scope">6 drone applications in logistics</h2>
      <p class="body">Exclusively logistics applications — from site surveys for investment through autonomous inventory to completed facility security.</p>
      <div class="scope-grid">
        {scopeCards.map((c) => (
          <div class="scope-card">
            <div class="scope-card__img-wrap">
              <img src={c.img} alt={c.imgAlt} width="1200" height="800" loading="lazy" decoding="async" class="scope-card__img" />
            </div>
            <div class="scope-card__body">
              <h3 class="scope-card__title">{c.title}</h3>
              <p class="scope-card__text">{c.text}</p>
              {c.link && <a href={c.link.href} class="adv-link">{c.link.label} <span aria-hidden="true">→</span></a>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. Who it's for -->
  <section class="ps-forwho" aria-labelledby="h-forwho">
    <div class="container">
      <h2 class="h2 h2--center" id="h-forwho">Who are drone services for?</h2>
      <p class="section-intro">We work wherever precise aerial data has a real impact on investment and operational decisions.</p>
      <div class="fw-grid">
        {forWhom.map((p) => (
          <div class="fw-card">
            <h3 class="fw-card__title">{p.title}</h3>
            <p class="fw-card__text">{p.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. Advantage (dark) -->
  <section class="ps-advantage" aria-labelledby="h-advantage">
    <div class="container">
      <div class="adv-grid">
        <div class="adv-copy">
          <p class="dark-eyebrow">Unique integration</p>
          <h2 class="h2 h2--dark" id="h-advantage">What sets us apart from a typical drone company</h2>
          <p class="adv-text">A drone company delivers photos. We deliver data in the context of your logistics project. We know what an orthophotomap means for a warehouse layout, how drone inventory translates into operational continuity and how Drone-in-a-Box integrates with a facility security system.</p>
          <p class="adv-text">Drone services here are part of a larger whole — logistics consulting, Greenfield projects and operational security. Data from the drone goes directly into the decision-making process, not into a folder of files.</p>
          <a href="/en/services/greenfield-projects/" class="adv-link">See how we manage Greenfield projects <span aria-hidden="true">→</span></a>
        </div>
        <div class="adv-stats">
          {/* Values are typical RTK/photogrammetry technology parameters (~1-3 cm accuracy, hours vs days).
              Replace with actual project data when available. */}
          <div class="adv-stat">
            <span class="adv-stat__val">2 cm</span>
            <span class="adv-stat__label">Geodetic survey accuracy from drone</span>
          </div>
          <div class="adv-stat">
            <span class="adv-stat__val">2 h</span>
            <span class="adv-stat__label">Survey time versus days with traditional methods</span>
          </div>
          <div class="adv-stat">
            <span class="adv-stat__val">360°</span>
            <span class="adv-stat__label">Complete construction progress documentation, independent of the contractor</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. FAQ -->
  <section class="ps-faq" aria-labelledby="h-faq">
    <div class="container">
      <h2 class="h2 h2--center" id="h-faq">FAQ — frequently asked questions</h2>
      <FaqAccordion items={faqs} single />
    </div>
  </section>

  <!-- End CTA -->
  <section class="ps-endcta" aria-labelledby="h-endcta">
    <div class="container">
      <div class="endcta-inner">
        <h2 class="endcta__h2" id="h-endcta">Need aerial data for a logistics project?</h2>
        <p class="endcta__text">Site survey, inventory scanning, roof inspection, construction monitoring or facility patrol — tell us what you need and we'll select the right application.</p>
        <div class="endcta__actions">
          <a href="/en/contact/" class="endcta__btn endcta__btn--primary">Enquire about drone services <span aria-hidden="true">→</span></a>
          <a href="/en/services/" class="endcta__btn endcta__btn--ghost">See our services <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- Detailed solutions -->
  <section class="ps-branze" aria-labelledby="h-branze">
    <div class="container">
      <h2 class="h2 h2--center" id="h-branze">Detailed solutions</h2>
      <p class="section-intro">Detailed pages for each drone application in logistics and investments.</p>
      <div class="branze-grid">
        {dronePages.map((b) => (
          <a class="branze-card" href={`/en/services/${b.slug}/`}>
            <span class="branze-card__industry">{b.industry}</span>
            <span class="branze-card__title">{b.h1}</span>
            <span class="branze-card__desc">{b.description}</span>
            <span class="branze-card__arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Related services -->
  <section class="ps-related" aria-labelledby="h-related">
    <div class="container">
      <h2 class="h2 h2--center" id="h-related">Other Vologis services</h2>
      <div class="related-grid">
        <a class="related-card" href="/en/services/greenfield-projects/">
          <span class="related-card__title">Greenfield projects</span>
          <span class="related-card__desc">From site analysis to operations launch. One partner.</span>
          <span class="related-card__arrow" aria-hidden="true">→</span>
        </a>
        <a class="related-card" href="/en/services/operational-consulting/">
          <span class="related-card__title">Operational consulting &amp; audit</span>
          <span class="related-card__desc">Bottleneck identification, process optimisation, quick wins.</span>
          <span class="related-card__arrow" aria-hidden="true">→</span>
        </a>
        <a class="related-card" href="/en/services/logistics-brokerage/">
          <span class="related-card__title">Logistics brokerage</span>
          <span class="related-card__desc">Warehouse operator, fulfillment and carrier selection and verification.</span>
          <span class="related-card__arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Cross-link: Operational security -->
  <section class="pg-crosslink" aria-label="Related services">
    <div class="container">
      <div class="crosslink-box">
        <div class="crosslink-box__content">
          <h2 class="crosslink-box__title">Drone-in-a-Box as part of Loss Prevention</h2>
          <p class="crosslink-box__text">Autonomous drone patrol is a tool within the operational security system of a logistics facility. We integrate Drone-in-a-Box with Loss Prevention processes, access control and CCTV monitoring.</p>
          <a href="/en/services/operational-security/" class="crosslink-box__link">Operational security and Loss Prevention <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </div>
  </section>

</ServicePageLayout>

<style>
  .h2 { font-family: var(--font-display); font-size: var(--text-xl); font-weight: 700; letter-spacing: -0.025em; line-height: 1.15; color: var(--color-ink); margin-bottom: var(--space-lg); }
  .h2--center { text-align: center; }
  .h2--dark { color: var(--color-ink-on-dark); }
  .body { font-size: var(--text-base); color: var(--color-muted); line-height: 1.75; margin-bottom: var(--space-md); }
  .section-intro { font-size: var(--text-md); color: var(--color-muted); line-height: 1.65; max-width: 60ch; margin-inline: auto; text-align: center; margin-bottom: var(--space-xl); }
  .dark-eyebrow { font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-blue-on-dark); margin-bottom: var(--space-md); }
  .ps-problem { padding-block: var(--space-3xl); background: var(--color-paper); }
  .ps-problem__grid { display: grid; grid-template-columns: 1fr 20rem; gap: var(--space-3xl); align-items: start; }
  .ps-brief { border: 1px solid var(--color-blue); border-radius: var(--radius-lg); background: var(--color-blue-tint); padding: var(--space-lg) var(--space-xl); position: sticky; top: calc(4.25rem + 3px + var(--space-lg)); }
  .ps-brief__label { font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-secondary); margin-bottom: var(--space-md); }
  .ps-brief__text { font-size: var(--text-base); color: var(--color-ink); line-height: 1.7; }
  .ps-brief__rule { border: none; border-top: 1px solid var(--color-blue); margin-block: var(--space-md); opacity: 0.3; }
  .ps-brief__sub { font-size: var(--text-sm); color: var(--color-muted); line-height: 1.5; }
  .ps-scope { padding-block: var(--space-3xl); background: var(--color-paper-dark); }
  .ps-scope .h2 { color: var(--color-ink-on-dark); }
  .ps-scope .body { color: var(--color-muted-on-dark); }
  .scope-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: var(--space-md); margin-top: var(--space-lg); }
  .scope-card { border: 1px solid var(--color-glass-border); border-radius: var(--radius-md); background: var(--color-glass-dark); overflow: hidden; display: flex; flex-direction: column; transition: border-color var(--dur-micro) var(--ease-out), background var(--dur-short) var(--ease-out); }
  .scope-card:hover { background: oklch(100% 0 0 / 0.08); border-color: var(--color-blue-on-dark); }
  .scope-card__img-wrap { aspect-ratio: 3 / 2; overflow: hidden; flex-shrink: 0; }
  .scope-card__img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s var(--ease-out); filter: saturate(0.85) brightness(0.92); }
  .scope-card:hover .scope-card__img { transform: scale(1.03); filter: saturate(0.95) brightness(0.98); }
  .scope-card__body { padding: var(--space-lg); flex: 1; display: flex; flex-direction: column; border-top: 3px solid var(--color-blue-on-dark); }
  .scope-card__title { font-family: var(--font-display); font-size: var(--text-base); font-weight: 700; color: var(--color-ink-on-dark); margin-bottom: var(--space-sm); }
  .scope-card__text { font-size: var(--text-sm); color: var(--color-muted-on-dark); line-height: 1.65; flex: 1; margin-bottom: var(--space-sm); }
  .ps-forwho { padding-block: var(--space-3xl); background: var(--color-paper-2); }
  .fw-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: var(--space-md); }
  .fw-card { border: 1px solid var(--color-rule); border-left: 4px solid var(--color-secondary); border-radius: var(--radius-md); padding: var(--space-lg); background: var(--color-paper); }
  .fw-card__title { font-family: var(--font-display); font-size: var(--text-base); font-weight: 700; color: var(--color-ink); margin-bottom: var(--space-sm); }
  .fw-card__text { font-size: var(--text-sm); color: var(--color-muted); line-height: 1.65; }
  .ps-advantage { padding-block: var(--space-3xl); background: var(--color-paper-dark); }
  .adv-grid { display: grid; grid-template-columns: 1fr auto; gap: var(--space-3xl); align-items: center; }
  .adv-text { font-size: var(--text-base); color: var(--color-muted-on-dark); line-height: 1.75; margin-bottom: var(--space-lg); }
  .adv-link { display: inline-flex; align-items: center; gap: var(--space-xs); font-family: var(--font-display); font-size: var(--text-base); font-weight: 600; color: var(--color-blue-on-dark); text-decoration: none; transition: color var(--dur-micro) var(--ease-out); }
  .adv-link:hover { color: var(--color-ink-on-dark); }
  .adv-stats { display: flex; flex-direction: column; gap: var(--space-lg); min-width: 16rem; }
  .adv-stat { display: flex; flex-direction: column; gap: var(--space-2xs); padding: var(--space-lg); border: 1px solid var(--color-glass-border); border-radius: var(--radius-md); background: var(--color-glass-dark); }
  .adv-stat__val { font-family: var(--font-display); font-size: var(--text-2xl, 2rem); font-weight: 700; color: var(--color-blue-on-dark); line-height: 1; letter-spacing: -0.03em; }
  .adv-stat__label { font-size: var(--text-sm); color: var(--color-muted-on-dark); line-height: 1.4; }
  .ps-faq { padding-block: var(--space-3xl); background: var(--color-paper-2); }
  .ps-endcta { padding-block: var(--space-3xl); background: var(--gradient-cta); }
  .endcta-inner { max-width: 52rem; margin-inline: auto; text-align: center; }
  .endcta__h2 { font-family: var(--font-display); font-size: var(--text-xl); font-weight: 700; letter-spacing: -0.025em; line-height: 1.2; color: var(--color-ink-on-dark); margin-bottom: var(--space-md); }
  .endcta__text { font-size: var(--text-base); color: var(--color-muted-on-dark); line-height: 1.7; margin-bottom: var(--space-xl); }
  .endcta__actions { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
  .endcta__btn { display: inline-flex; align-items: center; gap: var(--space-xs); font-family: var(--font-display); font-size: var(--text-base); font-weight: 600; padding: var(--space-md) var(--space-2xl); border-radius: var(--radius-pill); text-decoration: none; cursor: pointer; border: 1px solid transparent; transition: background var(--dur-micro) var(--ease-out), border-color var(--dur-micro) var(--ease-out); }
  .endcta__btn--primary { background: var(--color-accent); color: #fff; }
  .endcta__btn--primary:hover { background: var(--color-accent-hover); }
  .endcta__btn--ghost { background: var(--color-glass-dark); color: var(--color-ink-on-dark); border-color: var(--color-glass-border); }
  .endcta__btn--ghost:hover { background: oklch(100% 0 0 / 0.12); }
  .ps-related { padding-block: var(--space-3xl); background: var(--color-paper); border-top: 1px solid var(--color-rule); }
