---
import ServicePageLayout from "../../../layouts/ServicePageLayout.astro";
import FaqAccordion from "../../../components/FaqAccordion.astro";
import CalloutBox from "../../../components/CalloutBox.astro";

const SITE = "https://vologis.com";

const trustItems = [
  "Pre-investment analysis and site selection",
  "Warehouse masterplan and concept design",
  "CAPEX / OPEX / ROI calculations",
  "Vendor, technology and automation selection",
  "Realisation oversight and launch management",
  "Team recruitment and operational start",
  "Drone services: site surveys, orthophotomaps, construction monitoring",
];

const forWhom = [
  { title: "Logistics investors and developers",              text: "When you need end-to-end project management from site to operational readiness, without burdening your own teams." },
  { title: "Manufacturing companies building a facility",     text: "When you're constructing a new facility and need confidence that the layout and processes will work for years." },
  { title: "Fast-growing companies",                          text: "When your current warehouse is no longer sufficient and you need a larger, better-designed facility." },
  { title: "Companies relocating operations",                 text: "When you're moving logistics to a new location and cannot afford downtime or errors." },
  { title: "Funds and companies investing in logistics real estate", text: "When you need a partner managing the project for a specific tenant or for commercialisation." },
];

const scopeCards = [
  { num: "01", title: "Pre-investment analysis",       text: "We define business requirements, volume forecasts, rotation profiles and growth scenarios. We create pre-investment documentation that forms the foundation for all subsequent decisions." },
  { num: "02", title: "Site selection and analysis",   text: "We analyse locations for transport accessibility, labour market, costs, infrastructure and growth potential. We use our own drone services for site surveys and orthophotomaps of investment plots." },
  { num: "03", title: "Masterplan and concept design", text: "We design the warehouse layout, zone placement, racking, automation and traffic flow. Everything tailored to a specific rotation profile, volume and growth plans — with CAPEX/OPEX/ROI calculations." },
  { num: "04", title: "Vendor and technology selection", text: "We select and negotiate with racking, automation, WMS and equipment vendors — 100% independently. We run tenders and compare offers based on genuine return, not commissions." },
  { num: "05", title: "Realisation oversight",         text: "We coordinate project execution: construction oversight, infrastructure and IT systems implementation, automation integration. We manage schedule, budget and quality at every stage." },
  { num: "06", title: "Operations launch",             text: "We manage the operational start: testing, system commissioning, team training and recruitment. We bring the facility to full operational readiness on schedule." },
  { num: "07", title: "Post-launch optimisation",      text: "After launch we monitor processes, measure actual KPIs and compare them against the goals set at the project start. The project ends for us when we see the numbers — not on handover day." },
];

const whenItems = [
  "You're planning to build a new warehouse or distribution centre",
  "You're relocating operations to a larger or better-located facility",
  "You don't have an internal team to manage a logistics investment",
  "You want to avoid costly design-stage mistakes",
  "You need an objective site analysis before purchasing land",
  "Your team doesn't have capacity to coordinate dozens of vendors",
  "You're investing in your first automated facility and lack experience",
  "You're a developer needing end-to-end project management for a client",
];

const deliverables = [
  { title: "Pre-investment documentation and business analysis",   text: "A solid decision basis before committing capital — volume profiles, scenarios, risk." },
  { title: "Objective site analysis and recommendation",           text: "Location comparison based on hard criteria: transport, labour market, costs, infrastructure, potential." },
  { title: "Masterplan with layout and CAPEX/OPEX/ROI calculations", text: "Concept design tailored to specific volumes and processes, with full investment economics." },
  { title: "Negotiated vendor and technology offers",              text: "Objective tenders and negotiations — no commissions, no conflicts of interest, with comparative documentation." },
  { title: "Full realisation and schedule oversight",              text: "Single point of contact controlling construction, installations, IT systems and automation integration." },
  { title: "Launched, operational facility on schedule",           text: "Operational start with a trained team and tested systems — ready for full volume." },
  { title: "Post-launch KPIs achieved",                            text: "We close the project after the target performance indicators are met, not at key handover." },
];

const faqs = [
  { q: "How long does a Greenfield project take?",                  a: "A full project from pre-investment analysis to full operational readiness typically takes 6–18 months, depending on facility scale, automation level and construction pace. Design and masterplan alone: 4–10 weeks." },
  { q: "Do you also manage the construction side?",                  a: "We coordinate the project from a logistics and operational perspective and oversee vendors. We're not a general building contractor, but we work alongside developers and contractors to ensure the facility meets operational and logistics requirements." },
  { q: "Can we commission just the site selection or just the masterplan?", a: "Yes. Each stage can be commissioned separately — from site analysis alone, through the masterplan, to full project management. Many clients start with a pre-investment analysis and decide on further stages based on the results." },
  { q: "How do you select automation and WMS vendors?",              a: "100% independently. We have no partnership agreements or commissions from vendors. We run tenders, compare offers based on genuine ROI and recommend the solution best matched to the project's scale and budget." },
  { q: "How do you use drones in Greenfield projects?",              a: "At the site selection stage we conduct geodetic surveys and orthophotomaps of plots. During construction we conduct aerial construction progress monitoring. We also create visual materials for investors and for facility commercialisation." },
  { q: "What if I haven't chosen a site yet?",                       a: "That's the ideal time to engage us. Site analysis is one of the most critical stages — a mistake at this level costs you for the full operational lifetime. We'll help evaluate and compare locations before you commit to purchasing." },
];

const branze = [
  { slug: "greenfield-projects-logistics",           industry: "Logistics",              h1: "Greenfield project — logistics facility",          description: "End-to-end management of logistics investment from site to operational readiness." },
  { slug: "greenfield-projects-warehouse",           industry: "Warehouse",              h1: "Greenfield project — warehouse construction",       description: "Masterplan, automation selection and operational launch for new warehouse facilities." },
  { slug: "greenfield-projects-distribution-center", industry: "Distribution centre",   h1: "Greenfield project — distribution centre",          description: "Design and launch of a distribution centre — from site to full operational throughput." },
  { slug: "greenfield-projects-cold-storage",        industry: "Cold storage",           h1: "Greenfield project — cold storage facility",        description: "Cold storage design with temperature control, GDP requirements and cold chain operations." },
];

const schemaService = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Greenfield projects — end-to-end logistics investments",
  "provider": { "@type": "Organization", "name": "Vologis Sp. z o.o.", "url": SITE, "address": { "@type": "PostalAddress", "addressLocality": "Jarocin", "addressRegion": "Wielkopolska", "addressCountry": "PL" } },
  "areaServed": ["Poland", "Europe"],
  "serviceType": "Greenfield logistics project management",
  "description": "Vologis manages Greenfield projects end-to-end — from site analysis and masterplan, through warehouse design and automation selection, to operations launch. One partner through the full investment cycle.",
  "url": `${SITE}/en/services/greenfield-projects/`,
  "inLanguage": "en",
};

const schemaFaq = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((f) => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })),
};
---

<ServicePageLayout
  title="Greenfield Projects — End-to-End Logistics Investments | Vologis"
  description="Vologis manages Greenfield projects end-to-end — from site analysis and masterplan, through warehouse design and automation selection, to operations launch. One partner through the full investment cycle."
  canonical="https://vologis.com/en/services/greenfield-projects/"
  hreflangPL="/pl/uslugi/projekty-greenfield/"
  ogImage="/og/og-greenfield.png"
  heroImage="/services/projekty-greenfield.webp"
  eyebrow="Logistics services / Greenfield projects"
  h1="Greenfield Projects — From Empty Site to Running Operation"
  lead="Building a warehouse, distribution centre or facility from scratch is one of the most capital-intensive and high-risk projects a company undertakes. Mistakes made at the site selection or layout design stage cost you for the next 10–15 years of operation. Vologis manages Greenfield projects end-to-end — from pre-investment analysis and site selection, through masterplan and technology selection, to the physical launch of operations and hitting target KPIs. One partner, one accountability, throughout the full project lifecycle."
  trustItems={trustItems}
  ctaPrimaryLabel="Discuss your project"
  ctaPrimaryHref="/en/contact/"
  ctaSecondaryLabel="See how we work"
  ctaSecondaryHref="/en/process/"
  breadcrumbs={[{ name: "Greenfield projects" }]}
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaService)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFaq)} />

  <!-- 1. Problem -->
  <section class="ps-problem" aria-labelledby="h-problem">
    <div class="container">
      <div class="ps-problem__grid">
        <div class="ps-problem__copy">
          <h2 class="h2" id="h-problem">Greenfield decisions stay with the company for decades</h2>
          <p class="body">The wrong location, a poorly designed layout, over- or under-specified automation — these mistakes don't disappear after the building opens. They live on in operational costs, in picking times, in staff turnover and in constraints that block growth for the entire decade the facility operates.</p>
          <p class="body">The challenge is that a Greenfield project requires simultaneous coordination of dozens of parties: developers, general contractors, racking suppliers, automation integrators, WMS vendors, recruitment firms. Each focuses on their own slice. Nobody is responsible for the whole — except you.</p>
          <p class="body">Vologis takes on that role. We're one point of contact and one accountability through the full project. We integrate business, location, technical and operational analysis into a coherent whole — and drive the project to the point where operations are running against the agreed targets.</p>
        </div>
        <aside class="ps-brief" aria-label="In brief">
          <p class="ps-brief__label">In brief</p>
          <p class="ps-brief__text">A Greenfield project is comprehensive management of a logistics investment from scratch — from pre-investment analysis and site selection, through masterplan and technology selection, to operations launch and KPI achievement. Vologis acts as the single partner responsible for the full project cycle, integrating business, location, technical and operational analysis — including drone services for site surveys and construction monitoring.</p>
          <hr class="ps-brief__rule" />
          <p class="ps-brief__sub">Vologis &middot; Jarocin, Poland &middot; Serving the PL and EU markets</p>
        </aside>
      </div>
    </div>
  </section>

  <!-- 2. Scope -->
  <section class="ps-scope" aria-labelledby="h-scope">
    <div class="container">
      <h2 class="h2" id="h-scope">Greenfield project scope</h2>
      <p class="body">We manage the project through all stages — from the first spreadsheet to the moment the operation is running at full volume. We can enter at any stage.</p>
      <div class="scope-grid">
        {scopeCards.map((c) => (
          <div class="scope-card">
            <span class="scope-card__num tnum">{c.num}</span>
            <h3 class="scope-card__title">{c.title}</h3>
            <p class="scope-card__text">{c.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. Drones (dark) -->
  <section class="ps-drones" aria-labelledby="h-drones">
    <div class="container">
      <div class="drones-inner">
        <div class="drones-copy">
          <p class="dark-eyebrow">Technology advantage</p>
          <h2 class="h2 h2--dark" id="h-drones">Drones integrated into the investment project</h2>
          <p class="drones-text">Unlike conventional consulting, we integrate our own drone services directly into investment projects. At the site selection stage we provide precise geodetic surveys and orthophotomaps. During construction we conduct aerial construction progress monitoring. For developers and investors we create marketing materials presenting the facility from above.</p>
          <a href="/en/services/drone-services/" class="drones-link">See drone services <span aria-hidden="true">→</span></a>
        </div>
        <ul class="drones-pills" role="list">
          <li class="drones-pill">Site geodetic surveys</li>
          <li class="drones-pill">Orthophotomaps of investment plots</li>
          <li class="drones-pill">Construction progress monitoring</li>
          <li class="drones-pill">Investor visualisations</li>
          <li class="drones-pill">Facility commercialisation materials</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- 4. When -->
  <section class="ps-when" aria-labelledby="h-when">
    <div class="container">
      <h2 class="h2" id="h-when">When should you involve Vologis?</h2>
      <ul class="when-list when-list--2col" role="list">
        {whenItems.map((item) => (
          <li class="when-item">
            <svg class="when-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m4 10.5 4 4 8-9" /></svg>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- 5. Deliverables -->
  <section class="ps-benefits" aria-labelledby="h-benefits">
    <div class="container">
      <h2 class="h2" id="h-benefits">What you get in a Greenfield project</h2>
      <div class="ben-grid">
        {deliverables.map((d) => (
          <div class="ben-card">
            <h3 class="ben-card__title">{d.title}</h3>
            <p class="ben-card__text">{d.text}</p>
          </div>
        ))}
      </div>
      <CalloutBox>
        The earlier we enter a project, the more mistakes we can prevent — and the lower the cost of correcting them. The most expensive change is one that has to be made after the facility launches.
      </CalloutBox>
    </div>
  </section>

  <!-- 6. For whom -->
  <section class="ps-forwho" aria-labelledby="h-forwho">
    <div class="container">
      <h2 class="h2 h2--center" id="h-forwho">Who is the Greenfield service for?</h2>
      <p class="section-intro">Every logistics investment is different — in scale, specifics and complexity. We engage where a project requires coordination that the internal team can't carry alone.</p>
      <div class="fw-grid">
        {forWhom.map((p) => (
          <div class="fw-card">
            <h3 class="fw-card__title">{p.title}</h3>
            <p class="fw-card__text">{p.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 7. FAQ -->
  <section class="ps-faq" aria-labelledby="h-faq">
    <div class="container">
      <h2 class="h2 h2--center" id="h-faq">FAQ — frequently asked questions</h2>
      <FaqAccordion items={faqs} single />
    </div>
  </section>

  <!-- End CTA -->
  <section class="ps-endcta" aria-labelledby="h-endcta">
    <div class="container">
      <div class="endcta-inner">
        <h2 class="endcta__h2" id="h-endcta">Planning a logistics investment?</h2>
        <p class="endcta__text">The earlier we enter the project, the more mistakes we can prevent. Free first conversation.</p>
        <div class="endcta__actions">
          <a href="/en/contact/" class="endcta__btn endcta__btn--primary">Discuss your project <span aria-hidden="true">→</span></a>
          <a href="/en/process/" class="endcta__btn endcta__btn--ghost">See our process →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Detailed solutions -->
  <section class="ps-branze" aria-labelledby="h-branze">
    <div class="container">
      <h2 class="h2 h2--center" id="h-branze">Detailed solutions</h2>
      <p class="section-intro">Every type of logistics investment has its own specifics. See the detailed pages.</p>
      <div class="branze-grid">
        {branze.map((b) => (
          <a class="branze-card" href={`/en/services/${b.slug}/`}>
            <span class="branze-card__industry">{b.industry}</span>
            <span class="branze-card__title">{b.h1}</span>
            <span class="branze-card__desc">{b.description}</span>
            <span class="branze-card__arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Related -->
  <section class="ps-related" aria-labelledby="h-related">
    <div class="container">
      <h2 class="h2 h2--center" id="h-related">Other Vologis services</h2>
      <div class="related-grid">
        <a class="related-card" href="/en/services/operational-consulting/">
          <span class="related-card__title">Operational consulting &amp; audit</span>
          <span class="related-card__desc">Bottleneck identification, process optimisation and quick wins.</span>
          <span class="related-card__arrow" aria-hidden="true">→</span>
        </a>
        <a class="related-card" href="/en/services/drone-services/">
          <span class="related-card__title">Drone services</span>
          <span class="related-card__desc">Land surveying, orthophotomaps, inspections and construction monitoring.</span>
          <span class="related-card__arrow" aria-hidden="true">→</span>
        </a>
        <a class="related-card" href="/en/services/interim-management/">
          <span class="related-card__title">Interim Management</span>
          <span class="related-card__desc">Management support and operations stabilisation in difficult times.</span>
          <span class="related-card__arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Cross-link -->
  <section class="pg-crosslink" aria-label="Related services">
    <div class="container">
      <div class="crosslink-box">
        <div class="crosslink-box__content">
          <h2 class="crosslink-box__title">Plan facility security from the investment stage</h2>
          <p class="crosslink-box__text">Process security designed from the outset is many times cheaper than retrofitting after incidents. We integrate Greenfield projects with Loss Prevention from the planning stage.</p>
          <a href="/en/services/operational-security/" class="crosslink-box__link">Operational security and Loss Prevention <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </div>
  </section>

</ServicePageLayout>

<style>
  .h2 { font-family: var(--font-display); font-size: var(--text-xl); font-weight: 700; letter-spacing: -0.025em; line-height: 1.15; color: var(--color-ink); margin-bottom: var(--space-lg); }
  .h2--center { text-align: center; }
  .h2--dark { color: var(--color-ink-on-dark); }
  .body { font-size: var(--text-base); color: var(--color-muted); line-height: 1.75; margin-bottom: var(--space-md); }
  .section-intro { font-size: var(--text-md); color: var(--color-muted); line-height: 1.65; max-width: 60ch; margin-inline: auto; text-align: center; margin-bottom: var(--space-xl); }
  .dark-eyebrow { font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-blue-on-dark); margin-bottom: var(--space-md); }
  .ps-problem { padding-block: var(--space-3xl); background: var(--color-paper); }
  .ps-problem__grid { display: grid; grid-template-columns: 1fr 20rem; gap: var(--space-3xl); align-items: start; }
  .ps-brief { border: 1px solid var(--color-blue); border-radius: var(--radius-lg); background: var(--color-blue-tint); padding: var(--space-lg) var(--space-xl); position: sticky; top: calc(4.25rem + 3px + var(--space-lg)); }
  .ps-brief__label { font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-secondary); margin-bottom: var(--space-md); }
  .ps-brief__text { font-size: var(--text-base); color: var(--color-ink); line-height: 1.7; }
  .ps-brief__rule { border: none; border-top: 1px solid var(--color-blue); margin-block: var(--space-md); opacity: 0.3; }
  .ps-brief__sub { font-size: var(--text-sm); color: var(--color-muted); line-height: 1.5; }
  .ps-scope { padding-block: var(--space-3xl); background: var(--color-paper-2); }
  .scope-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: var(--space-md); margin-top: var(--space-lg); }
  .scope-card { border: 1px solid var(--color-rule); border-radius: var(--radius-md); padding: var(--space-lg); background: var(--color-paper); transition: border-color var(--dur-micro) var(--ease-out), box-shadow var(--dur-short) var(--ease-out); }
  .scope-card:hover { border-color: var(--color-blue); box-shadow: var(--shadow-sm); }
  .scope-card__num { display: block; font-family: var(--font-display); font-size: var(--text-sm); font-weight: 700; color: var(--color-secondary); margin-bottom: var(--space-sm); letter-spacing: 0.04em; }
  .scope-card__title { font-family: var(--font-display); font-size: var(--text-base); font-weight: 700; color: var(--color-ink); margin-bottom: var(--space-sm); }
  .scope-card__text { font-size: var(--text-sm); color: var(--color-muted); line-height: 1.65; }
  .ps-drones { padding-block: var(--space-3xl); background: var(--color-paper-dark); }
  .drones-inner { display: grid; grid-template-columns: 1fr auto; gap: var(--space-3xl); align-items: center; }
  .drones-text { font-size: var(--text-base); color: var(--color-muted-on-dark); line-height: 1.75; margin-bottom: var(--space-lg); }
  .drones-link { display: inline-flex; align-items: center; gap: var(--space-xs); font-family: var(--font-display); font-size: var(--text-base); font-weight: 600; color: var(--color-blue-on-dark); text-decoration: none; transition: color var(--dur-micro) var(--ease-out); }
  .drones-link:hover { color: var(--color-ink-on-dark); }
  .drones-pills { list-style: none; display: flex; flex-direction: column; gap: var(--space-sm); min-width: 18rem; }
  .drones-pill { font-size: var(--text-sm); font-weight: 500; color: var(--color-ink-on-dark); padding: var(--space-sm) var(--space-lg); border: 1px solid var(--color-glass-border); border-left: 3px solid var(--color-blue-on-dark); border-radius: var(--radius-sm); background: var(--color-glass-dark); line-height: 1.4; }
  .ps-when { padding-block: var(--space-3xl); background: var(--color-paper); }
  .when-list { list-style: none; display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: var(--space-md); margin-top: var(--space-lg); }
  .when-list--2col { grid-template-columns: repeat(2, 1fr); }
  .when-item { display: flex; align-items: flex-start; gap: var(--space-sm); font-size: var(--text-base); color: var(--color-ink); line-height: 1.55; }
  .when-icon { flex-shrink: 0; width: 1.2rem; height: 1.2rem; margin-top: 0.15rem; color: var(--color-blue); }
  .ps-benefits { padding-block: var(--space-3xl); background: var(--color-paper-2); }
  .ben-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: var(--space-md); margin-bottom: var(--space-xl); }
  .ben-card { border: 1px solid var(--color-rule); border-top: 3px solid var(--color-secondary); border-radius: var(--radius-md); padding: var(--space-lg); background: var(--color-paper); }
  .ben-card__title { font-family: var(--font-display); font-size: var(--text-base); font-weight: 700; color: var(--color-ink); margin-bottom: var(--space-sm); }
  .ben-card__text { font-size: var(--text-sm); color: var(--color-muted); line-height: 1.65; }
  .ps-forwho { padding-block: var(--space-3xl); background: var(--color-paper); }
  .fw-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: var(--space-md); }
  .fw-card { border: 1px solid var(--color-rule); border-left: 4px solid var(--color-secondary); border-radius: var(--radius-md); padding: var(--space-lg); background: var(--color-paper); }
  .fw-card__title { font-family: var(--font-display); font-size: var(--text-base); font-weight: 700; color: var(--color-ink); margin-bottom: var(--space-sm); }
  .fw-card__text { font-size: var(--text-sm); color: var(--color-muted); line-height: 1.65; }
  .ps-faq { padding-block: var(--space-3xl); background: var(--color-paper-2); }
  .ps-endcta { padding-block: var(--space-3xl); background: var(--gradient-cta); }
  .endcta-inner { max-width: 52rem; margin-inline: auto; text-align: center; }
  .endcta__h2 { font-family: var(--font-display); font-size: var(--text-xl); font-weight: 700; letter-spacing: -0.025em; line-height: 1.2; color: var(--color-ink-on-dark); margin-bottom: var(--space-md); }
  .endcta__text { font-size: var(--text-base); color: var(--color-muted-on-dark); line-height: 1.7; margin-bottom: var(--space-xl); }
  .endcta__actions { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
  .endcta__btn { display: inline-flex; align-items: center; gap: var(--space-xs); font-family: var(--font-display); font-size: var(--text-base); font-weight: 600; padding: var(--space-md) var(--space-2xl); border-radius: var(--radius-pill); text-decoration: none; cursor: pointer; border: 1px solid transparent; transition: background var(--dur-micro) var(--ease-out), border-color var(--dur-micro) var(--ease-out); }
