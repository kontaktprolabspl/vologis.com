---
import BaseLayout from "../../layouts/BaseLayout.astro";

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",             "item": "https://vologis.com/en/" },
    { "@type": "ListItem", "position": 2, "name": "Terms & Conditions","item": "https://vologis.com/en/terms/" }
  ]
};
---

<BaseLayout
  title="Terms &amp; Conditions | Vologis"
  description="Terms and conditions for using the vologis.com website."
  canonical="https://vologis.com/en/terms/"
  hreflangPL="/pl/regulamin/"
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />

  <div class="legal-page">
    <div class="container">
      <div class="legal-wrap">
        <header class="legal-header">
          <nav class="breadcrumb" aria-label="Breadcrumb">
            <ol class="breadcrumb-list" role="list">
              <li><a href="/en/">Home</a></li>
              <li aria-hidden="true" class="breadcrumb-sep">›</li>
              <li aria-current="page">Terms &amp; Conditions</li>
            </ol>
          </nav>
          <h1 class="legal-h1">Terms &amp; Conditions</h1>
          <p class="legal-meta">Vologis Sp. z o.o.</p>
        </header>

        <section class="legal-section">
          <p class="legal-notice">
            The full Terms &amp; Conditions of the vologis.com website are provided in Polish, as required by Polish law (Act of 18 July 2002 on the provision of electronic services).
          </p>
          <p>
            For an English summary or translation, please contact us at
            <a href="mailto:biuro@vologis.com">biuro@vologis.com</a>.
          </p>
          <p>
            <a href="/pl/regulamin/">View Terms &amp; Conditions in Polish →</a>
          </p>
        </section>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .legal-page { padding-top: calc(4.25rem + 3px + var(--space-3xl)); padding-bottom: var(--space-3xl); min-height: 60vh; }
  .legal-wrap { max-width: 48rem; }
  .legal-header { margin-bottom: var(--space-2xl); }
  .legal-h1 { font-family: var(--font-display); font-size: var(--text-xl); font-weight: 700; color: var(--color-ink); margin-bottom: var(--space-sm); }
  .legal-meta { font-size: var(--text-sm); color: var(--color-muted); }
  .legal-section { font-size: var(--text-base); color: var(--color-muted); line-height: 1.7; }
  .legal-section p { margin-bottom: var(--space-md); }
  .legal-notice { padding: var(--space-lg); background: var(--color-paper-2); border-left: 4px solid var(--color-blue); border-radius: var(--radius-sm); }
  .legal-section a { color: var(--color-secondary); }
  .breadcrumb-list { display: flex; align-items: center; gap: var(--space-2xs); list-style: none; font-size: var(--text-sm); color: var(--color-muted); margin-bottom: var(--space-lg); }
  .breadcrumb-list a { color: var(--color-muted); text-decoration: none; }
  .breadcrumb-list a:hover { color: var(--color-ink); }
  .breadcrumb-sep { color: var(--color-neutral); }
</style>
