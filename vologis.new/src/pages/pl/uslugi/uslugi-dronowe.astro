---
import ServicePageLayout from "../../../layouts/ServicePageLayout.astro";
import FaqAccordion from "../../../components/FaqAccordion.astro";
import CalloutBox from "../../../components/CalloutBox.astro";

const SITE = "https://vologis.com";
import programmatic from "../../../data/programmatic.json";
const branze = programmatic.pages.filter((p) => p.parent === "uslugi-dronowe");

/* ── Data ────────────────────────────────────────────────── */

const trustItems = [
  "Pomiary geodezyjne i ortofotomapy działek inwestycyjnych",
  "Fotogrametria, modele 3D i pomiary kubatury",
  "Inwentaryzacja zapasów dronem (RFID/LiDAR) bez wstrzymywania operacji",
  "Inspekcje dachów hal i instalacji PV z termowizją i AI",
  "Monitoring inwestycji Greenfield z powietrza",
  "Patrol i ochrona obiektów — Drone-in-a-Box",
];

const forWhom = [
  {
    title: "Deweloperzy i właściciele obiektów logistycznych",
    text: "Gdy potrzebujesz pomiarów terenu, monitoringu budowy, inspekcji stanu technicznego i dokumentacji gotowego obiektu.",
  },
  {
    title: "Inwestorzy i fundusze",
    text: "Gdy chcesz obiektywnie ocenić działkę inwestycyjną lub niezależnie kontrolować postęp realizacji inwestycji Greenfield.",
  },
  {
    title: "Operatorzy magazynowi i 3PL",
    text: "Gdy potrzebujesz dronowej inwentaryzacji zapasów w magazynie wysokiego składowania, inspekcji dachu hali lub autonomicznego patrolu obiektu.",
  },
  {
    title: "Firmy realizujące projekty Greenfield",
    text: "Gdy drony mają być integralną częścią procesu inwestycyjnego — od pomiarów geodezyjnych po monitoring budowy i ochronę gotowego obiektu.",
  },
  {
    title: "Firmy odpowiedzialne za bezpieczeństwo obiektów",
    text: "Gdy szukasz technologicznego uzupełnienia systemu ochrony i Loss Prevention — autonomiczny patrol jako element całodobowego nadzoru.",
  },
];

const scopeCards: Array<{title: string; text: string; img: string; imgAlt: string; link?: {href: string; label: string}}> = [
  {
    title: "Pomiary geodezyjne i ortofotomapy",
    text: "Precyzyjne pomiary działek inwestycyjnych i terenów pod logistykę — z dokładnością do centymetrów. Ortofotomapy dają rzeczywisty obraz terenu gotowy do projektowania layoutu, analizy dostępności i dokumentacji inwestycyjnej.",
    img: "/services/drony/drony-ortofotomapa.png",
    imgAlt: "Ortofotomapa działki inwestycyjnej — widok z drona z punktami pomiarowymi",
  },
  {
    title: "Modele 3D, fotogrametria i pomiary kubatury",
    text: "Digital twins terenu i obiektów logistycznych: modele 3D powstałe ze zdjęć z drona (fotogrametria). Precyzyjny pomiar kubatury składowanych materiałów sypkich i hałd — kontrola ilościowa bez ręcznych pomiarów w terenie. Dane wspierają projekty Greenfield od etapu planowania.",
    img: "/services/drony/drony-model-3d.png",
    imgAlt: "Model fotogrametryczny 3D terenu z mapą wysokości DEM — gradient kolorów od niebieskiego do żółtego",
    link: { href: "/pl/uslugi/projekty-greenfield/", label: "Zobacz projekty Greenfield" },
  },
  {
    title: "Inwentaryzacja zapasów w magazynie",
    text: "Drony z czytnikami kodów kreskowych, RFID i skanerami LiDAR autonomicznie liczą i lokalizują palety między regałami wysokiego składowania — także nocą, bez wstrzymywania operacji. Eliminują błędy ręcznych liczeń i zwalniają zasoby ludzkie z żmudnej inwentaryzacji.",
    img: "/services/drony/drony-inwentaryzacja.png",
    imgAlt: "Wnętrze magazynu wysokiego składowania — widok drona między regałami z paletami",
  },
  {
    title: "Inspekcje obiektów logistycznych",
    text: "Inspekcje dachów hal magazynowych, instalacji fotowoltaicznych i stanu technicznego obiektów. Kamery termowizyjne i algorytmy AI wykrywają mikrouszkodzenia, wady izolacji i awarie PV zanim staną się kosztownymi naprawami lub przerwami operacyjnymi.",
    img: "/services/drony/drony-inspekcja.png",
    imgAlt: "Termowizyjna inspekcja dachu hali magazynowej z panelami PV — obraz z drona w palecie ciepła",
  },
  {
    title: "Monitoring postępu budowy",
    text: "Regularna dokumentacja postępu prac z powietrza — od pierwszych prac ziemnych po odbiór obiektu. Obiektywny, datowany obraz dla inwestora, niezależny od raportów wykonawcy. Zintegrowany z prowadzeniem inwestycji Greenfield przez Vologis.",
    img: "/services/drony/drony-budowa.png",
    imgAlt: "Aerial shot budowy centrum logistycznego — stalowa konstrukcja i fundamenty, widok z drona",
    link: { href: "/pl/uslugi/projekty-greenfield/", label: "Zobacz projekty Greenfield" },
  },
  {
    title: "Patrol i ochrona obiektów — Drone-in-a-Box",
    text: "Autonomiczne patrole wokół centrów logistycznych i magazynów. Dron startuje automatycznie przy naruszeniu strefy, przekazując wideo do centrum ochrony w czasie rzeczywistym. Uzupełnienie procesów Loss Prevention — element całodobowego systemu bezpieczeństwa operacyjnego.",
    img: "/services/drony/drony-patrol.png",
    imgAlt: "Nocny widok centrum logistycznego z lotu drona — ogrodzony teren z oświetlonym placem",
    link: { href: "/pl/uslugi/bezpieczenstwo-operacyjne/", label: "Bezpieczeństwo operacyjne i Loss Prevention" },
  },
];

const faqs = [
  {
    q: "Czy drony mogą inwentaryzować zapasy bez wstrzymywania operacji magazynowej?",
    a: "Tak. Drony wyposażone w czytniki RFID, kodów kreskowych i skanery LiDAR przeprowadzają autonomiczną inwentaryzację między regałami wysokiego składowania — często nocą lub w sekcjach poza aktywną operacją, bez konieczności zatrzymywania wózków widłowych ani ewakuacji personelu.",
  },
  {
    q: "Jaka jest dokładność pomiarów geodezyjnych z drona?",
    a: "Przy zastosowaniu odpowiednich procedur i punktów referencyjnych osiągamy dokładność do kilku centymetrów. Konkretny poziom dokładności ustalamy w zależności od celu pomiaru i wymagań projektu.",
  },
  {
    q: "Czym różni się inspekcja termowizyjna od standardowego przeglądu dachu?",
    a: "Kamera termowizyjna na dronie wykrywa nieszczelności, wady izolacji i anomalie cieplne instalacji PV, których nie widać gołym okiem podczas standardowej inspekcji. Algorytmy AI automatycznie lokalizują i klasyfikują anomalie — skracając czas analizy i dokumentując stan obiektu w formie gotowej do przeglądu inżynierskiego.",
  },
  {
    q: "Jak działa system Drone-in-a-Box?",
    a: "Drone-in-a-Box to autonomiczna stacja dokująca z dronem, który startuje samoczynnie przy wykryciu naruszenia strefy przez system alarmowy lub na żądanie operatora. Dron transmituje wideo do centrum ochrony w czasie rzeczywistym i wraca automatycznie na stację po zakończeniu patrolu. Stanowi uzupełnienie systemu CCTV i fizycznej ochrony.",
  },
  {
    q: "Czy monitoring budowy jest jednorazowy czy cykliczny?",
    a: "Najczęściej cykliczny — regularne loty w ustalonych odstępach dają obiektywny obraz postępu prac w czasie. Możliwy jest też pojedynczy pomiar lub dokumentacja na konkretnym etapie inwestycji.",
  },
];

/* ── Schema ───────────────────────────────────────────────── */

const schemaService = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Usługi dronowe dla logistyki i inwestycji",
  "provider": {
    "@type": "Organization",
    "name": "Vologis Sp. z o.o.",
    "url": SITE,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Jarocin",
      "addressRegion": "Wielkopolska",
      "addressCountry": "PL",
    },
  },
  "areaServed": ["Polska", "Europa"],
  "serviceType": "Drone services for logistics: surveys, inspections, warehouse inventory, Drone-in-a-Box patrol",
  "description": "Usługi dronowe wyłącznie dla logistyki: pomiary geodezyjne, modele 3D, autonomiczna inwentaryzacja zapasów, inspekcje obiektów z AI, monitoring Greenfield i patrol Drone-in-a-Box. Vologis integruje dane dronowe z projektami logistycznymi.",
  "url": `${SITE}/pl/uslugi/uslugi-dronowe/`,
};

const schemaWebPage = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Drony w logistyce — pomiary, inspekcje, inwentaryzacja i ochrona obiektów | Vologis",
  "description": "Usługi dronowe wyłącznie dla logistyki: pomiary geodezyjne, modele 3D, autonomiczna inwentaryzacja zapasów, inspekcje obiektów z AI, monitoring Greenfield i patrol Drone-in-a-Box. Vologis integruje dane dronowe z projektami logistycznymi.",
  "url": `${SITE}/pl/uslugi/uslugi-dronowe/`,
  "inLanguage": "pl-PL",
};

const schemaFaq = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((f) => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
};
---

<ServicePageLayout
  title="Drony w logistyce — pomiary, inspekcje, inwentaryzacja i ochrona obiektów | Vologis"
  description="Usługi dronowe dla logistyki: ortofotomapy, modele 3D, autonomiczna inwentaryzacja zapasów, inspekcje obiektów z AI, monitoring Greenfield i Drone-in-a-Box. Zintegrowane z projektami logistycznymi."
  canonical="https://vologis.com/pl/uslugi/uslugi-dronowe/"
  ogImage="/og/og-drony.png"
  heroImage="/services/uslugi-dronowe.webp"
  eyebrow="Usługi logistyczne / Usługi dronowe"
  h1="Drony w logistyce — pomiary, inspekcje, inwentaryzacja i ochrona obiektów"
  lead="Dron w logistyce to precyzyjne narzędzie analityczne: skraca czas inwestycji, kontroluje zapasy bez wstrzymywania operacji i wzmacnia bezpieczeństwo obiektu. Vologis stosuje drony wyłącznie w zastosowaniach logistycznych — od pomiarów działek i fotogrametrii, przez autonomiczną inwentaryzację w magazynach wysokiego składowania, inspekcje hal z termowizją i AI, po autonomiczne patrole Drone-in-a-Box. Dane integrujemy bezpośrednio z projektami logistycznymi."
  trustItems={trustItems}
  ctaPrimaryLabel="Zapytaj o usługi dronowe"
  ctaPrimaryHref="/pl/kontakt/"
  ctaSecondaryLabel="Zobacz projekty Greenfield"
  ctaSecondaryHref="/pl/uslugi/projekty-greenfield/"
  breadcrumbs={[{ name: "Usługi dronowe" }]}
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaService)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaWebPage)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFaq)} />

  <!-- ─── 1. Problem / Wartość ──────────────────────────────── -->
  <section class="ps-problem" aria-labelledby="h-problem">
    <div class="container">
      <div class="ps-problem__grid">
        <div class="ps-problem__copy">
          <h2 class="h2" id="h-problem">
            Trzy problemy, które dron rozwiązuje szybciej i taniej niż metody tradycyjne
          </h2>
          <p class="body">
            Tradycyjny pomiar geodezyjny dużej działki inwestycyjnej zajmuje dni i angażuje zespół w terenie. Dron robi to w godziny, z dokładnością do centymetrów — a ortofotomapa i model 3D trafiają od razu do projektantów layoutu i analityków inwestycyjnych.
          </p>
          <p class="body">
            W magazynach wysokiego składowania ręczna inwentaryzacja to dni przestoju i błędy sięgające kilku procent stanów. Drony z RFID i LiDAR autonomicznie skanują regały nocą, bez wstrzymywania operacji — i dostarczają dokładny obraz stanu zapasów gotowy do rana.
          </p>
          <p class="body">
            Patrol obiektu tradycyjnymi metodami ma martwe strefy i zależy od dostępności ochrony. Drone-in-a-Box startuje automatycznie przy naruszeniu strefy i natychmiast przekazuje obraz do centrum ochrony. To uzupełnienie Loss Prevention, które działa całą dobę bez dodatkowego etatu.
          </p>
        </div>
        <aside class="ps-brief" aria-label="W skrócie">
          <p class="ps-brief__label">W skrócie</p>
          <p class="ps-brief__text">
            Usługi dronowe Vologis obejmują 6 zastosowań logistycznych: pomiary geodezyjne i ortofotomapy działek, fotogrametrię i modele 3D z pomiarem kubatury, autonomiczną inwentaryzację zapasów (RFID/LiDAR), inspekcje obiektów z termowizją i AI, monitoring postępu budowy Greenfield oraz patrol i ochronę obiektów (Drone-in-a-Box). Vologis integruje dane dronowe bezpośrednio z projektami logistycznymi — interpretując je w kontekście konkretnych decyzji inwestycyjnych i operacyjnych.
          </p>
          <hr class="ps-brief__rule" />
          <p class="ps-brief__sub">
            Vologis &middot; Jarocin, Polska &middot; Obsługa rynku PL i EU
          </p>
        </aside>
      </div>
    </div>
  </section>

  <!-- ─── 2. Co obejmują usługi ─────────────────────────────── -->
  <section class="ps-scope" aria-labelledby="h-scope">
    <div class="container">
      <h2 class="h2" id="h-scope">6 zastosowań dronów w logistyce</h2>
      <p class="body">
        Wyłącznie logistyczne zastosowania — od pomiarów terenu pod inwestycję po autonomiczną inwentaryzację i ochronę gotowego obiektu.
      </p>
      <div class="scope-grid">
        {scopeCards.map((c) => (
          <div class="scope-card">
            <div class="scope-card__img-wrap">
              <img
                src={c.img}
                alt={c.imgAlt}
                width="1200"
                height="800"
                loading="lazy"
                decoding="async"
                class="scope-card__img"
              />
            </div>
            <div class="scope-card__body">
              <h3 class="scope-card__title">{c.title}</h3>
              <p class="scope-card__text">{c.text}</p>
              {c.link && (
                <a href={c.link.href} class="adv-link">
                  {c.link.label} <span aria-hidden="true">→</span>
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── 3. Dla kogo ───────────────────────────────────────── -->
  <section class="ps-forwho" aria-labelledby="h-forwho">
    <div class="container">
      <h2 class="h2 h2--center" id="h-forwho">Dla kogo są usługi dronowe?</h2>
      <p class="section-intro">
        Pracujemy wszędzie tam, gdzie precyzyjne dane z powietrza mają realny wpływ na decyzje inwestycyjne i operacyjne.
      </p>
      <div class="fw-grid">
        {forWhom.map((p) => (
          <div class="fw-card">
            <h3 class="fw-card__title">{p.title}</h3>
            <p class="fw-card__text">{p.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── 4. Przewaga: drony + logistyka (dark) ────────────── -->
  <section class="ps-advantage" aria-labelledby="h-advantage">
    <div class="container">
      <div class="adv-grid">
        <div class="adv-copy">
          <p class="dark-eyebrow">Unikalna integracja</p>
          <h2 class="h2 h2--dark" id="h-advantage">
            Czym różnimy się od typowej firmy dronowej
          </h2>
          <p class="adv-text">
            Firma dronowa dostarczy Ci zdjęcia. My dostarczamy dane w kontekście Twojego projektu logistycznego. Wiemy, co oznacza ortofotomapa dla layoutu magazynu, jak inwentaryzacja dronem przekłada się na ciągłość operacji i jak Drone-in-a-Box integruje się z systemem bezpieczeństwa obiektu.
          </p>
          <p class="adv-text">
            Usługi dronowe to u nas element większej całości — doradztwa logistycznego, projektów Greenfield i bezpieczeństwa operacyjnego. Dane z drona trafiają bezpośrednio do procesu decyzyjnego, nie do folderu z plikami.
          </p>
          <a href="/pl/uslugi/projekty-greenfield/" class="adv-link">
            Zobacz jak prowadzimy projekty Greenfield <span aria-hidden="true">→</span>
          </a>
        </div>
        <div class="adv-stats">
          {/* Wartości to typowe parametry technologii dronowej (dokładność RTK/fotogrametria ~1-3 cm,
              pomiar w godzinach zamiast dni). Do podmiany na realne dane z projektów, jeśli dostępne. */}
          <div class="adv-stat">
            <span class="adv-stat__val">2 cm</span>
            <span class="adv-stat__label">Dokładność pomiarów geodezyjnych z drona</span>
          </div>
          <div class="adv-stat">
            <span class="adv-stat__val">2 h</span>
            <span class="adv-stat__label">Czas pomiaru zamiast dni tradycyjnych metod</span>
          </div>
          <div class="adv-stat">
            <span class="adv-stat__val">360°</span>
            <span class="adv-stat__label">Pełna dokumentacja postępu budowy, niezależna od wykonawcy</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── 5. FAQ ────────────────────────────────────────────── -->
  <section class="ps-faq" aria-labelledby="h-faq">
    <div class="container">
      <h2 class="h2 h2--center" id="h-faq">FAQ — najczęściej zadawane pytania</h2>
      <FaqAccordion items={faqs} single />
    </div>
  </section>

  <!-- ─── CTA końcowe ───────────────────────────────────────── -->
  <section class="ps-endcta" aria-labelledby="h-endcta">
    <div class="container">
      <div class="endcta-inner">
        <h2 class="endcta__h2" id="h-endcta">
          Potrzebujesz danych z powietrza dla projektu logistycznego?
        </h2>
        <p class="endcta__text">
          Pomiar działki, inwentaryzacja zapasów, inspekcja dachu, monitoring budowy czy patrol obiektu. Powiedz czego potrzebujesz — dobierzemy właściwe zastosowanie.
        </p>
        <div class="endcta__actions">
          <a href="/pl/kontakt/" class="endcta__btn endcta__btn--primary">
            Zapytaj o usługi dronowe <span aria-hidden="true">→</span>
          </a>
          <a href="/pl/uslugi/" class="endcta__btn endcta__btn--ghost">
            Zobacz nasze usługi <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Rozwiązania szczegółowe ──────────────────────── -->
  <section class="ps-branze" aria-labelledby="h-branze">
    <div class="container">
      <h2 class="h2 h2--center" id="h-branze">Rozwiązania szczegółowe</h2>
      <p class="section-intro">
        Sprawdź szczegółowe strony dla każdego zastosowania dronów w logistyce i inwestycjach.
      </p>
      <div class="branze-grid">
        {branze.map((b) => (
          <a class="branze-card" href={`/pl/uslugi/${b.slug}`}>
            <span class="branze-card__industry">{b.industry}</span>
            <span class="branze-card__title">{b.h1}</span>
            <span class="branze-card__desc">{b.description}</span>
            <span class="branze-card__arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Related services ─────────────────────────────────── -->
  <section class="ps-related" aria-labelledby="h-related">
    <div class="container">
      <h2 class="h2 h2--center" id="h-related">Inne usługi Vologis</h2>
      <div class="related-grid">
        <a class="related-card" href="/pl/uslugi/projekty-greenfield">
          <span class="related-card__title">Projekty Greenfield</span>
          <span class="related-card__desc">Od analizy lokalizacji do uruchomienia operacji. Jeden partner.</span>
          <span class="related-card__arrow" aria-hidden="true">→</span>
        </a>
        <a class="related-card" href="/pl/uslugi/doradztwo-operacyjne">
          <span class="related-card__title">Doradztwo operacyjne i audyt</span>
          <span class="related-card__desc">Identyfikacja wąskich gardeł, optymalizacja procesów, quick wins.</span>
          <span class="related-card__arrow" aria-hidden="true">→</span>
        </a>
        <a class="related-card" href="/pl/uslugi/posrednictwo-logistyczne">
          <span class="related-card__title">Pośrednictwo logistyczne</span>
          <span class="related-card__desc">Dobór i weryfikacja operatorów magazynowych, fulfillment i przewoźników.</span>
          <span class="related-card__arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ─── Cross-link: Bezpieczeństwo ──────────────────── -->
  <section class="pg-crosslink" aria-label="Powiązane usługi">
    <div class="container">
      <div class="crosslink-box">
        <div class="crosslink-box__content">
          <h2 class="crosslink-box__title">Drone-in-a-Box jako element Loss Prevention</h2>
          <p class="crosslink-box__text">Autonomiczny patrol dronem to narzędzie w systemie bezpieczeństwa operacyjnego obiektu logistycznego. Łączymy Drone-in-a-Box z procesami Loss Prevention, kontrolą dostępu i monitoringiem CCTV.</p>
          <a href="/pl/uslugi/bezpieczenstwo-operacyjne" class="crosslink-box__link">
            Bezpieczeństwo operacyjne i Loss Prevention <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
