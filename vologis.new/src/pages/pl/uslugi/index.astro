---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ServiceCard from "../../../components/ServiceCard.astro";
import Eyebrow from "../../../components/Eyebrow.astro";
import HeroCTAs from "../../../components/HeroCTAs.astro";

const icons = {
  route: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="19" r="2.5"/><circle cx="18" cy="5" r="2.5"/><path d="M8.5 19H15a3.5 3.5 0 0 0 0-7H9a3.5 3.5 0 0 1 0-7h6.5"/></svg>`,
  search: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>`,
  warehouse: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21V8l9-5 9 5v13"/><path d="M3 21h18"/><path d="M8 21v-6h8v6"/><path d="M8 12h8"/></svg>`,
  drone: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="6" height="6" rx="1"/><path d="M9 9 5 5M15 9l4-4M9 15l-4 4M15 15l4 4"/><circle cx="4" cy="4" r="2"/><circle cx="20" cy="4" r="2"/><circle cx="4" cy="20" r="2"/><circle cx="20" cy="20" r="2"/></svg>`,
  bolt: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 4 14h7l-1 8 9-12h-7l1-8Z"/></svg>`,
};

const services = [
  {
    number: "01",
    icon: icons.route,
    title: "Pośrednictwo logistyczne i fulfillment",
    subtitle: "Jeden partner zamiast dziesiątek rozmów z operatorami.",
    bullets: [
      "Wyszukiwanie i weryfikacja operatorów magazynowych",
      "Negocjowanie warunków i SLA w imieniu klienta",
      "Obsługa branż specjalistycznych (chłodnie, ADR, farmacja)",
      "Porównanie ofert i rekomendacja optymalnego rozwiązania",
      "Pełna niezależność — bez ukrytych prowizji od dostawców",
    ],
    href: "/pl/uslugi/posrednictwo-logistyczne",
  },
  {
    number: "02",
    icon: icons.search,
    title: "Doradztwo operacyjne i audyt",
    subtitle: "Sprawdzimy gdzie Twoja logistyka traci pieniądze, czas i ludzi.",
    bullets: [
      "Audyt procesów magazynowych i transportowych",
      "Identyfikacja wąskich gardeł i quick wins",
      "Dobór systemów WMS, automatyki i robotyki",
      "Projektowanie layoutów magazynowych",
      "Policzalne rekomendacje — nie ogólniki",
    ],
    href: "/pl/uslugi/doradztwo-operacyjne",
  },
  {
    number: "03",
    icon: icons.warehouse,
    title: "Kompleksowe projekty Greenfield",
    subtitle: "Od pustej działki do gotowej operacji. Jeden partner, pełna odpowiedzialność.",
    bullets: [
      "Analiza przedinwestycyjna i wybór lokalizacji",
      "Projekt koncepcyjny i dobór dostawców",
      "Nadzór nad przygotowaniem obiektu",
      "Wdrożenie systemów i infrastruktury",
      "Rekrutacja zespołu i start operacyjny",
    ],
    href: "/pl/uslugi/projekty-greenfield",
  },
  {
    number: "04",
    icon: icons.drone,
    title: "Nowoczesne usługi dronowe",
    subtitle: "Innowacyjna technologia zintegrowana z projektami logistycznymi.",
    bullets: [
      "Pomiary geodezyjne i ortofotomapy",
      "Inspekcje terenów inwestycyjnych",
      "Monitoring postępu prac budowlanych",
      "Materiały marketingowe z powietrza (foto/wideo)",
      "Dokumentacja dla deweloperów i inwestorów",
    ],
    href: "/pl/uslugi/uslugi-dronowe",
  },
  {
    number: "05",
    icon: icons.bolt,
    title: "Interim Management i restrukturyzacja",
    subtitle: "Twój dyrektor logistyki odszedł? Masz kryzys operacyjny? Wskakujemy od poniedziałku.",
    bullets: [
      "Błyskawiczna diagnoza i gaszenie pożarów",
      "Czasowe wsparcie zarządcze na poziomie C-level",
      "Restrukturyzacja procesów i redukcja kosztów",
      "Stabilizacja operacji w trudnych warunkach",
      "Elastyczne modele współpracy i rozliczenia",
    ],
    href: "/pl/uslugi/interim-management",
  },
];

const processSteps = [
  { num: "01", name: "Analiza i identyfikacja potrzeb", desc: "Mapujemy sytuację, definiujemy problem, tworzymy plan działania." },
  { num: "02", name: "Quick Wins", desc: "Natychmiastowe zmiany procesowe bez czekania na duże wdrożenia." },
  { num: "03", name: "Wybór lokalizacji i partnerów", desc: "Research rynku, negocjacje, projekt koncepcyjny." },
  { num: "04", name: "Wdrożenie operacyjne", desc: "Przejmujemy koordynację projektu aż do startu operacyjnego." },
  { num: "05", name: "Optymalizacja i rozwój", desc: "Monitorujemy KPI, wdrażamy długofalowe usprawnienia." },
];

const SITE = "https://vologis.com";

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": `${SITE}/pl/` },
    { "@type": "ListItem", "position": 2, "name": "Usługi", "item": `${SITE}/pl/uslugi` },
  ],
};

const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Usługi logistyczne Vologis",
  "itemListElement": services.map((s, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "Service",
      "name": s.title,
      "description": s.subtitle,
      "url": `${SITE}${s.href}`,
    },
  })),
};
---

<BaseLayout
  title="Usługi logistyczne end-to-end — Vologis"
  description="Pięć sposobów na to, żeby Twoja logistyka przestała być kosztem, a zaczęła działać. Każda usługa oparta na praktyce operacyjnej, nie teorii."
  canonical="https://vologis.com/pl/uslugi"
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaItemList)} />

  <!-- ── 1. Hero ─────────────────────────────────────── -->
  <section class="svc-hero" aria-labelledby="svc-heading">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol class="breadcrumb-list" role="list">
          <li><a href="/pl/">Strona główna</a></li>
          <li aria-hidden="true" class="breadcrumb-sep">›</li>
          <li aria-current="page">Usługi</li>
        </ol>
      </nav>
      <Eyebrow text="NASZE USŁUGI" />
      <h1 id="svc-heading" class="svc-hero__h1">
        Logistyka end-to-end.<br>Nie zostawiamy Cię z raportem.
      </h1>
      <p class="svc-hero__sub">
        Pięć obszarów wsparcia — od pierwszej analizy po fizyczne wdrożenie
        i optymalizację. Działamy projektowo, rozliczamy się za efekty.
      </p>
      <HeroCTAs
        primaryLabel="Umów konsultację"
        primaryHref="/pl/kontakt"
        secondaryLabel="Zobacz jak pracujemy"
        secondaryHref="/pl/proces"
      />
    </div>
  </section>

  <!-- ── 2. Services grid ────────────────────────────── -->
  <section class="svc-grid-section" aria-labelledby="svc-grid-heading">
    <div class="container">
      <h2 id="svc-grid-heading" class="sr-only">Zakres usług</h2>
      <div class="svc-grid">
        {services.map((s) => (
          <ServiceCard
            icon={s.icon}
            number={s.number}
            title={s.title}
            subtitle={s.subtitle}
            bullets={s.bullets}
            href={s.href}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ── 3. How we work (process strip) ──────────────── -->
  <section class="proc-strip" aria-labelledby="proc-heading">
    <div class="container">
      <h2 id="proc-heading" class="proc-strip__title">Jak pracujemy</h2>
      <ol class="proc-strip__steps">
        {processSteps.map((step) => (
          <li class="proc-step">
            <span class="proc-step__num tnum" aria-hidden="true">{step.num}</span>
            <h3 class="proc-step__name">{step.name}</h3>
            <p class="proc-step__desc">{step.desc}</p>
          </li>
        ))}
      </ol>
      <a href="/pl/proces" class="proc-strip__link">
        Zobacz szczegółowy opis procesu <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <!-- ── 4. USP strip ────────────────────────────────── -->
  <section class="usp-strip" aria-labelledby="usp-heading">
    <div class="container">
      <h2 id="usp-heading" class="sr-only">Dlaczego Vologis</h2>
      <div class="usp-grid">
        <div class="usp-col">
          <span class="usp-col__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0Z"/><path d="m8.5 12 2.5 2.5 4.5-5"/></svg>
          </span>
          <h3 class="usp-col__title">Realne wdrożenie, nie raport</h3>
          <p class="usp-col__desc">
            Nie kończymy pracy na zostawieniu dokumentu. Bierzemy odpowiedzialność
            za fizyczne wdrożenie zmian aż do osiągnięcia ustalonych KPI.
          </p>
        </div>

        <div class="usp-col">
          <span class="usp-col__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3 4 6v5c0 5 3.5 8 8 10 4.5-2 8-5 8-10V6l-8-3Z"/></svg>
          </span>
          <h3 class="usp-col__title">100% niezależność</h3>
          <p class="usp-col__desc">
            Nie jesteśmy powiązani z żadnym operatorem, deweloperem ani dostawcą
            technologii. Dobieramy rozwiązania wyłącznie pod kątem Twojego ROI.
          </p>
        </div>

        <div class="usp-col">
          <span class="usp-col__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M18.4 5.6l-2.1 2.1M7.7 16.3l-2.1 2.1"/></svg>
          </span>
          <h3 class="usp-col__title">Jeden punkt kontaktu</h3>
          <p class="usp-col__desc">
            Lokalizacja, operacje magazynowe, automatyka, usługi dronowe — zdejmujemy
            z Ciebie ciężar koordynacji. Jeden partner, pełen zakres.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 5. CTA ──────────────────────────────────────── -->
  <section class="svc-cta" aria-labelledby="svc-cta-heading">
    <div class="container">
      <div class="svc-cta__inner">
        <h2 id="svc-cta-heading" class="svc-cta__title">Planujesz projekt logistyczny?</h2>
        <p class="svc-cta__sub">
          Bezpłatna konsultacja — zero zobowiązań. Odpowiemy w ciągu 24 godzin.
        </p>
        <div class="svc-cta__actions">
          <a href="/pl/kontakt" class="cta-btn cta-btn--primary">
            Umów konsultację <span aria-hidden="true">→</span>
          </a>
          <a href="/pl/proces" class="cta-btn cta-btn--ghost">
            Zobacz nasz proces <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Breadcrumb (on dark hero) ───────────────────── */
  .breadcrumb {
    margin-bottom: var(--space-lg);
  }

  .breadcrumb-list {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    list-style: none;
    font-size: var(--text-sm);
    color: var(--color-muted-on-dark);
  }

  .breadcrumb-list a {
    color: var(--color-muted-on-dark);
    text-decoration: none;
    transition: color var(--dur-micro) var(--ease-out);
  }

  .breadcrumb-list a:hover { color: var(--color-ink-on-dark); }

  .breadcrumb-sep { color: var(--color-muted-on-dark); user-select: none; opacity: 0.6; }

  .breadcrumb-list [aria-current="page"] { color: var(--color-ink-on-dark); font-weight: 500; }

  /* ── 1. Hero ─────────────────────────────────────── */
  .svc-hero {
    background: var(--color-paper-dark);
    color: var(--color-ink-on-dark);
    padding-top: calc(var(--space-3xl) + 5rem);
    padding-bottom: var(--space-3xl);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.14em;
    color: var(--color-blue-on-dark);
    text-transform: uppercase;
    margin-bottom: var(--space-md);
  }

  .svc-hero__h1 {
    font-family: var(--font-display);
    font-size: var(--text-display-s);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.08;
    color: var(--color-ink-on-dark);
    margin-bottom: var(--space-lg);
  }

  .svc-hero__sub {
    font-size: var(--text-md);
    color: var(--color-muted-on-dark);
    max-width: 60ch;
    line-height: 1.6;
    margin-bottom: var(--space-xl);
  }

  /* ── 2. Services grid ────────────────────────────── */
  .svc-grid-section {
    padding-block: var(--space-3xl);
  }

  .svc-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  /* ── 3. Process strip ────────────────────────────── */
  .proc-strip {
    background: var(--color-paper-dark);
    color: var(--color-ink-on-dark);
    padding-block: var(--space-3xl);
  }

  .proc-strip__title {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-blue-on-dark);
    margin-bottom: var(--space-xl);
  }

  .proc-strip__steps {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-lg);
    list-style: none;
  }

  .proc-step {
    position: relative;
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-glass-border);
  }

  .proc-step__num {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.04em;
    color: oklch(85.4% 0.052 199 / 0.45);
    margin-bottom: var(--space-sm);
  }

  .proc-step__name {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-ink-on-dark);
    margin-bottom: var(--space-xs);
    line-height: 1.25;
  }

  .proc-step__desc {
    font-size: var(--text-sm);
    color: var(--color-muted-on-dark);
    line-height: 1.5;
  }

  .proc-strip__link {
    display: inline-block;
    margin-top: var(--space-xl);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-blue-on-dark);
    text-decoration: none;
    transition: color var(--dur-micro) var(--ease-out);
  }

  .proc-strip__link span { display: inline-block; transition: transform var(--dur-short) var(--ease-out); }
  .proc-strip__link:hover { color: var(--color-ink-on-dark); }
  .proc-strip__link:hover span { transform: translateX(4px); }

  /* ── 4. USP strip ────────────────────────────────── */
  .usp-strip {
    background: var(--color-paper-2);
    padding-block: var(--space-3xl);
  }

  .usp-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .usp-col__icon {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-md);
    background: var(--color-paper);
    color: var(--color-blue);
    margin-bottom: var(--space-md);
  }

  .usp-col__icon svg { width: 1.5rem; height: 1.5rem; }

  .usp-col__title {
    font-family: var(--font-display);
    font-size: var(--text-md);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin-bottom: var(--space-sm);
  }

  .usp-col__desc {
    font-size: var(--text-base);
    color: var(--color-muted);
    line-height: 1.6;
  }

  /* ── 5. CTA ──────────────────────────────────────── */
  .svc-cta {
    background: var(--color-paper-dark);
    padding-block: var(--space-3xl);
  }

  .svc-cta__inner {
    text-align: center;
    max-width: 44rem;
    margin-inline: auto;
  }

  .svc-cta__title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--color-ink-on-dark);
    margin-bottom: var(--space-md);
  }

  .svc-cta__sub {
    font-size: var(--text-md);
    color: var(--color-muted-on-dark);
    line-height: 1.6;
    margin-bottom: var(--space-xl);
  }

  .svc-cta__actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 700;
    border-radius: var(--radius-pill);
    padding: var(--space-sm) var(--space-xl);
    text-decoration: none;
    border: 1px solid transparent;
    transition:
      background var(--dur-micro) var(--ease-out),
      border-color var(--dur-micro) var(--ease-out),
      color var(--dur-micro) var(--ease-out),
      transform var(--dur-micro) var(--ease-out);
  }

  .cta-btn span { display: inline-block; transition: transform var(--dur-short) var(--ease-out); }
  .cta-btn:hover span { transform: translateX(4px); }

  .cta-btn--primary {
    color: var(--color-ink-on-dark);
    background: var(--color-accent);
    box-shadow: 0 8px 24px oklch(61.2% 0.208 22 / 0.32);
  }

  .cta-btn--primary:hover {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
  }

  .cta-btn--ghost {
    color: var(--color-ink-on-dark);
    border-color: var(--color-glass-border);
  }

  .cta-btn--ghost:hover {
    background: var(--color-ink-on-dark);
    color: var(--color-ink);
    border-color: var(--color-ink-on-dark);
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 60rem) {
    .svc-grid { grid-template-columns: 1fr; }
    .proc-strip__steps { grid-template-columns: 1fr 1fr; gap: var(--space-xl); }
    .usp-grid { grid-template-columns: 1fr; gap: var(--space-2xl); }
  }

  @media (max-width: 40rem) {
    .svc-hero__h1 { font-size: var(--text-display-s); }
    .proc-strip__steps { grid-template-columns: 1fr; }
    .svc-cta__actions { flex-direction: column; align-items: stretch; }
    .cta-btn { justify-content: center; }
  }
</style>
