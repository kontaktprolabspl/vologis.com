    spedycja: "Czy klient mieści się w naszych procesach i stawkach?",
    vologis: "Który operator lub partner fulfillment najlepiej pasuje do potrzeb i budżetu klienta?",
  },
  {
    feature: "Zakres",
    transport: "Najem lub sprzedaż powierzchni.",
    spedycja: "Własna oferta: składowanie, obsługa, transport.",
