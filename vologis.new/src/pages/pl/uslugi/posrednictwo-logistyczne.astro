/* ── Schema ───────────────────────────────────────────────── */

const schemaService = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Pośrednictwo logistyczne",
  "provider": {
    "@type": "Organization",
    "name": "Vologis Sp. z o.o.",
    "url": SITE,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Jarocin",
      "addressRegion": "Wielkopolska",
      "addressCountry": "PL",
    },
  },
  "areaServed": ["Polska", "Europa"],
  "serviceType": "Pośrednictwo logistyczne, magazynowanie i fulfillment",
  "description": "Vologis dobiera i weryfikuje operatorów magazynowych, partnerów fulfillment oraz przewoźników — dopasowanych do specyfiki ładunku i branży klienta, w tym chłodnie, ADR i farmacja.",
  "url": `${SITE}/pl/uslugi/posrednictwo-logistyczne/`,
};

const schemaWebPage = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Pośrednictwo logistyczne — magazyny, fulfillment, transport | Vologis",
  "description": "Vologis dobiera sprawdzonych operatorów magazynowych, partnerów fulfillment i przewoźników. Niezależne pośrednictwo logistyczne dla firm produkcyjnych, e-commerce i handlowych — w tym chłodnie, ADR i farmacja.",
  "url": `${SITE}/pl/uslugi/posrednictwo-logistyczne/`,
  "inLanguage": "pl-PL",
};

const schemaFaq = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((f) => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
};
---

<ServicePageLayout
  title="Pośrednictwo logistyczne — magazyny, fulfillment, transport | Vologis"
  description="Vologis dobiera sprawdzonych operatorów magazynowych, partnerów fulfillment i przewoźników. Niezależne pośrednictwo logistyczne dla firm produkcyjnych, e-commerce i handlowych — w tym chłodnie, ADR i farmacja."
  canonical="https://vologis.com/pl/uslugi/posrednictwo-logistyczne/"
  ogImage="/og/og-posrednictwo.png"
  heroImage="/services/posrednictwo-logistyczne.webp"
  eyebrow="Usługi logistyczne / Pośrednictwo logistyczne"
  h1="Pośrednictwo logistyczne — magazyn, fulfillment i transport od jednego partnera"
  lead="Vologis pomaga firmom znaleźć i zweryfikować przestrzeń magazynową, partnerów fulfillment oraz sprawdzonych przewoźników — bez angażowania własnego zespołu w miesiące researchu i negocjacji. Przejmujemy ciężar porównania ofert, weryfikacji operatorów i doboru rozwiązania dopasowanego do specyfiki ładunku, w tym dla wymagających branż jak chłodnie, ADR czy farmacja. Jesteśmy w 100% niezależni — nie reprezentujemy żadnego operatora, tylko Twój interes."
  trustItems={trustItems}
  ctaPrimaryLabel="Zapytaj o pośrednictwo logistyczne"
  ctaPrimaryHref="/pl/kontakt"
  ctaSecondaryLabel="Sprawdź, jak działamy"
  ctaSecondaryHref="/pl/proces"
  breadcrumbs={[{ name: "Pośrednictwo logistyczne" }]}
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaService)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaWebPage)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFaq)} />

  <!-- ─── 1. Problem ───────────────────────────────────────── -->
  <section class="ps-problem" aria-labelledby="h-problem">
    <div class="container">
      <div class="ps-problem__grid">
        <div class="ps-problem__copy">
          <h2 class="h2" id="h-problem">
            Znalezienie odpowiedniego magazynu lub partnera fulfillment to miesiące pracy — jeśli robisz to samodzielnie
          </h2>
          <p class="body">
            W wielu firmach wybór operatora logistycznego wygląda tak samo: kilka zapytań do znanych z rynku nazw, porównanie PDF-ów z ofertami, negocjacje prowadzone bez znajomości rynkowych stawek i standardów SLA. Na końcu decyzja oparta na tym, kto odpowiedział najszybciej — niekoniecznie na tym, kto jest najlepiej dopasowany.
          </p>
          <p class="body">
            Problem narasta, gdy ładunek ma specyficzne wymagania: chłodnia, ADR, farmacja, wysoka rotacja SKU, integracje z marketplace'ami. Liczba operatorów, którzy naprawdę spełniają te wymagania — a nie tylko deklarują — jest znacznie mniejsza niż wynikałoby z pierwszego przeglądu rynku.
          </p>
          <p class="body">
            Pośrednictwo logistyczne Vologis przejmuje cały ten ciężar. Nie tylko wskazujemy operatora — weryfikujemy go, negocjujemy warunki i koordynujemy uruchomienie współpracy, pozostając po Twojej stronie przez cały proces.
          </p>
        </div>
        <aside class="ps-brief" aria-label="W skrócie">
          <p class="ps-brief__label">W skrócie</p>
          <p class="ps-brief__text">
            Pośrednictwo logistyczne to usługa, w której Vologis dobiera i weryfikuje operatorów magazynowych, partnerów fulfillment oraz przewoźników — dopasowanych do specyfiki Twojego ładunku i branży. Przejmujemy research, porównanie ofert i negocjacje, pozostając w 100% niezależni. Obsługujemy też branże specjalistyczne: chłodnie, ADR, farmacja.
          </p>
          <hr class="ps-brief__rule" />
          <p class="ps-brief__sub">
            Vologis &middot; Jarocin, Polska &middot; Obsługa rynku PL i EU
          </p>
        </aside>
      </div>
    </div>
  </section>

  <!-- ─── 2. Dla kogo ───────────────────────────────────────── -->
  <section class="ps-forwho" aria-labelledby="h-forwho">
    <div class="container">
      <h2 class="h2 h2--center" id="h-forwho">Dla kogo jest pośrednictwo logistyczne?</h2>
      <p class="section-intro">
        Ta usługa jest dla firm, które potrzebują sprawnego doboru operatora lub przestrzeni magazynowej bez angażowania własnego zespołu w długotrwały research.
      </p>
      <div class="fw-grid">
        {forWhom.map((p) => (
          <div class="fw-card">
            <h3 class="fw-card__title">{p.title}</h3>
            <p class="fw-card__text">{p.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── 3. Co obejmuje ────────────────────────────────────── -->
  <section class="ps-scope" aria-labelledby="h-scope">
    <div class="container">
      <h2 class="h2" id="h-scope">Co obejmuje usługa pośrednictwa logistycznego?</h2>
      <p class="body">
        Zakres współpracy może obejmować dobór magazynu lub operatora fulfillment, stałą obsługę logistyczną albo szersze wsparcie — razem z organizacją transportu i koordynacją dostawców.
      </p>
      <div class="scope-grid">
        {scopeCards.map((c) => (
          <div class="scope-card">
            <h3 class="scope-card__title">{c.title}</h3>
