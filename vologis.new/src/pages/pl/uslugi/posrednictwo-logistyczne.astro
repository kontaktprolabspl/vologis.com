  },
];

const benefits = [
  {
    title: "Oszczędność miesięcy researchu",
    text: "Nie musisz samodzielnie przeszukiwać rynku, porównywać dziesiątek ofert i weryfikować operatorów. Przejmujemy cały ten ciężar.",
  },
  {
    title: "Niezależna ocena rynku",
    text: "Vologis nie jest powiązany z żadnym operatorem magazynowym ani fulfillment. Rekomendujemy wyłącznie to, co realnie pasuje do Twoich potrzeb i budżetu.",
  },
  {
    title: "Weryfikacja, nie tylko oferty",
