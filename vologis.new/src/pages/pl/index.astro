---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { localBusinessSchema, speakableSchema } from "../../utils/schema";
import Eyebrow from "../../components/Eyebrow.astro";
import HeroCTAs from "../../components/HeroCTAs.astro";

/* ── Data ────────────────────────────────────────────────── */

const problemCards = [
  {
    title: "Koszty transportu rosną, ale nikt nie wie dlaczego",
    text: "Brakuje jasnego obrazu stawek, tras, dostawców i realnych źródeł kosztu.",
  },
  {
    title: "Magazyn działa, ale coraz wolniej",
    text: "Procesy nie nadążają za sprzedażą, sezonowością lub zmianą skali.",
  },
  {
    title: "Dostawcy są rozproszeni i trudni do kontroli",
    text: "Firma ma coraz więcej partnerów, ale coraz mniej przejrzystości.",
  },
  {
    title: "Decyzje są podejmowane bez danych",
    text: "Raporty są niespójne, a operacje opierają się na intuicji zamiast faktach.",
  },
  {
    title: "Firma rośnie szybciej niż jej procesy",
    text: "To, co działało wcześniej, zaczyna generować opóźnienia, koszty i chaos.",
  },
];

const serviceCards = [
  {
    num: "01",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 15l4-5 3 3 5-7"/></svg>`,
    title: "Audyt i doradztwo logistyczne",
    desc: "Diagnozujemy koszty, procesy, dostawców i wąskie gardła operacyjne.",
    bullets: [
      "audyt kosztów transportu i magazynu",
      "analiza procesów i danych operacyjnych",
      "rekomendacje quick wins i plan zmian",
    ],
    effect: "Wiesz, gdzie uciekają pieniądze i co trzeba zmienić najpierw.",
    href: "/pl/uslugi/doradztwo-operacyjne",
  },
  {
    num: "02",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h11v9H3z"/><path d="M14 9h4l3 3v3h-7z"/><circle cx="7" cy="18" r="1.6"/><circle cx="17" cy="18" r="1.6"/></svg>`,
    title: "Transport i spedycja",
    desc: "Pomagamy uporządkować organizację transportu oraz współpracę z przewoźnikami i operatorami.",
    bullets: [
      "analiza stawek, tras i dostawców",
      "optymalizacja modelu transportowego",
      "wsparcie w negocjacjach i wyborze partnerów",
    ],
    effect: "Zyskujesz większą kontrolę nad kosztami, jakością i terminowością.",
    href: "/pl/uslugi/posrednictwo-logistyczne",
  },
  {
    num: "03",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="2.4"/><circle cx="5" cy="18" r="2.4"/><circle cx="19" cy="18" r="2.4"/><path d="M12 7.4v4M10.3 13.2 6.7 16M13.7 13.2 17.3 16"/></svg>`,
    title: "Zarządzanie łańcuchem dostaw",
    desc: "Projektujemy procesy i model operacyjny, który wspiera skalowanie firmy.",
    bullets: [
      "planowanie przepływu towarów",
      "zarządzanie dostawcami i ryzykiem",
      "monitoring efektywności operacji",
    ],
    effect: "Łańcuch dostaw przestaje być hamulcem, a zaczyna wspierać wzrost.",
    href: "/pl/uslugi",
  },
];

const processSteps = [
  {
    num: "01",
    title: "Diagnoza",
    desc: "Analizujemy koszty, procesy, dane, dostawców i największe źródła ryzyka.",
    output: "mapa problemów i szybkie rekomendacje",
  },
  {
    num: "02",
    title: "Analiza i projekt",
    desc: "Projektujemy docelowy model działania oraz priorytety zmian.",
    output: "plan działań, business case i harmonogram",
  },
  {
    num: "03",
    title: "Wdrożenie",
    desc: "Pomagamy przeprowadzić zmianę operacyjnie, nie tylko opisać ją w raporcie.",
    output: "nowe procesy, odpowiedzialności i kontrola wykonania",
  },
  {
    num: "04",
    title: "Monitoring",
    desc: "Mierzymy efekty, korygujemy działania i pilnujemy utrzymania wyniku.",
    output: "dashboard, cykl kontroli i dalsze rekomendacje",
  },
];

const caseScope = [
  "audyt kosztów transportu",
  "analiza dostawców",
  "mapa ryzyk operacyjnych",
  "rekomendacje i wsparcie wdrożenia",
];

const caseEffects = [
  "większa kontrola nad kosztami logistycznymi",
  "krótszy czas podejmowania decyzji",
  "uporządkowany model współpracy z dostawcami",
];

const audienceChips = [
  "Firmy produkcyjne",
  "E-commerce",
  "Dystrybutorzy",
  "Operatorzy TSL",
  "Retail i FMCG",
  "Firmy w ekspansji PL + EU",
];

const articles = [
  {
    date: "2026-06-18",
    label: "18 cze 2026",
    title: "AI i automatyzacja w logistyce — gdzie naprawdę warto inwestować, a gdzie to tylko moda",
    href: "/pl/wiedza/ai-automatyzacja-logistyka",
  },
  {
    date: "2026-06-18",
    label: "18 cze 2026",
    title: "Jak wybrać partnera logistycznego — i dlaczego najniższa cena prawie zawsze jest pułapką",
    href: "/pl/wiedza/wybor-partnera-logistycznego",
  },
  {
    date: "2026-06-12",
    label: "12 cze 2026",
    title: "Audyt logistyczny — jak obiektywnie sprawdzić, gdzie firma traci czas, pieniądze i efektywność",
    href: "/pl/wiedza/audyt-logistyczny",
  },
];

/* ── Schema ───────────────────────────────────────────────── */

/* LocalBusiness and Speakable use SITE config via schema utils */
const schemaLocalBusiness = localBusinessSchema();
const schemaSpeakable = speakableSchema("/pl/", [
  "[data-speakable='headline']",
  "[data-speakable='summary']",
]);
---

<BaseLayout
  title="Vologis — Doradztwo Logistyczne | Transport i Spedycja | SCM"
  description="Vologis: doradztwo logistyczne, transport i zarządzanie łańcuchem dostaw dla firm produkcyjnych i e-commerce. Diagnozujemy koszty, projektujemy rozwiązania i wspieramy wdrożenie zmian. Rynki PL i EU."
  preloadImage="/hero-bg.webp"
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaSpeakable)} />

  <!-- ══════════════════════════════════════════════════════
       1. HERO
       ══════════════════════════════════════════════════════ -->
  <section class="hero" aria-labelledby="hero-h1">
    <div class="container hero-grid">

      <div class="hero-copy">
        <Eyebrow text="DORADZTWO LOGISTYCZNE, END TO END" bg="light" />
        <h1 id="hero-h1" class="hero-h1" data-speakable="headline">
          Odzyskaj kontrolę<br>nad logistyką —<br>zanim zacznie zjadać marżę.
        </h1>
        <p class="hero-sub" data-speakable="summary">
          Doradztwo logistyczne, transport i zarządzanie łańcuchem dostaw
          dla firm produkcyjnych, e-commerce i TSL. Diagnozujemy koszty,
          projektujemy rozwiązania i wspieramy wdrożenie zmian.
        </p>
        <HeroCTAs
          bg="light"
          primaryHref="/pl/kontakt"
          primaryLabel="Umów konsultację"
          secondaryHref="/pl/proces"
          secondaryLabel="Zobacz jak pracujemy"
        />
        <p class="hero-microproof">
          Audyt, rekomendacje i wdrożenie — bez raportów do szuflady.
        </p>
      </div>


    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       2. STATS BAR
       ══════════════════════════════════════════════════════ -->
  <section class="stats-section" aria-label="Vologis w liczbach">
    <div class="container">
      <div class="stats-strip">
        <div class="stat-item">
          <span class="stat-number tnum">15+</span>
          <span class="stat-rule" aria-hidden="true"></span>
          <span class="stat-qualifier">lat doświadczenia w logistyce</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">Unia Europejska</span>
          <span class="stat-rule" aria-hidden="true"></span>
          <span class="stat-qualifier">zakres projektów i operacji</span>
        </div>
        <div class="stat-item">
          <span class="stat-number tnum">5</span>
          <span class="stat-rule" aria-hidden="true"></span>
          <span class="stat-qualifier">obszary: doradztwo, transport, supply chain, usługi dronowe, pośrednictwo sprzedaży</span>
        </div>
        <div class="stat-item">
          <span class="stat-number tnum">5–10</span>
          <span class="stat-rule" aria-hidden="true"></span>
          <span class="stat-qualifier">dni roboczych do pierwszej diagnozy</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       3. PROBLEM SECTION
       ══════════════════════════════════════════════════════ -->
  <section class="problem-section" aria-labelledby="problem-heading">
    <div class="container">
      <div class="section-head section-head--center">
        <h2 id="problem-heading" class="section-title">
          Logistyka rzadko psuje wynik nagle.<br>Zwykle robi to po cichu.
        </h2>
        <p class="section-intro">
          Rosnące koszty, opóźnienia, rozproszeni dostawcy i decyzje podejmowane bez danych
          stopniowo obniżają marżę i blokują wzrost firmy.
        </p>
      </div>
      <div class="problem-grid">
        {problemCards.map((c) => (
          <div class="problem-card">
            <h3 class="problem-card__title">{c.title}</h3>
            <p class="problem-card__text">{c.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       4. SERVICES
       ══════════════════════════════════════════════════════ -->
  <section class="services-section" aria-labelledby="services-heading">
    <div class="container">
      <div class="section-head section-head--center">
        <p class="eyebrow eyebrow--accent">Co robimy</p>
        <h2 id="services-heading" class="section-title">
          Trzy obszary, jeden cel:<br>mierzalna poprawa operacji.
        </h2>
        <p class="section-intro">
          Łączymy doradztwo, transport i zarządzanie łańcuchem dostaw, żeby znaleźć źródło problemu,
          zaprojektować rozwiązanie i dopilnować jego wdrożenia.
        </p>
      </div>
      <div class="services-grid">
        {serviceCards.map((s) => (
          <article class="svc-card">
            <div class="svc-card__top">
              <div class="svc-icon" aria-hidden="true" set:html={s.icon} />
              <span class="svc-num tnum" aria-hidden="true">{s.num}</span>
            </div>
            <h3 class="svc-title">{s.title}</h3>
            <p class="svc-desc">{s.desc}</p>
            <ul class="svc-bullets" role="list">
              {s.bullets.map((b) => (
                <li class="svc-bullet">
                  <svg class="svc-check" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m4 10.5 4 4 8-9" /></svg>
                  {b}
                </li>
              ))}
            </ul>
            <div class="svc-effect">
              <span class="svc-effect__label">Efekt</span>
              <p class="svc-effect__text">{s.effect}</p>
            </div>
            <a class="svc-link" href={s.href}>Zobacz zakres <span aria-hidden="true">→</span></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       5. PROCESS — dark navy
       ══════════════════════════════════════════════════════ -->
  <section class="process-section" aria-labelledby="process-heading">
    <div class="container">
      <div class="section-head section-head--center section-head--on-dark">
        <p class="eyebrow eyebrow--on-dark">Jak pracujemy</p>
        <h2 id="process-heading" class="section-title">Od diagnozy do mierzalnego efektu.</h2>
        <p class="section-intro">
          Każdy projekt zaczyna się od zrozumienia problemu — nie od gotowego rozwiązania.
        </p>
      </div>
      <div class="process-visual">
        <img
          src="/process-visual.webp"
          alt="Wizualna reprezentacja procesu Vologis: diagnoza, analiza, wdrożenie i monitoring operacji logistycznych"
          class="process-visual__img"
          width="1536"
          height="512"
          loading="lazy"
          decoding="async"
        />
      </div>

      <ol class="process-steps">
        {processSteps.map((step) => (
          <li class="process-step">
            <span class="step-num tnum" aria-hidden="true">{step.num}</span>
            <h3 class="step-title">{step.title}</h3>
            <p class="step-desc">{step.desc}</p>
            <p class="step-output">
              <span class="step-output__label">Output:</span>
              {step.output}
            </p>
          </li>
        ))}
      </ol>
      <div class="process-cta">
        <a href="/pl/proces" class="btn-outline btn-outline--on-dark">Pełny opis procesu →</a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       6. CASE / PROOF
       ══════════════════════════════════════════════════════ -->
  <section class="case-section" aria-labelledby="case-heading">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow eyebrow--accent">Dowód w praktyce</p>
          <h2 id="case-heading" class="section-title">Efekty, które można zmierzyć.</h2>
        </div>
      </div>
      <p class="case-intro">
        Nie kończymy pracy na rekomendacjach. Pomagamy przełożyć analizę na decyzje, wdrożenie i kontrolę efektu.
      </p>

      <div class="case-grid">
        <div class="case-card">
          <div class="case-card__header">
            <p class="case-card__type">Firma produkcyjna</p>
            <span class="case-badge">Case anonymized</span>
          </div>
          <h3 class="case-card__title">Reorganizacja łańcucha dostaw</h3>
          <div class="case-cols">
            <div>
              <p class="case-cols__label">Zakres</p>
              <ul class="case-list" role="list">
                {caseScope.map((item) => (
                  <li class="case-list__item">
                    <svg class="case-list__icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m4 10.5 4 4 8-9" /></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
            <div>
              <p class="case-cols__label">Efekt</p>
              <ul class="case-list" role="list">
                {caseEffects.map((item) => (
                  <li class="case-list__item">
                    <svg class="case-list__icon case-list__icon--blue" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m4 10.5 4 4 8-9" /></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>

        <figure class="testimonial">
          <svg class="testimonial__mark" viewBox="0 0 40 32" fill="currentColor" aria-hidden="true">
            <path d="M0 32V19.2C0 8.32 6.4 2.133 19.2 0l2.4 3.733C14.4 5.333 10.4 9.067 9.6 14.4H16V32H0Zm24 0V19.2C24 8.32 30.4 2.133 43.2 0l2.4 3.733C38.4 5.333 34.4 9.067 33.6 14.4H40V32H24Z"/>
          </svg>
          <blockquote class="testimonial__text">
            Vologis przeprowadził nas od diagnozy przez konkretne rekomendacje aż po wdrożenie.
            Terminy dotrzymane, koszty pod kontrolą.
          </blockquote>
          <figcaption class="testimonial__attr">
            <span class="testimonial__role">Dyrektor Operacyjny, firma produkcyjna</span>
            <span class="testimonial__note">— do uzupełnienia danymi klienta</span>
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       7. FOR WHOM
       ══════════════════════════════════════════════════════ -->
  <section class="audience-section" aria-labelledby="audience-heading">
    <div class="container">
      <div class="section-head section-head--center">
        <p class="eyebrow eyebrow--accent">Dla kogo</p>
        <h2 id="audience-heading" class="section-title">
          Dla firm, w których logistyka<br>ma bezpośredni wpływ na wynik.
        </h2>
        <p class="section-intro">
          Pracujemy z organizacjami, które chcą uporządkować operacje, obniżyć koszty
          i podejmować decyzje na podstawie danych.
        </p>
      </div>
      <div class="audience-chips" role="list" aria-label="Grupy docelowe">
        {audienceChips.map((chip) => (
          <span class="audience-chip" role="listitem">{chip}</span>
        ))}
      </div>
      <p class="audience-note">
        Największą wartość wnosimy tam, gdzie skala wzrostu zaczyna ujawniać problemy
        w kosztach, procesach i dostawcach.
      </p>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       8. ARTICLES — Wiedza z praktyki
       ══════════════════════════════════════════════════════ -->
  <section class="knowledge-section" aria-labelledby="knowledge-heading">
    <div class="container">
      <div class="knowledge-header">
        <div>
          <p class="eyebrow eyebrow--accent">Wiedza z praktyki</p>
          <h2 id="knowledge-heading" class="section-title">Analizy i komentarze.</h2>
          <p class="knowledge-sub">
            Analizy, case studies i komentarze o logistyce, kosztach, transporcie i łańcuchu dostaw.
          </p>
        </div>
        <a href="/pl/wiedza" class="btn-outline">Wszystkie artykuły →</a>
      </div>
      <ol class="article-list" role="list">
        {articles.map((art) => (
          <li class="article-item">
            <time class="article-date" datetime={art.date}>{art.label}</time>
            <a href={art.href} class="article-title">{art.title}</a>
            <span class="article-read" aria-hidden="true">Czytaj →</span>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       9. LINKEDIN
       ══════════════════════════════════════════════════════ -->
  <section class="linkedin-section" aria-label="Aktywność na LinkedIn">
    <div class="container">
      <div class="linkedin-head">
        <div class="linkedin-copy">
          <p class="eyebrow eyebrow--accent">LinkedIn</p>
          <h2 class="linkedin-title">Śledź nas na LinkedIn.</h2>
          <p class="linkedin-sub">
            Analizy rynku TSL, case studies, aktualizacje regulacyjne i praktyczne wnioski z projektów.
          </p>
        </div>
        <a
          href="https://www.linkedin.com/company/vologis"
          class="btn-outline"
          target="_blank"
          rel="noopener noreferrer"
        >
          Obserwuj Vologis →
        </a>
      </div>
      <div class="linkedin-widget" id="linkedin-widget-container">
        <div class="sk-ww-linkedin-profile-post" data-embed-id="25688916"></div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       10. FINAL CTA
       ══════════════════════════════════════════════════════ -->
  <section class="cta-section" aria-labelledby="cta-heading">
    <div class="container">
      <div class="cta-inner">

        <div class="cta-copy">
          <p class="eyebrow eyebrow--on-dark">Bezpłatna konsultacja</p>
          <h2 id="cta-heading" class="cta-title">Zacznij od diagnozy,<br>nie od zgadywania.</h2>
          <p class="cta-sub">
            W 30 minut ocenimy, gdzie logistyka generuje największe koszty, ryzyka lub blokady
            wzrostu — i jakie działania warto podjąć najpierw.
          </p>
          <button
            class="btn-accent"
            data-calendly="popup"
            type="button"
          >
            Umów bezpłatną konsultację
          </button>
        </div>

        <div class="cta-form">
          <p class="cta-form-label">Wolisz napisać? Zostaw kontakt.</p>
          <form
            class="contact-form"
            action="/pl/kontakt"
            method="get"
            aria-label="Szybki formularz kontaktowy"
          >
            <input
              type="text"
              name="name"
              placeholder="Imię i nazwisko"
              class="form-input"
              aria-label="Imię i nazwisko"
            />
            <input
              type="email"
              name="email"
              placeholder="Adres e-mail"
              class="form-input"
              aria-label="Adres e-mail"
              required
            />
            <textarea
              name="message"
              placeholder="Największe wyzwanie logistyczne w Twojej firmie"
              class="form-input form-textarea"
              aria-label="Wiadomość"
              rows="3"
            ></textarea>
            <button type="submit" class="form-submit">Wyślij zapytanie →</button>
          </form>
          <p class="form-note">Odpowiemy z konkretną propozycją kolejnego kroku.</p>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Shared ──────────────────────────────────────────────── */
  section { padding-block: var(--space-3xl); }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: var(--space-md);
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .eyebrow::before {
    content: "";
    width: 1.5rem;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .eyebrow--accent { color: oklch(50% 0.210 22); } /* darkened for 4.5:1 contrast on light bg */
  .eyebrow--on-dark { color: var(--color-blue-on-dark); }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-display-s);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--color-ink);
    margin-bottom: var(--space-md);
  }

  .section-intro {
    font-size: var(--text-base);
    color: var(--color-muted);
    max-width: 58ch;
    line-height: 1.65;
  }

  .section-head { margin-bottom: var(--space-2xl); }

  .section-head--center {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .section-head--center .eyebrow::before { display: none; }
  .section-head--center .section-intro { margin-inline: auto; }
  .section-head--on-dark .section-title { color: var(--color-ink-on-dark); }
  .section-head--on-dark .section-intro { color: var(--color-muted-on-dark); }

  /* ── Buttons ─────────────────────────────────────────────── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-ink-on-dark);
    background: var(--color-ink);
    border: none;
    border-radius: var(--radius-pill);
    padding: var(--space-sm) var(--space-xl);
    white-space: nowrap;
    cursor: pointer;
    text-decoration: none;
    box-shadow: var(--shadow-sm);
    transition: background var(--dur-micro) var(--ease-out), transform var(--dur-micro) var(--ease-out);
  }

  .btn-primary:hover { background: var(--color-accent); transform: translateY(-1px); }
  .btn-primary:active { transform: translateY(0); }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-ink);
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: 2px;
    white-space: nowrap;
    transition: color var(--dur-micro) var(--ease-out), border-color var(--dur-micro) var(--ease-out);
  }

  .btn-secondary:hover { color: var(--color-accent); border-color: var(--color-accent); }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-ink);
    border: 1px solid var(--color-ink);
    border-radius: var(--radius-pill);
    padding: var(--space-xs) var(--space-lg);
    white-space: nowrap;
    text-decoration: none;
    transition: background var(--dur-micro) var(--ease-out), color var(--dur-micro) var(--ease-out);
  }

  .btn-outline:hover { background: var(--color-ink); color: var(--color-ink-on-dark); }

  .btn-outline--on-dark {
    color: var(--color-ink-on-dark);
    border-color: var(--color-glass-border);
  }

  .btn-outline--on-dark:hover { background: var(--color-ink-on-dark); color: var(--color-ink); }

  .btn-accent {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 700;
    color: #fff;
    background: var(--color-accent);
    border: none;
    border-radius: var(--radius-pill);
    padding: var(--space-sm) var(--space-xl);
    white-space: nowrap;
    cursor: pointer;
    text-decoration: none;
    box-shadow: 0 8px 24px oklch(61.2% 0.208 22 / 0.32);
    transition: background var(--dur-micro) var(--ease-out), transform var(--dur-micro) var(--ease-out);
  }

  .btn-accent:hover { background: var(--color-accent-hover); transform: translateY(-1px); }
  .btn-accent:active { transform: translateY(0); }

  /* ── 1. Hero ─────────────────────────────────────────────── */
  .hero {
    padding-top: calc(var(--space-3xl) + 5rem);
    padding-bottom: var(--space-3xl);
    position: relative;
    overflow: hidden;
    background-image: url('/hero-bg.webp');
    background-size: cover;
    background-position: center right;
    background-repeat: no-repeat;
  }

  /* Overlay: fully opaque left (text zone) → transparent right (image zone) */
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      oklch(97.5% 0.018 138 / 1.00)  0%,
      oklch(97.5% 0.018 138 / 1.00) 30%,
      oklch(97.5% 0.018 138 / 0.90) 50%,
      oklch(97.5% 0.018 138 / 0.28) 70%,
      oklch(97.5% 0.018 138 / 0.00) 100%
    );
    pointer-events: none;
  }

  .hero > * { position: relative; }

  /* hero-grid is just a passthrough container now */

  .hero-copy {
    max-width: 42rem;
  }

  .hero-h1 {
    font-size: clamp(2.5rem, 4vw + 1rem, 4.5rem);
    letter-spacing: -0.035em;
    line-height: 1.06;
    color: var(--color-ink);
    margin-bottom: var(--space-lg);
  }

  .hero-sub {
    font-size: var(--text-md);
    color: var(--color-muted);
    max-width: 54ch;
    line-height: 1.6;
    margin-bottom: var(--space-xl);
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
    margin-bottom: var(--space-md);
  }

  .hero-microproof {
    font-size: var(--text-sm);
    color: var(--color-neutral);
    font-style: italic;
  }


  /* ── 2. Stats ────────────────────────────────────────────── */
  .stats-section {
    padding-block: var(--space-xl);
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    background: var(--color-paper-2);
  }

  .stats-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-xl);
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding-left: var(--space-lg);
    border-left: 2px solid var(--color-rule);
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    line-height: 1;
  }

  .stat-rule { display: none; }

  .stat-qualifier {
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: 1.4;
  }

  /* ── 3. Problem ──────────────────────────────────────────── */
  .problem-section { background: var(--color-paper); }

  .problem-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .problem-card {
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    background: var(--color-paper);
    transition: border-color var(--dur-micro) var(--ease-out);
  }

  .problem-card:hover { border-color: var(--color-blue); }

  .problem-card__title {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-ink);
    margin-bottom: var(--space-sm);
    line-height: 1.3;
  }

  .problem-card__text {
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: 1.6;
  }

  /* ── 4. Services ─────────────────────────────────────────── */
  .services-section { background: var(--color-paper-2); }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .svc-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    border: 1px solid var(--color-rule);
    border-top: 3px solid var(--color-secondary);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    background: var(--color-paper);
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--dur-short) var(--ease-out), transform var(--dur-short) var(--ease-out);
  }

  .svc-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-4px); }

  .svc-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .svc-icon {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-md);
    background: var(--color-blue-tint);
    color: var(--color-secondary);
  }

  .svc-icon :global(svg) { width: 1.5rem; height: 1.5rem; }

  .svc-num {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-neutral);
    font-weight: 500;
    letter-spacing: 0.08em;
  }

  .svc-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    line-height: 1.2;
  }

  .svc-desc {
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: 1.6;
  }

  .svc-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .svc-bullet {
    display: flex;
    align-items: flex-start;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    color: var(--color-ink);
    line-height: 1.5;
  }

  .svc-check {
    flex-shrink: 0;
    width: 1.1rem;
    height: 1.1rem;
    margin-top: 0.15rem;
    color: var(--color-blue);
  }

  .svc-effect {
    margin-top: auto;
    background: var(--color-paper-2);
    border-radius: var(--radius-sm);
    padding: var(--space-md);
    border-left: 3px solid var(--color-secondary);
  }

  .svc-effect__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-neutral);
    display: block;
    margin-bottom: 4px;
  }

  .svc-effect__text {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-ink);
    line-height: 1.4;
  }

  .svc-link {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    color: oklch(40% 0.085 238); /* darkened for 4.5:1 contrast on --color-paper-2 bg */
    text-decoration: none;
    align-self: flex-start;
    transition: color var(--dur-micro) var(--ease-out);
  }

  .svc-link:hover { color: var(--color-ink); }
  .svc-link span { transition: transform var(--dur-short) var(--ease-out); display: inline-block; }
  .svc-link:hover span { transform: translateX(4px); }

  /* ── 5. Process ──────────────────────────────────────────── */
  .process-section {
    background: var(--color-paper-dark);
    color: var(--color-ink-on-dark);
  }

  /* Process visual strip */
  .process-visual {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-glass-border);
    margin-bottom: var(--space-2xl);
    box-shadow: var(--shadow-lg);
  }

  .process-visual__img {
    display: block;
    width: 100%;
    height: clamp(180px, 22vw, 320px);
    object-fit: cover;
    object-position: center center;
  }

  .process-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
    list-style: none;
    margin-bottom: var(--space-2xl);
  }

  .process-step {
    border-top: 1px solid var(--color-glass-border);
    padding-top: var(--space-lg);
  }

  .step-num {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.04em;
    color: oklch(85.4% 0.052 199 / 0.35);
    margin-bottom: var(--space-sm);
  }

  .step-title {
    font-family: var(--font-display);
    font-size: var(--text-md);
    font-weight: 700;
    color: var(--color-ink-on-dark);
    margin-bottom: var(--space-sm);
    letter-spacing: -0.015em;
    line-height: 1.2;
  }

  .step-desc {
    font-size: var(--text-sm);
    color: var(--color-muted-on-dark);
    line-height: 1.6;
    margin-bottom: var(--space-md);
  }

  .step-output {
    font-size: var(--text-sm);
    color: var(--color-blue-on-dark);
    line-height: 1.5;
  }

  .step-output__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 2px;
    opacity: 0.7;
  }

  .process-cta { text-align: center; }

  /* ── 6. Case ─────────────────────────────────────────────── */
  .case-section { background: var(--color-paper); }

  .case-intro {
    font-size: var(--text-md);
    color: var(--color-muted);
    line-height: 1.65;
    max-width: 60ch;
    margin-bottom: var(--space-2xl);
    margin-top: calc(-1 * var(--space-lg));
  }

  .case-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .case-card {
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    background: var(--color-paper);
    box-shadow: var(--shadow-sm);
  }

  .case-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .case-card__type {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-secondary);
  }

  .case-badge {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.04em;
    padding: 2px var(--space-sm);
    border-radius: var(--radius-pill);
    border: 1px dashed var(--color-neutral);
    color: var(--color-neutral);
    flex-shrink: 0;
  }

  .case-card__title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-ink);
    margin-bottom: var(--space-lg);
    letter-spacing: -0.02em;
  }

  .case-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }

  .case-cols__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-neutral);
    margin-bottom: var(--space-sm);
  }

  .case-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .case-list__item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    color: var(--color-ink);
    line-height: 1.5;
  }

  .case-list__icon {
    flex-shrink: 0;
    width: 1rem;
    height: 1rem;
    margin-top: 0.2rem;
    color: var(--color-neutral);
  }

  .case-list__icon--blue { color: var(--color-blue); }

  .testimonial {
    background: var(--color-paper-dark);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    margin: 0;
  }

  .testimonial__mark {
    width: 2rem;
    height: auto;
    color: var(--color-blue-on-dark);
    opacity: 0.5;
    flex-shrink: 0;
  }

  .testimonial__text {
    font-size: var(--text-md);
    color: var(--color-ink-on-dark);
    line-height: 1.65;
    font-style: normal;
  }

  .testimonial__attr {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .testimonial__role {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-muted-on-dark);
  }

  .testimonial__note {
    font-size: var(--text-xs);
    color: var(--color-neutral);
    font-family: var(--font-mono);
  }

  /* ── 7. For whom ─────────────────────────────────────────── */
  .audience-section { background: var(--color-paper-2); }

  .audience-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-xl);
    justify-content: center;
  }

  .audience-chip {
    display: inline-flex;
    align-items: center;
    padding: var(--space-sm) var(--space-lg);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-pill);
    background: var(--color-paper);
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-ink);
    box-shadow: var(--shadow-sm);
    transition: border-color var(--dur-micro) var(--ease-out), box-shadow var(--dur-short) var(--ease-out);
  }

  .audience-chip:hover {
    border-color: var(--color-blue);
    box-shadow: var(--shadow-md);
  }

  .audience-note {
    text-align: center;
    font-size: var(--text-base);
    color: var(--color-muted);
    max-width: 60ch;
    margin-inline: auto;
    line-height: 1.65;
  }

  /* ── 8. Articles ─────────────────────────────────────────── */
  .knowledge-section { background: var(--color-paper); }

  .knowledge-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-lg);
    flex-wrap: wrap;
    margin-bottom: var(--space-2xl);
  }

  .knowledge-sub {
    font-size: var(--text-base);
    color: var(--color-muted);
    line-height: 1.6;
    max-width: 52ch;
    margin-top: var(--space-xs);
  }

  .article-list {
    list-style: none;
    border-top: 1px solid var(--color-rule);
  }

  .article-item {
    display: grid;
    grid-template-columns: 8rem 1fr auto;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-lg) 0;
    border-bottom: 1px solid var(--color-rule);
    transition: background var(--dur-micro) var(--ease-out);
  }

  .article-date {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-neutral);
    white-space: nowrap;
  }

  .article-title {
    font-family: var(--font-display);
    font-size: var(--text-md);
    font-weight: 600;
    color: var(--color-ink);
    text-decoration: none;
    line-height: 1.3;
    transition: color var(--dur-micro) var(--ease-out);
  }

  .article-title:hover { color: var(--color-secondary); }

  .article-read {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-neutral);
    white-space: nowrap;
  }

  /* ── 9. LinkedIn ─────────────────────────────────────────── */
  .linkedin-section {
    background: var(--color-paper-2);
    border-top: 1px solid var(--color-rule);
  }

  .linkedin-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-xl);
    flex-wrap: wrap;
    margin-bottom: var(--space-xl);
  }

  .linkedin-title {
    font-family: var(--font-display);
    font-size: var(--text-display-s);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin-bottom: var(--space-md);
  }

  .linkedin-sub {
    font-size: var(--text-base);
    color: var(--color-muted);
    max-width: 48ch;
    line-height: 1.6;
  }

  .linkedin-widget { width: 100%; min-width: 0; }

  /* ── 10. Final CTA ───────────────────────────────────────── */
  .cta-section {
    background: var(--gradient-cta);
    position: relative;
    overflow: hidden;
  }

  .cta-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .cta-title {
    font-family: var(--font-display);
    font-size: var(--text-display-s);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.08;
    color: var(--color-ink-on-dark);
    margin-bottom: var(--space-md);
  }

  .cta-sub {
    font-size: var(--text-base);
    color: var(--color-muted-on-dark);
    max-width: 44ch;
    line-height: 1.65;
    margin-bottom: var(--space-xl);
  }

  .cta-form {
    background: oklch(100% 0 0 / 0.06);
    border: 1px solid var(--color-glass-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
  }

  .cta-form-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-blue-on-dark);
    margin-bottom: var(--space-lg);
    display: block;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .form-input {
    width: 100%;
    padding: var(--space-sm) var(--space-md);
    background: oklch(26% 0.060 257 / 0.5);
    border: 1px solid var(--color-glass-border);
    border-radius: var(--radius-sm);
    color: var(--color-ink-on-dark);
    font-family: var(--font-body);
    font-size: var(--text-base);
    outline: none;
    transition: border-color var(--dur-micro) var(--ease-out);
  }

  .form-input::placeholder { color: oklch(80% 0.035 205 / 0.6); }
  .form-input:focus { border-color: var(--color-blue-on-dark); }

  .form-textarea { resize: vertical; min-height: 80px; line-height: 1.5; }

  .form-submit {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-ink-on-dark);
    background: var(--color-accent);
    border: none;
    border-radius: var(--radius-sm);
    padding: var(--space-sm) var(--space-xl);
    cursor: pointer;
    align-self: flex-start;
    box-shadow: 0 6px 20px oklch(61.2% 0.208 22 / 0.35);
    transition: background var(--dur-micro) var(--ease-out), transform var(--dur-micro) var(--ease-out);
  }

  .form-submit:hover { background: var(--color-accent-hover); transform: translateY(-1px); }
  .form-submit:active { transform: translateY(0); }

  .form-note {
    font-size: var(--text-xs);
    color: var(--color-muted-on-dark);
    margin-top: var(--space-sm);
    opacity: 0.8;
  }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 64rem) {
    .stats-strip { grid-template-columns: repeat(2, 1fr); }
    .problem-grid { grid-template-columns: repeat(2, 1fr); }
    .process-steps { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 60rem) {
    .services-grid { grid-template-columns: 1fr; }
    .case-grid { grid-template-columns: 1fr; }
    .cta-inner { grid-template-columns: 1fr; }
    .linkedin-head { flex-direction: column; align-items: flex-start; }
  }

  @media (max-width: 48rem) {
    .hero-h1 { font-size: clamp(2rem, 6vw + 0.5rem, 3rem); }
    .stats-strip { grid-template-columns: 1fr 1fr; gap: var(--space-lg); }
    .problem-grid { grid-template-columns: 1fr; }
    .process-steps { grid-template-columns: 1fr; }
    .case-cols { grid-template-columns: 1fr; }
    .article-item { grid-template-columns: 6rem 1fr; }
    .article-read { display: none; }
    .hero-actions { flex-direction: column; align-items: flex-start; }
  }

  @media (max-width: 36rem) {
    .stats-strip { grid-template-columns: 1fr; }
    .knowledge-header { flex-direction: column; align-items: flex-start; }
  }

  /* ── Transparent header over hero ───────────────────────── */
  :global(.hd.hd--at-top) {
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-bottom-color: transparent;
  }
</style>

<script>
  // Transparent header at top of homepage, solid glass after scrolling
  const hd = document.querySelector('.hd') as HTMLElement | null;
  if (hd) {
    const THRESHOLD = 60;
    const update = () => hd.classList.toggle('hd--at-top', window.scrollY < THRESHOLD);
    window.addEventListener('scroll', update, { passive: true });
    update();
  }

  // Load LinkedIn widget only when section scrolls into viewport
  const linkedinContainer = document.getElementById('linkedin-widget-container');
  if (linkedinContainer && 'IntersectionObserver' in window) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          observer.disconnect();
          const script = document.createElement('script');
          script.src = 'https://widgets.sociablekit.com/linkedin-profile-posts/widget.js';
          script.defer = true;
          document.body.appendChild(script);
        }
      });
    }, { rootMargin: '300px' });
    observer.observe(linkedinContainer);
  }
</script>
