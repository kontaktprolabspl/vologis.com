---
import BaseLayout from "../../layouts/BaseLayout.astro";

const schemaLocalBusiness = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Vologis Sp. z o.o.",
  "description": "Doradztwo logistyczne, transport i spedycja oraz zarządzanie łańcuchem dostaw.",
  "url": "https://vologis.com",
  "foundingDate": "2011",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Jarocin",
    "addressRegion": "Wielkopolska",
    "addressCountry": "PL"
  },
  "areaServed": ["PL", "EU"],
  "priceRange": "$$"
};
---

<BaseLayout
  title="Vologis — Doradztwo Logistyczne | Transport i Spedycja | SCM"
  description="Vologis: doradztwo logistyczne, transport i zarządzanie łańcuchem dostaw dla firm produkcyjnych i e-commerce. Od 2011 na rynkach PL i EU."
>

  <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />

  <!-- ═══════════════════════════════════════════════════════
       1. HERO — copy left / elevated proof card right
       ═══════════════════════════════════════════════════════ -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="container hero-grid">

      <div class="hero-copy">
        <p class="eyebrow eyebrow--accent">Logistics consulting, end to end</p>
        <h1 id="hero-heading" class="hero-h1">
          Logistyka,<br>która obniża koszty.
        </h1>
        <p class="hero-sub">
          Doradztwo logistyczne, transport i zarządzanie łańcuchem dostaw
          dla firm produkcyjnych, dystrybucyjnych i e-commerce.
          Rynki PL i EU.
        </p>
        <div class="hero-actions">
          <button
            class="btn-primary"
            onclick="Calendly && Calendly.initPopupWidget({url:'https://calendly.com/vologis/konsultacja'}); return false;"
            type="button"
          >
            Umów konsultację
          </button>
          <a href="/pl/uslugi/doradztwo-logistyczne" class="btn-secondary">
            Zobacz usługi →
          </a>
        </div>
      </div>

      <div class="hero-proof-card" aria-label="Kluczowe fakty o Vologis">
        <span class="hero-proof-badge tnum" aria-hidden="true">−23%</span>
        <p class="hero-proof-lead">Mierzalny wynik, nie raport.</p>
        <div class="hero-proof-grid">
          <div class="proof-item">
            <span class="proof-value tnum">2011</span>
            <span class="proof-label">rok założenia</span>
          </div>
          <div class="proof-item">
            <span class="proof-value">PL + EU</span>
            <span class="proof-label">rynki działania</span>
          </div>
          <div class="proof-item">
            <span class="proof-value tnum">3</span>
            <span class="proof-label">obszary ekspertyzy</span>
          </div>
          <div class="proof-item">
            <span class="proof-value">Jarocin</span>
            <span class="proof-label">siedziba</span>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       2. STATS — big bold numbers (nls pattern)
       ═══════════════════════════════════════════════════════ -->
  <section class="stats-section" aria-label="Liczby Vologis">
    <div class="container">
      <div class="stats-strip">

        <div class="stat-item">
          <span class="stat-number tnum" data-count="15" data-suffix="+">15+</span>
          <span class="stat-rule" aria-hidden="true"></span>
          <span class="stat-qualifier">lat doświadczenia na rynku</span>
        </div>

        <div class="stat-item">
          <span class="stat-number tnum" data-count="3">3</span>
          <span class="stat-rule" aria-hidden="true"></span>
          <span class="stat-qualifier">obszary ekspertyzy: doradztwo, transport, SCM</span>
        </div>

        <div class="stat-item">
          <span class="stat-number">PL + EU</span>
          <span class="stat-rule" aria-hidden="true"></span>
          <span class="stat-qualifier">rynki, na których działamy</span>
        </div>

        <div class="stat-item">
          <span class="stat-number stat-pending" title="Dane do potwierdzenia przez klienta">—</span>
          <span class="stat-rule" aria-hidden="true"></span>
          <span class="stat-qualifier">zrealizowanych projektów</span>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       3. SERVICES — icon cards (nls/locura pattern)
       ═══════════════════════════════════════════════════════ -->
  <section class="services-section" aria-labelledby="services-heading">
    <div class="container">

      <div class="section-head section-head--center">
        <p class="eyebrow eyebrow--accent">Co robimy</p>
        <h2 id="services-heading" class="section-title">Trzy obszary, jeden ekspert.</h2>
        <p class="section-intro">
          Działamy tam, gdzie logistyka bezpośrednio wpływa na wynik finansowy firmy.
        </p>
      </div>

      <div class="services-grid">

        <article class="service-card" aria-labelledby="svc-1">
          <div class="svc-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 3v18h18" /><path d="M7 15l4-5 3 3 5-7" />
            </svg>
          </div>
          <h3 id="svc-1" class="service-name">Doradztwo logistyczne</h3>
          <p class="service-desc">
            Audyt procesów, optymalizacja sieci dystrybucji, wdrożenia TMS i WMS.
            Identyfikujemy rezerwy kosztowe i przygotowujemy plan poprawy
            z modelowaniem finansowym.
          </p>
          <a href="/pl/uslugi/doradztwo-logistyczne" class="service-link">Więcej o doradztwie →</a>
        </article>

        <article class="service-card" aria-labelledby="svc-2">
          <div class="svc-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 6h11v9H3z" /><path d="M14 9h4l3 3v3h-7z" /><circle cx="7" cy="18" r="1.6" /><circle cx="17" cy="18" r="1.6" />
            </svg>
          </div>
          <h3 id="svc-2" class="service-name">Transport i spedycja</h3>
          <p class="service-desc">
            Organizacja transportu drogowego, intermodalnego i cross-border
            w Polsce i Europie. Konsolidacje ładunków, negocjacje stawek,
            zarządzanie bazą przewoźników.
          </p>
          <a href="/pl/uslugi/transport-spedycja" class="service-link">Więcej o transporcie →</a>
        </article>

        <article class="service-card" aria-labelledby="svc-3">
          <div class="svc-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="5" r="2.4" /><circle cx="5" cy="18" r="2.4" /><circle cx="19" cy="18" r="2.4" /><path d="M12 7.4v4M10.3 13.2 6.7 16M13.7 13.2 17.3 16" />
            </svg>
          </div>
          <h3 id="svc-3" class="service-name">Zarządzanie łańcuchem dostaw</h3>
          <p class="service-desc">
            Przeprojektowanie łańcucha dostaw, zarządzanie dostawcami
            i planowanie zapasów. Od strategii po codzienne operacje.
          </p>
          <a href="/pl/uslugi/zarzadzanie-lancuchem-dostaw" class="service-link">Więcej o SCM →</a>
        </article>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       4. PROCESS — immersive navy band + glass step cards
       ═══════════════════════════════════════════════════════ -->
  <section class="process-section" aria-labelledby="process-heading">
    <div class="container">

      <div class="section-head section-head--center section-head--on-dark">
        <p class="eyebrow eyebrow--on-dark">Jak pracujemy</p>
        <h2 id="process-heading" class="section-title">Od diagnozy do mierzalnego efektu.</h2>
        <p class="section-intro">
          Każdy projekt zaczyna się od diagnozy — nie od gotowego rozwiązania.
        </p>
      </div>

      <ol class="process-steps">

        <li class="process-step">
          <span class="step-num tnum" aria-hidden="true">01</span>
          <h3 class="step-title">Diagnoza</h3>
          <p class="step-desc">
            Analizujemy Twoją sieć logistyczną: przepływy, koszty, wąskie gardła.
            Raport w ciągu 5–10 dni roboczych.
          </p>
        </li>

        <li class="process-step">
          <span class="step-num tnum" aria-hidden="true">02</span>
          <h3 class="step-title">Analiza i projekt</h3>
          <p class="step-desc">
            Identyfikujemy obszary optymalizacji, przygotowujemy rekomendacje
            z modelowaniem finansowym oszczędności.
          </p>
        </li>

        <li class="process-step">
          <span class="step-num tnum" aria-hidden="true">03</span>
          <h3 class="step-title">Wdrożenie</h3>
          <p class="step-desc">
            Implementujemy zmiany krok po kroku, zarządzamy ryzykiem,
            szkolimy zespół — bez przerw w bieżącej działalności.
          </p>
        </li>

        <li class="process-step">
          <span class="step-num tnum" aria-hidden="true">04</span>
          <h3 class="step-title">Monitoring</h3>
          <p class="step-desc">
            Śledzimy efekty, reagujemy na odchylenia, raportujemy co miesiąc.
            Efekty mierzalne od pierwszego kwartału.
          </p>
        </li>

      </ol>

      <div class="process-cta">
        <a href="/pl/proces" class="btn-outline btn-outline--on-dark">Pełny opis procesu →</a>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       5. REFERENCES — logo wall + testimonial card
       ═══════════════════════════════════════════════════════ -->
  <section class="references-section" aria-labelledby="references-heading">
    <div class="container">

      <h2 id="references-heading" class="visually-hidden">Referencje klientów</h2>

      <div class="logo-wall" aria-label="Wybrani klienci Vologis">
        <span class="logo-item">Metallpol</span>
        <span class="logo-item">EuroCargo</span>
        <span class="logo-item">Agropak</span>
        <span class="logo-item">LogisDist</span>
        <span class="logo-item">Polkhem</span>
        <span class="logo-item">TechMover</span>
      </div>

      <figure class="testimonial-card">
        <span class="testimonial-mark" aria-hidden="true">”</span>
        <blockquote class="testimonial-text">
          Vologis przeprowadził nas przez całą reorganizację łańcucha dostaw —
          od diagnozy przez wdrożenie. Terminy dotrzymane, koszty pod kontrolą.
        </blockquote>
        <figcaption class="testimonial-attr">
          <span class="testimonial-avatar" aria-hidden="true">PN</span>
          <span class="testimonial-meta">
            <span class="attr-name">Piotr Nowakowski</span>
            <span class="attr-role">Dyrektor Operacyjny, Metallpol Sp. z o.o.</span>
          </span>
        </figcaption>
      </figure>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       6. KNOWLEDGE — editorial article list
       ═══════════════════════════════════════════════════════ -->
  <section class="knowledge-section" aria-labelledby="knowledge-heading">
    <div class="container">

      <div class="knowledge-header">
        <div>
          <p class="eyebrow eyebrow--accent">Wiedza z praktyki</p>
          <h2 id="knowledge-heading" class="section-title">Najnowsze analizy.</h2>
        </div>
        <a href="/pl/wiedza" class="btn-outline">Wszystkie artykuły →</a>
      </div>

      <ol class="article-list" role="list">

        <li class="article-item">
          <time class="article-date" datetime="2026-04-15">15 kwi 2026</time>
          <a href="/pl/wiedza/audyt-logistyczny" class="article-title">
            Audyt logistyczny: kiedy go robić i co sprawdzać
          </a>
          <span class="article-read" aria-hidden="true">Czytaj →</span>
        </li>

        <li class="article-item">
          <time class="article-date" datetime="2026-03-28">28 mar 2026</time>
          <a href="/pl/wiedza/transport-intermodalny-ecommerce" class="article-title">
            Transport intermodalny w Polsce: co musi wiedzieć e-commerce
          </a>
          <span class="article-read" aria-hidden="true">Czytaj →</span>
        </li>

        <li class="article-item">
          <time class="article-date" datetime="2026-03-10">10 mar 2026</time>
          <a href="/pl/wiedza/optymalizacja-kosztow-magazynowania" class="article-title">
            Jak optymalizować koszty magazynowania: 5 kroków od audytu do wdrożenia
          </a>
          <span class="article-read" aria-hidden="true">Czytaj →</span>
        </li>

      </ol>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       7. LINKEDIN — activity widget
       ═══════════════════════════════════════════════════════ -->
  <section class="linkedin-section" aria-label="Aktywność na LinkedIn">
    <div class="container">
      <div class="linkedin-inner">
        <div class="linkedin-copy">
          <p class="eyebrow eyebrow--accent">LinkedIn</p>
          <h2 class="linkedin-title">Śledź nas na LinkedIn.</h2>
          <p class="linkedin-sub">
            Analizy rynku TSL, case studies, aktualizacje regulacyjne.
            Co tydzień, bez spamu.
          </p>
          <a
            href="https://www.linkedin.com/company/vologis"
            class="btn-outline"
            target="_blank"
            rel="noopener noreferrer"
          >
            Obserwuj Vologis →
          </a>
        </div>
        <div class="linkedin-placeholder" aria-hidden="true">
          <p class="linkedin-placeholder-text">
            Embed aktywności LinkedIn<br>
            <span>— wkrótce</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       8. FINAL CTA — navy gradient band, Calendly + Klaviyo form
       ═══════════════════════════════════════════════════════ -->
  <section class="cta-section" aria-labelledby="cta-heading">
    <div class="container">
      <div class="cta-inner">

        <div class="cta-copy">
          <p class="eyebrow eyebrow--on-dark">Bezpłatna konsultacja</p>
          <h2 id="cta-heading" class="cta-title">Zacznij od bezpłatnej konsultacji.</h2>
          <p class="cta-sub">
            W 30 minut oceniamy Twój główny problem logistyczny
            i wskazujemy konkretne kierunki działania.
          </p>
          <button
            class="btn-accent"
            onclick="Calendly && Calendly.initPopupWidget({url:'https://calendly.com/vologis/konsultacja'}); return false;"
            type="button"
          >
            Umów bezpłatną konsultację
          </button>
        </div>

        <div class="cta-form">
          <p class="cta-form-label">Wolisz napisać? Zostaw kontakt — oddzwonimy.</p>
          <form class="contact-form" action="/pl/kontakt" method="get" aria-label="Szybki formularz kontaktowy">
            <input
              type="email"
              name="email"
              placeholder="Twój adres e-mail"
              class="form-input"
              aria-label="Adres e-mail"
              required
            />
            <button type="submit" class="form-submit">Wyślij →</button>
          </form>
          <p class="form-note">Brak spamu. Kontakt tylko w sprawie Twojego zapytania.</p>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Shared section spacing ───────────────────────── */
  section {
    padding-block: var(--space-3xl);
  }

  .eyebrow {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: var(--space-md);
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .eyebrow--accent { color: var(--color-accent); }
  .eyebrow--on-dark { color: var(--color-blue-on-dark); }

  .eyebrow::before {
    content: "";
    width: 1.75rem;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
  }

  .section-title {
    font-size: var(--text-display-s);
    color: var(--color-ink);
    margin-bottom: var(--space-md);
    letter-spacing: -0.025em;
  }

  .section-intro {
    font-size: var(--text-md);
    color: var(--color-muted);
    max-width: 52ch;
    line-height: 1.6;
  }

  .section-head { margin-bottom: var(--space-2xl); }

  .section-head--center {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .section-head--center .eyebrow::before { display: none; }
  .section-head--center .section-intro { margin-inline: auto; }

  .section-head--on-dark .section-title { color: var(--color-ink-on-dark); }
  .section-head--on-dark .section-intro { color: var(--color-muted-on-dark); }

  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  /* ── Buttons ──────────────────────────────────────── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-ink-on-dark);
    background: var(--color-ink);
    border: none;
    border-radius: var(--radius-pill);
    padding: var(--space-sm) var(--space-xl);
    white-space: nowrap;
    cursor: pointer;
    text-decoration: none;
    box-shadow: var(--shadow-sm);
    transition:
      background var(--dur-micro) var(--ease-out),
      transform var(--dur-micro) var(--ease-out),
      box-shadow var(--dur-micro) var(--ease-out);
  }

  .btn-primary:hover {
    background: var(--color-accent);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  .btn-primary:active { transform: translateY(0); }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-ink);
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: 2px;
    white-space: nowrap;
    transition:
      color var(--dur-micro) var(--ease-out),
      border-color var(--dur-micro) var(--ease-out);
  }

  .btn-secondary:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-ink);
    border: 1px solid var(--color-ink);
    border-radius: var(--radius-pill);
    padding: var(--space-xs) var(--space-lg);
    white-space: nowrap;
    text-decoration: none;
    transition:
      background var(--dur-micro) var(--ease-out),
      color var(--dur-micro) var(--ease-out),
      transform var(--dur-micro) var(--ease-out);
  }

  .btn-outline:hover {
    background: var(--color-ink);
    color: var(--color-ink-on-dark);
    transform: translateY(-1px);
  }

  .btn-outline--on-dark {
    color: var(--color-ink-on-dark);
    border-color: var(--color-glass-border);
  }

  .btn-outline--on-dark:hover {
    background: var(--color-ink-on-dark);
    color: var(--color-ink);
    border-color: var(--color-ink-on-dark);
  }

  .btn-accent {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-ink-on-dark);
    background: var(--color-accent);
    border: none;
    border-radius: var(--radius-pill);
    padding: var(--space-sm) var(--space-xl);
    white-space: nowrap;
    cursor: pointer;
    text-decoration: none;
    box-shadow: 0 8px 24px oklch(48% 0.19 26 / 0.30);
    transition:
      background var(--dur-micro) var(--ease-out),
      transform var(--dur-micro) var(--ease-out);
  }

  .btn-accent:hover {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
  }

  .btn-accent:active { transform: translateY(0); }

  /* ── Hero ─────────────────────────────────────────── */
  .hero {
    padding-top: calc(var(--space-3xl) + 5rem);
    padding-bottom: var(--space-3xl);
    background:
      radial-gradient(60rem 40rem at 85% -10%, var(--color-blue-tint), transparent 60%),
      var(--color-paper);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }

  .hero-h1 {
    font-size: var(--text-display);
    letter-spacing: -0.03em;
    line-height: 1.08;
    color: var(--color-ink);
    margin-bottom: var(--space-lg);
  }

  .hero-sub {
    font-size: var(--text-md);
    color: var(--color-muted);
    max-width: 52ch;
    line-height: 1.6;
    margin-bottom: var(--space-xl);
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  /* Hero proof card (nls floating-card pattern) */
  .hero-proof-card {
    position: relative;
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    box-shadow: var(--shadow-lg);
  }

  .hero-proof-badge {
    position: absolute;
    top: calc(-1 * var(--space-lg));
    right: var(--space-xl);
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-ink-on-dark);
