---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FaqAccordion from "../../components/FaqAccordion.astro";
import Eyebrow from "../../components/Eyebrow.astro";
import HeroCTAs from "../../components/HeroCTAs.astro";

const SITE = "https://vologis.com";

/* ── Data ────────────────────────────────────────────────── */

const trustItems = [
  "Działamy od marca 2011 roku",
  "Logistyka, spedycja, transport i doradztwo",
  "Transport krajowy i międzynarodowy",
  "Wsparcie firm w Polsce i Europie",
  "Podejście dopasowane do sytuacji klienta",
];

const briefItems = [
  {
    key: "Czym jest Vologis:",
    val: "firma logistyczno-doradcza wspierająca przedsiębiorstwa w logistyce, spedycji, transporcie i zarządzaniu procesami operacyjnymi.",
  },
  {
    key: "Komu pomaga:",
    val: "firmom produkcyjnym, handlowym, dystrybucyjnym, e-commerce i organizacjom, które chcą lepiej zarządzać transportem i procesami.",
  },
  {
    key: "Od kiedy:",
    val: "Vologis działa od marca 2011 roku.",
  },
  {
    key: "Jak pracuje:",
    val: "zakres współpracy buduje w odniesieniu do sytuacji i potrzeb klienta, unikając przypadkowych działań.",
  },
];

const philosophyCards = [
  {
    title: "Logistyka musi wspierać biznes",
    text: "Transport, magazyn i spedycja powinny być dopasowane do modelu działania firmy, a nie funkcjonować jako osobny obszar oderwany od sprzedaży, produkcji czy finansów.",
  },
  {
    title: "Koszt to nie tylko stawka za transport",
    text: "Najtańsza oferta może generować ukryte koszty: opóźnienia, reklamacje, przestoje, dodatkową pracę zespołu lub utratę przewidywalności.",
  },
  {
    title: "Proces jest ważniejszy niż interwencja",
    text: "Jednorazowe rozwiązanie problemu pomaga tylko na chwilę. Dlatego szukamy przyczyn, powtarzalnych wzorców i decyzji, które poprawiają organizację w dłuższym czasie.",
  },
  {
    title: "Partnerzy muszą być sprawdzeni",
    text: "W transporcie i spedycji zaufanie do podwykonawców ma bezpośredni wpływ na bezpieczeństwo ładunku, terminowość i komunikację z klientem.",
  },
  {
    title: "Dane pomagają podejmować lepsze decyzje",
    text: "Bez danych trudno odróżnić realny problem od wrażenia. Dlatego w projektach doradczych i logistycznych ważne są fakty, wskaźniki i analiza procesów.",
  },
  {
    title: "Długoterminowa współpraca daje większy efekt",
    text: "Największą wartość widać wtedy, gdy partner logistyczny rozumie rytm firmy, jej klientów, ograniczenia i cele rozwojowe.",
  },
];

const expertiseCards = [
  {
    num: "01",
    title: "Logistyka",
    text: "Pomagamy optymalizować koszty i procesy logistyczne, projektować bardziej uporządkowany przepływ towarów, informacji i odpowiedzialności oraz budować rozwiązania dopasowane do realnych potrzeb firmy.",
  },
  {
    num: "02",
    title: "Spedycja",
    text: "Wspieramy organizację przewozu, wybór środka transportu, dokumentację, awizowanie, przygotowanie przesyłki, nadanie, odbiór i koordynację zlecenia z osobistym opiekunem.",
  },
  {
    num: "03",
    title: "Transport krajowy i międzynarodowy",
    text: "Organizujemy transport na terenie Polski i Europy, w tym transport całopojazdowy FTL i częściowy LTL, dobierając rozwiązanie do ładunku, terminu i wymagań klienta.",
  },
  {
    num: "04",
    title: "Doradztwo logistyczne",
    text: "Analizujemy procesy, koszty, ryzyka i wąskie gardła. Pomagamy firmom podejmować decyzje dotyczące organizacji logistyki, magazynu, transportu i współpracy z partnerami.",
  },
  {
    num: "05",
    title: "Doradztwo w zarządzaniu",
    text: "Wspieramy firmy w poprawie organizacji, kontroli procesów, budżetowaniu, analizach i wdrażaniu działań, które mają zwiększać efektywność operacyjną.",
  },
  {
    num: "06",
    title: "Audyty i usprawnienia",
    text: "Pomagamy obiektywnie ocenić obecny stan organizacji, wskazać źródła problemów i zbudować plan działań, który oddziela szybkie usprawnienia od projektów strategicznych.",
  },
];

const processSteps = [
  {
    num: "01",
    title: "Zaczynamy od zrozumienia sytuacji",
    text: "Najpierw ustalamy, czego naprawdę potrzebuje firma: transportu, wsparcia spedycyjnego, audytu, doradztwa czy uporządkowania konkretnego procesu.",
  },
  {
    num: "02",
    title: "Analizujemy realne ograniczenia",
    text: "Bierzemy pod uwagę terminy, koszty, typ ładunku, wymagania odbiorców, dostępne dane, obecne procesy i możliwości zespołu klienta.",
  },
  {
    num: "03",
    title: "Dobieramy rozwiązanie",
    text: "Nie proponujemy przypadkowych działań. Zakres pracy dopasowujemy do sytuacji klienta, tak aby rozwiązanie było możliwe do wdrożenia i uzasadnione biznesowo.",
  },
  {
    num: "04",
    title: "Koordynujemy i komunikujemy",
    text: "W logistyce jakość komunikacji jest równie ważna jak sama usługa. Dlatego dbamy o jasne ustalenia, odpowiedzialność i przepływ informacji.",
  },
  {
    num: "05",
    title: "Wyciągamy wnioski",
    text: "Jeśli współpraca ma charakter stały, analizujemy powtarzalne problemy, koszty i możliwości poprawy, aby kolejne decyzje były coraz lepsze.",
  },
];

const principleCards = [
  {
    title: "Najpierw diagnoza, potem działanie",
    text: "Nie każda firma potrzebuje tego samego rozwiązania. Dlatego zaczynamy od zrozumienia problemu, a dopiero potem rekomendujemy działania.",
  },
  {
    title: "Partnerstwo zamiast transakcji",
    text: "Największą wartość tworzy współpraca oparta na zaufaniu, znajomości operacji klienta i długoterminowym myśleniu o efektywności.",
  },
  {
    title: "Odpowiedzialność za szczegóły",
    text: "W logistyce szczegóły decydują o wyniku: dokument, termin, awizacja, dobór przewoźnika, sposób załadunku i komunikacja w sytuacji problemowej.",
  },
  {
    title: "Praktyka ponad teorię",
    text: "Doradztwo ma sens tylko wtedy, gdy prowadzi do decyzji możliwych do wdrożenia w realnym środowisku firmy.",
  },
  {
    title: "Koszt rozumiemy szerzej niż cena",
    text: "Patrzymy na całkowity koszt decyzji: stawkę, czas pracy zespołu, ryzyko, opóźnienia, reklamacje i wpływ na klienta końcowego.",
  },
  {
    title: "Rozwiązania dopasowane do klienta",
    text: "Zakres działań budujemy w odniesieniu do sytuacji i potrzeb firmy, zamiast narzucać jeden gotowy model współpracy.",
  },
];

const timelineItems = [
  {
    year: "2011",
    title: "Start usług Vologis",
    text: "Vologis rozpoczyna działalność w obszarze doradztwa i bezpośredniej pomocy w zarządzaniu dla podmiotów gospodarczych.",
  },
  {
    year: "Kolejne lata",
    title: "Rozwój kompetencji logistycznych",
    text: "Firma rozwija wsparcie w logistyce, spedycji, transporcie oraz doradztwie logistycznym, odpowiadając na potrzeby klientów związane z efektywnością operacji.",
  },
  {
    year: "Dzisiaj",
    title: "Partner logistyczno-doradczy dla firm",
    text: "Vologis wspiera klientów w Polsce i Europie, pomagając organizować transport, optymalizować procesy i podejmować lepsze decyzje logistyczne.",
  },
];

const whyVologis = [
  "Łączymy transport, spedycję, logistykę i doradztwo w jednym partnerstwie.",
  "Pracujemy indywidualnie, w odniesieniu do sytuacji klienta.",
  "Pomagamy ograniczać przypadkowe decyzje w logistyce.",
  "Wspieramy zarówno codzienne zlecenia, jak i długoterminowe usprawnienia.",
  "Patrzymy na koszt, ryzyko, jakość i przewidywalność.",
  "Rozumiemy logistykę jako część całej organizacji, nie tylko jako usługę przewozu.",
  "Pracujemy z firmami, które chcą rosnąć bez zwiększania chaosu operacyjnego.",
];

const clientTypes = [
  "Firmy produkcyjne",
  "Firmy handlowe",
  "Dystrybutorzy",
  "E-commerce i D2C",
  "Importerzy i eksporterzy",
  "Firmy rozwijające sprzedaż na nowych rynkach",
  "Organizacje planujące uporządkowanie logistyki",
  "Firmy potrzebujące wsparcia transportowego lub spedycyjnego",
];

const faqs = [
  {
    q: "Czym zajmuje się Vologis?",
    a: "Vologis wspiera firmy w logistyce, spedycji, transporcie, doradztwie logistycznym i doradztwie w zakresie zarządzania. Pomaga organizować transport, porządkować procesy, optymalizować koszty i podejmować lepsze decyzje operacyjne.",
  },
  {
    q: "Od kiedy dziala Vologis?",
    a: "Vologis swiadczy uslugi od marca 2011 roku. Od poczatku firma koncentruje sie na doradztwie, pomocy w zarzadzaniu i wsparciu przedsiebiorstw w obszarach wplywajacych na efektywnosc operacyjna.",
  },
  {
    q: "Dla jakich firm pracuje Vologis?",
    a: "Vologis pracuje z firmami produkcyjnymi, handlowymi, dystrybucyjnymi, e-commerce oraz organizacjami, ktore potrzebuja wsparcia w transporcie, spedycji, logistyce lub optymalizacji procesow.",
  },
  {
    q: "Czy Vologis zajmuje sie transportem krajowym i miedzynarodowym?",
    a: "Tak. Vologis wspiera transport krajowy i miedzynarodowy, w tym transport na terenie Unii Europejskiej oraz przewozy calopojazadowe FTL i czesciowe LTL.",
  },
  {
    q: "Czy Vologis swiadczy doradztwo logistyczne?",
    a: "Tak. Doradztwo logistyczne jest jednym z obszarow dzialalnosci Vologis. Firma pomaga analizowac procesy, koszty, organizacje pracy i decyzje wplywajace na logistyke przedsiebiorstwa.",
  },
  {
    q: "Jak wyglada wspolpraca z Vologis?",
    a: "Wspolpraca zaczyna sie od zrozumienia sytuacji klienta. Nastepnie Vologis dobiera zakres dzialan, organizuje usluge lub rekomenduje rozwiazania dopasowane do potrzeb, kosztow, terminow i ryzyka operacyjnego.",
  },
  {
    q: "Czy Vologis dziala tylko lokalnie?",
    a: "Vologis ma siedzibe w Jarocinie, ale wspiera klientow w Polsce i Europie, szczegolnie w obszarach transportu, spedycji, logistyki i doradztwa.",
  },
];

/* ── Schema ───────────────────────────────────────────────── */

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Strona glowna", "item": `${SITE}/pl/` },
    { "@type": "ListItem", "position": 2, "name": "O nas", "item": `${SITE}/pl/o-nas` },
  ],
};

const schemaAboutPage = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "O nas — Vologis",
  "description": "Strona o firmie Vologis, jej historii, doswiadczeniu i podejsciu do logistyki, spedycji, transportu i doradztwa.",
  "url": `${SITE}/pl/o-nas`,
  "inLanguage": "pl-PL",
  "publisher": {
    "@type": "Organization",
    "name": "Vologis Sp. z o.o.",
    "url": SITE,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "ul. Wroclawska 79B",
      "postalCode": "63-200",
      "addressLocality": "Jarocin",
      "addressCountry": "PL",
    },
    "email": "biuro@vologis.com",
    "telephone": "+48533037996",
    "areaServed": ["Polska", "Europa"],
    "knowsAbout": [
      "logistyka",
      "spedycja",
      "transport krajowy i miedzynarodowy",
      "doradztwo logistyczne",
      "optymalizacja procesow logistycznych",
    ],
  },
};

const schemaPerson = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Pawel Wojtczak",
  "jobTitle": "CEO i Prezes Zarzadu",
  "worksFor": {
    "@type": "Organization",
    "name": "Vologis Sp. z o.o.",
    "url": SITE,
  },
};

const schemaFaq = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((f) => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
};
---

<BaseLayout
  title="O nas | Vologis — niezależny partner logistyczny end-to-end"
  description="Poznaj Vologis — niezależną firmę doradczą specjalizującą się w pośrednictwie logistycznym, doradztwie operacyjnym, projektach Greenfield, usługach dronowych i interim management. PL i EU."
  canonical="https://vologis.com/pl/o-nas/"
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaAboutPage)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaPerson)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFaq)} />

  <!-- ── 1. HERO (dark navy) ───────────────────────────────── -->
  <section class="on-hero" aria-labelledby="on-h1">
    <div class="container">

      <nav class="on-bc" aria-label="Breadcrumb">
        <ol class="on-bc__list" role="list">
          <li><a href="/pl/">Strona główna</a></li>
          <li class="on-bc__sep" aria-hidden="true">›</li>
          <li aria-current="page">O nas</li>
        </ol>
      </nav>

      <Eyebrow text="O VOLOGIS" />
      <h1 id="on-h1" class="on-h1">
        Logistyka zaczyna się od dobrych decyzji.<br>Vologis pomaga je podejmować.
      </h1>
      <p class="on-lead">
        Vologis to firma logistyczno-doradcza, która wspiera przedsiębiorstwa w logistyce,
        spedycji, transporcie i zarządzaniu procesami operacyjnymi. Pomagamy firmom porządkować
        działania, ograniczać ryzyko, optymalizować koszty i podejmować decyzje logistyczne na
        podstawie doświadczenia, danych i dobrze zaprojektowanych procedur.
      </p>

      <HeroCTAs
        primaryLabel="Umów konsultację"
        primaryHref="/pl/kontakt"
        secondaryLabel="Zobacz jak pracujemy"
        secondaryHref="/pl/proces"
      />

      <ul class="on-trust" role="list" aria-label="Kluczowe fakty o Vologis">
        {trustItems.map((item) => (
          <li class="on-trust__item">
            <svg class="on-trust__icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m4 10.5 4 4 8-9" />
            </svg>
            {item}
          </li>
        ))}
      </ul>

    </div>
  </section>

  <!-- ── 2. KIM JESTEŚMY ───────────────────────────────────── -->
  <section class="on-section on-who" aria-labelledby="on-who-h">
    <div class="container on-two-col">

      <div class="on-copy">
        <h2 class="on-h2" id="on-who-h">Kim jesteśmy?</h2>
        <p class="on-body">
          Vologis powstał z przekonania, że logistyka nie powinna być zbiorem przypadkowych
          decyzji, telefonów i doraźnych reakcji na problemy. W dobrze zarządzanej firmie
          transport, magazyn, spedycja, dostawy, dokumenty i komunikacja muszą tworzyć spójny
          system.
        </p>
        <p class="on-body">
          Od marca 2011 roku wspieramy firmy w obszarach, które bezpośrednio wpływają na ich
          efektywność operacyjną: logistyce, spedycji, transporcie, doradztwie logistycznym
          oraz doradztwie w zakresie zarządzania. Naszą rolą jest nie tylko zorganizować
          usługę, ale też pomóc klientowi lepiej zrozumieć, jakie decyzje będą bezpieczne,
          opłacalne i możliwe do wdrożenia w jego realiach.
        </p>
        <p class="on-body">
          Zakres współpracy budujemy w odniesieniu do sytuacji, potrzeb i ograniczeń klienta.
          Dzięki temu unikamy przypadkowych ruchów i skupiamy się na rozwiązaniach, które
          realnie wspierają organizację.
        </p>
      </div>

      <aside class="on-brief" aria-label="Vologis w skrócie">
        <p class="on-brief__label">Vologis w skrócie</p>
        <ul class="on-brief__list" role="list">
          {briefItems.map((item) => (
            <li class="on-brief__item">
              <span class="on-brief__key">{item.key}</span>
              <span class="on-brief__val">{item.val}</span>
            </li>
          ))}
        </ul>
      </aside>

    </div>
  </section>

  <!-- ── 3. HISTORIA ───────────────────────────────────────── -->
  <section class="on-section on-history" aria-labelledby="on-history-h">
    <div class="container on-history-inner">
      <h2 class="on-h2" id="on-history-h">Historia Vologis zaczęła się od praktycznego problemu</h2>
      <div class="on-history-body">
        <p class="on-body">
          Wiele firm rozwija sprzedaż, produkty i relacje z klientami szybciej niż swoje
          procesy operacyjne. Na początku wystarcza kilka kontaktów do przewoźników, podstawowe
          procedury, arkusze i doświadczenie jednej lub dwóch osób. Z czasem jednak rośnie
          liczba zamówień, kierunków, wyjątków, dokumentów i decyzji, które trzeba podejmować
          codziennie.
        </p>
        <p class="on-body">
          Właśnie wtedy logistyka zaczyna decydować o tym, czy firma może rosnąć dalej.
          Opóźniony transport, źle dobrany przewoźnik, brak kontroli nad kosztami, przeciążony
          magazyn lub nieczytelna komunikacja między działami potrafią zatrzymać wzrost równie
          skutecznie jak brak sprzedaży.
        </p>
        <p class="on-body on-body--highlight">
          Vologis został zbudowany po to, aby pomagać firmom w tym miejscu: tam, gdzie operacja
          zaczyna wymagać większego porządku, doświadczenia i odpowiedzialnego partnera.
        </p>
        <p class="on-body">
          Nie patrzymy na logistykę wyłącznie przez pryzmat pojedynczego zlecenia. Patrzymy na
          nią jako na część całego systemu firmy: zakupów, sprzedaży, produkcji, magazynu,
          finansów, obsługi klienta i zarządzania.
        </p>
      </div>
    </div>
  </section>

  <!-- ── 4. FOUNDER ────────────────────────────────────────── -->
  <section class="on-section on-founder" aria-labelledby="on-founder-h">
    <div class="container">
      <div class="on-founder-grid">

        <div class="on-founder-copy">
          <h2 class="on-h2" id="on-founder-h">Doświadczenie, które łączy logistykę i zarządzanie</h2>
          <p class="on-body">
            Za Vologis stoi doświadczenie w pracy z firmami, które potrzebują nie tylko usługi
            transportowej, ale realnego wsparcia w podejmowaniu decyzji logistycznych i
            organizacyjnych. To podejście łączy praktykę operacyjną z doradztwem w zakresie
            zarządzania.
          </p>
          <p class="on-body">
            W logistyce łatwo jest obiecać szybkie rozwiązanie. Trudniej jest zrozumieć, dlaczego
            problem powstaje, jakie ryzyko niesie dana decyzja i jak zaprojektować współpracę
            tak, aby nie tworzyć kolejnych komplikacji. Dlatego w Vologis kluczowe są trzy rzeczy:
            diagnoza, odpowiedzialność i dopasowanie rozwiązania do konkretnej sytuacji klienta.
          </p>
          <blockquote class="on-quote">
            <p class="on-quote__text">
              Dobra logistyka nie polega na tym, żeby reagować szybciej na chaos. Polega na tym,
              żeby tak zaprojektować proces, partnerów i decyzje, aby chaos pojawiał się rzadziej.
            </p>
            <footer class="on-quote__attr">
              <cite class="on-quote__name">Paweł Wojtczak, CEO i Prezes Zarządu Vologis</cite>
            </footer>
          </blockquote>
        </div>

        <div class="on-founder-right">
          <img
            src="/pawel-wojtczak.webp"
            alt="Paweł Wojtczak — CEO i Prezes Zarządu Vologis, ekspert logistyki i doradztwa operacyjnego"
            width="480"
            height="720"
            class="on-founder-photo"
            loading="lazy"
            decoding="async"
          />

          <div class="on-founder-bio">
            <p class="on-founder-name">Paweł Wojtczak</p>
            <p class="on-founder-role">CEO i Prezes Zarządu, Vologis</p>
            <p class="on-founder-bio-text">
              Wspiera firmy w obszarze logistyki, spedycji, transportu i zarządzania
              procesami operacyjnymi. Łączy perspektywę doradczą z praktycznym rozumieniem
              codziennych wyzwań firm produkcyjnych, handlowych, dystrybucyjnych i e-commerce.
