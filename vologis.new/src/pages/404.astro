---
import BaseLayout from "../layouts/BaseLayout.astro";

/*
  Global 404 page — renders once as static HTML.
  Language (PL / EN) is detected client-side from window.location.pathname.
  Default render: Polish (majority of visitors).
  noIndex: true → robots: noindex, nofollow
  Not included in sitemap (sitemap filter: includes('/pl/'), '404' doesn't match).
*/
---

<BaseLayout
  title="Strona nie została znaleziona | Vologis"
  description="Nie znaleźliśmy tej podstrony. Wróć na stronę główną Vologis albo przejdź do usług, wiedzy lub kontaktu."
  noIndex={true}
>

  <!-- ── 404 HERO ───────────────────────────────────────────── -->
  <section class="e4-hero" aria-labelledby="e4-h1">
    <div class="container e4-grid">

      <!-- Left: copy -->
      <div class="e4-copy">
        <p class="e4-eyebrow" aria-hidden="true">404</p>

        <!-- PL -->
        <h1 id="e4-h1" class="e4-h1 lang-pl">
          Ta trasa nie prowadzi do właściwej strony
        </h1>
        <p class="e4-lead lang-pl">
          Podstrona, której szukasz, mogła zostać przeniesiona, usunięta albo
          adres został wpisany niepoprawnie. Wróć na stronę główną lub przejdź
          do jednej z najważniejszych sekcji Vologis.
        </p>
        <div class="e4-actions lang-pl">
          <a href="/pl/" class="e4-btn e4-btn--primary">Wróć na stronę główną</a>
          <a href="/pl/kontakt" class="e4-btn e4-btn--ghost">Skontaktuj się z nami</a>
        </div>

        <!-- EN (hidden by default, shown by JS) -->
        <h1 class="e4-h1 lang-en" hidden aria-hidden="true">
          This route does not lead to the right page
        </h1>
        <p class="e4-lead lang-en" hidden aria-hidden="true">
          The page you are looking for may have been moved, removed or the
          address may have been typed incorrectly. Go back to the homepage or
          choose one of the key Vologis sections below.
        </p>
        <div class="e4-actions lang-en" hidden aria-hidden="true">
          <a href="/pl/" class="e4-btn e4-btn--primary">Back to homepage</a>
          <a href="/pl/kontakt" class="e4-btn e4-btn--ghost">Contact us</a>
        </div>
      </div>

      <!-- Right: decorative "404" + route SVG -->
      <div class="e4-visual" aria-hidden="true">
        <span class="e4-ghost">404</span>
        <div class="e4-route">
          <svg class="e4-route-svg" viewBox="0 0 40 160" fill="none"
               stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
               role="presentation">
            <!-- Origin point -->
            <circle cx="20" cy="12" r="6" fill="currentColor" stroke="none" class="e4-dot" />
            <!-- Dashed route line -->
            <line x1="20" y1="20" x2="20" y2="120"
                  stroke-width="2" stroke-dasharray="6 5" class="e4-dashed" />
            <!-- Destination: X = route not found -->
            <line x1="12" y1="128" x2="28" y2="144" stroke-width="2.5" class="e4-cross" />
            <line x1="28" y1="128" x2="12" y2="144" stroke-width="2.5" class="e4-cross" />
          </svg>
        </div>
      </div>

    </div>
  </section>

  <!-- ── HELP SECTION ──────────────────────────────────────── -->
  <section class="e4-help" aria-labelledby="e4-help-h">
    <div class="container">

      <!-- PL -->
      <div class="lang-pl">
        <h2 class="e4-help-h" id="e4-help-h">Szukasz konkretnej informacji?</h2>
        <p class="e4-help-intro">
          Najczęściej użytkownicy trafiają dalej do usług, bazy wiedzy albo
          kontaktu. Wybierz jedną ze ścieżek poniżej.
        </p>
      </div>

      <!-- EN -->
      <div class="lang-en" hidden aria-hidden="true">
        <h2 class="e4-help-h" id="e4-help-h-en">Looking for something specific?</h2>
        <p class="e4-help-intro">
          Most visitors continue to our services, knowledge base or contact page.
          Choose one of the paths below.
        </p>
      </div>

      <!-- Cards: PL -->
      <div class="e4-cards lang-pl" role="list">
        <a class="e4-card" href="/pl/uslugi" role="listitem">
          <div class="e4-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"
                 stroke-linecap="round" stroke-linejoin="round">
              <circle cx="6" cy="19" r="2.5"/><circle cx="18" cy="5" r="2.5"/>
              <path d="M8.5 19H15a3.5 3.5 0 0 0 0-7H9a3.5 3.5 0 0 1 0-7h6.5"/>
            </svg>
          </div>
          <h3 class="e4-card__title">Usługi</h3>
          <p class="e4-card__desc">
            Sprawdź, jak Vologis wspiera firmy w logistyce, transporcie,
            spedycji i doradztwie.
          </p>
          <span class="e4-card__cta">Zobacz usługi <span aria-hidden="true">→</span></span>
        </a>

        <a class="e4-card" href="/pl/wiedza" role="listitem">
          <div class="e4-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"
                 stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
            </svg>
          </div>
          <h3 class="e4-card__title">Wiedza</h3>
          <p class="e4-card__desc">
            Przeczytaj praktyczne artykuły o logistyce, magazynach, transporcie
            i optymalizacji procesów.
          </p>
          <span class="e4-card__cta">Przejdź do wiedzy <span aria-hidden="true">→</span></span>
        </a>

        <a class="e4-card" href="/pl/kontakt" role="listitem">
          <div class="e4-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"
                 stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
          </div>
          <h3 class="e4-card__title">Kontakt</h3>
          <p class="e4-card__desc">
            Opisz swój problem logistyczny lub zapytaj o organizację transportu,
            doradztwo albo audyt.
          </p>
          <span class="e4-card__cta">Napisz do Vologis <span aria-hidden="true">→</span></span>
        </a>
      </div>

      <!-- Cards: EN -->
      <div class="e4-cards lang-en" hidden aria-hidden="true" role="list">
        <a class="e4-card" href="/pl/uslugi" role="listitem">
          <div class="e4-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"
                 stroke-linecap="round" stroke-linejoin="round">
              <circle cx="6" cy="19" r="2.5"/><circle cx="18" cy="5" r="2.5"/>
              <path d="M8.5 19H15a3.5 3.5 0 0 0 0-7H9a3.5 3.5 0 0 1 0-7h6.5"/>
            </svg>
          </div>
          <h3 class="e4-card__title">Services</h3>
          <p class="e4-card__desc">
            See how Vologis supports companies in logistics, transport,
            forwarding and advisory.
          </p>
          <span class="e4-card__cta">View services <span aria-hidden="true">→</span></span>
        </a>

        <a class="e4-card" href="/pl/wiedza" role="listitem">
          <div class="e4-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"
                 stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
            </svg>
          </div>
          <h3 class="e4-card__title">Knowledge</h3>
          <p class="e4-card__desc">
            Read practical articles about logistics, warehousing, transport
            and process optimization.
          </p>
          <span class="e4-card__cta">Visit knowledge base <span aria-hidden="true">→</span></span>
        </a>

        <a class="e4-card" href="/pl/kontakt" role="listitem">
          <div class="e4-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"
                 stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
          </div>
          <h3 class="e4-card__title">Contact</h3>
          <p class="e4-card__desc">
            Describe your logistics challenge or ask about transport
            organization, advisory or audit.
          </p>
          <span class="e4-card__cta">Contact Vologis <span aria-hidden="true">→</span></span>
        </a>
      </div>

      <!-- Footnote: PL -->
      <p class="e4-footnote lang-pl">
        Jeśli problem się powtarza, daj nam znać —
        <a href="/pl/kontakt">sprawdzimy, czy link wymaga poprawy</a>.
      </p>

      <!-- Footnote: EN -->
      <p class="e4-footnote lang-en" hidden aria-hidden="true">
        If this keeps happening,
        <a href="/pl/kontakt">let us know</a>
        — we will check whether the link needs to be fixed.
      </p>

    </div>
  </section>

</BaseLayout>

<style>
  /* ─── Hero ───────────────────────────────────────────────── */
  .e4-hero {
    padding-top: calc(4.25rem + 3px + var(--space-2xl));
    padding-bottom: var(--space-2xl);
    background: var(--color-paper);
    overflow: hidden;
    min-height: calc(100vh - 16rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .e4-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-3xl);
    align-items: center;
  }

  /* Eyebrow */
  .e4-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .e4-eyebrow::before {
    content: "";
    width: 1.5rem;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    flex-shrink: 0;
  }

  /* H1 */
  .e4-h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw + 0.5rem, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.08;
    color: var(--color-ink);
    margin-bottom: var(--space-lg);
    max-width: 22ch;
  }

  /* Lead */
  .e4-lead {
    font-size: var(--text-md);
    color: var(--color-muted);
    line-height: 1.65;
    max-width: 52ch;
    margin-bottom: var(--space-xl);
  }

  /* Actions */
  .e4-actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  /* Buttons */
  .e4-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    padding: var(--space-sm) var(--space-xl);
    border-radius: var(--radius-pill);
    text-decoration: none;
    cursor: pointer;
    border: 1px solid transparent;
    white-space: nowrap;
    transition:
      background var(--dur-micro) var(--ease-out),
      border-color var(--dur-micro) var(--ease-out),
      color var(--dur-micro) var(--ease-out),
      transform var(--dur-micro) var(--ease-out);
  }

  .e4-btn--primary {
    background: var(--color-ink);
    color: var(--color-ink-on-dark);
  }

  .e4-btn--primary:hover {
    background: var(--color-accent);
    transform: translateY(-1px);
  }

  .e4-btn--ghost {
    background: var(--color-paper-2);
    color: var(--color-ink);
    border-color: var(--color-rule);
  }

  .e4-btn--ghost:hover {
    border-color: var(--color-blue);
    background: var(--color-paper);
  }

  /* ─── Decorative right column ────────────────────────────── */
  .e4-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    user-select: none;
    pointer-events: none;
    flex-shrink: 0;
  }

  /* Ghost "404" number */
  .e4-ghost {
    font-family: var(--font-display);
    font-size: clamp(6rem, 14vw, 14rem);
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 2px var(--color-rule);
    display: block;
  }

  /* Route SVG */
  .e4-route-svg {
    width: 40px;
    height: 160px;
  }

  .e4-dot   { color: var(--color-secondary); }
  .e4-dashed { color: var(--color-rule); }
  .e4-cross  { color: var(--color-accent); }

  /* ─── Help section ───────────────────────────────────────── */
  .e4-help {
    padding-block: var(--space-3xl);
    background: var(--color-paper-2);
    border-top: 1px solid var(--color-rule);
  }

  .e4-help-h {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin-bottom: var(--space-md);
  }

  .e4-help-intro {
    font-size: var(--text-base);
    color: var(--color-muted);
    line-height: 1.65;
    max-width: 58ch;
    margin-bottom: var(--space-2xl);
  }

  /* Cards */
  .e4-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .e4-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    background: var(--color-paper);
    text-decoration: none;
    position: relative;
    transition:
      border-color var(--dur-short) var(--ease-out),
      box-shadow var(--dur-short) var(--ease-out),
      transform var(--dur-short) var(--ease-out);
  }

  .e4-card:hover {
    border-color: var(--color-blue);
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .e4-card__icon {
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-md);
    background: var(--color-blue-tint);
    color: var(--color-secondary);
    flex-shrink: 0;
  }

  .e4-card__icon svg { width: 1.4rem; height: 1.4rem; }

  .e4-card__title {
    font-family: var(--font-display);
    font-size: var(--text-md);
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    line-height: 1.2;
  }

  .e4-card__desc {
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: 1.65;
    flex: 1;
  }

  .e4-card__cta {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-secondary);
    margin-top: auto;
    transition: color var(--dur-micro) var(--ease-out);
  }

  .e4-card__cta span {
    display: inline-block;
    transition: transform var(--dur-short) var(--ease-out);
  }

  .e4-card:hover .e4-card__cta { color: var(--color-ink); }
  .e4-card:hover .e4-card__cta span { transform: translateX(4px); }

  /* Stretched link */
  .e4-card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
  }

  /* Footnote */
  .e4-footnote {
    font-size: var(--text-sm);
    color: var(--color-neutral);
    line-height: 1.6;
  }

  .e4-footnote a {
    color: var(--color-secondary);
    text-decoration: none;
    transition: color var(--dur-micro) var(--ease-out);
  }

  .e4-footnote a:hover { color: var(--color-ink); }

  /* ─── Responsive ─────────────────────────────────────────── */
  @media (max-width: 64rem) {
    .e4-ghost { font-size: clamp(5rem, 10vw, 9rem); }
  }

  @media (max-width: 48rem) {
    .e4-grid {
      grid-template-columns: 1fr;
    }

    .e4-visual {
      flex-direction: row;
      align-items: center;
      order: -1;
      justify-content: flex-start;
      gap: var(--space-lg);
    }

    .e4-ghost {
      font-size: clamp(4rem, 18vw, 6rem);
      -webkit-text-stroke: 1.5px var(--color-rule);
    }

    .e4-route { display: none; }

    .e4-hero { min-height: auto; }
    .e4-lead { font-size: var(--text-base); }
    .e4-actions { flex-direction: column; }
    .e4-btn { width: 100%; justify-content: center; }

    .e4-cards { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Detect language from URL and switch visible content
  const isEN = window.location.pathname.startsWith('/en');

  if (isEN) {
    // Hide PL elements
    document.querySelectorAll<HTMLElement>('.lang-pl').forEach((el) => {
      el.hidden = true;
      el.setAttribute('aria-hidden', 'true');
    });
    // Show EN elements
    document.querySelectorAll<HTMLElement>('.lang-en').forEach((el) => {
      el.hidden = false;
      el.removeAttribute('aria-hidden');
    });
    // Fix h1 id for accessibility
    const h1en = document.querySelector<HTMLElement>('.e4-h1.lang-en');
    if (h1en) h1en.id = 'e4-h1';
    const h1pl = document.querySelector<HTMLElement>('.e4-h1.lang-pl');
    if (h1pl) h1pl.removeAttribute('id');
    const helpH = document.querySelector<HTMLElement>('#e4-help-h-en');
    if (helpH) helpH.id = 'e4-help-h';
    // Update document title and meta description
    document.title = 'Page not found | Vologis';
    const metaDesc = document.querySelector<HTMLMetaElement>('meta[name="description"]');
    if (metaDesc) {
      metaDesc.content =
        'We could not find this page. Go back to the Vologis homepage or visit services, knowledge base or contact.';
    }
  }
</script>
