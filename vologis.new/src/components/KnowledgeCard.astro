---
interface Props {
  title: string;
  slug: string;
  description: string;
  category: string;
  updatedAt: string;
  readingTime: string;
  featured?: boolean;
}

const { title, slug, description, category, updatedAt, readingTime, featured = false } = Astro.props;
const href = `/pl/wiedza/${slug}`;
---

<article class:list={["kc", { "kc--featured": featured }]}>
  <div class="kc__meta">
    <span class="kc__cat">{category}</span>
    <span class="kc__sep" aria-hidden="true">·</span>
    <span class="kc__time">{readingTime} czytania</span>
  </div>
  <h3 class="kc__title">
    <a class="kc__link" href={href}>{title}</a>
  </h3>
  <p class="kc__desc">{description}</p>
  <div class="kc__footer">
    <time class="kc__date" datetime={updatedAt}>
      Aktualizacja: {updatedAt.split("-").reverse().join(".")}
    </time>
    <a class="kc__cta" href={href}>Czytaj artykuł <span aria-hidden="true">→</span></a>
  </div>
</article>

<style>
  .kc {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    background: var(--color-paper);
    transition:
      border-color var(--dur-short) var(--ease-out),
      box-shadow var(--dur-short) var(--ease-out);
    position: relative;
  }

  .kc:hover {
    border-color: var(--color-blue);
    box-shadow: var(--shadow-md);
  }

  /* Featured variant: horizontal two-column layout on desktop */
  .kc--featured {
    border-left: 4px solid var(--color-secondary);
    background: var(--color-paper);
    box-shadow: var(--shadow-sm);
  }

  .kc__meta {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    flex-wrap: wrap;
  }

  .kc__cat {
    display: inline-flex;
    align-items: center;
    padding: 2px var(--space-sm);
    border-radius: var(--radius-pill);
    background: var(--color-blue-tint);
    color: var(--color-ink);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .kc__sep { color: var(--color-neutral); user-select: none; }

  .kc__time {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  .kc__title {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--color-ink);
  }

  .kc--featured .kc__title { font-size: var(--text-xl); }
  .kc:not(.kc--featured) .kc__title { font-size: var(--text-md); }

  .kc__link {
    color: inherit;
    text-decoration: none;
    transition: color var(--dur-micro) var(--ease-out);
  }

  /* Stretched link — whole card is clickable */
  .kc__link::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
  }

  .kc:hover .kc__link { color: var(--color-secondary); }

  .kc__desc {
    font-size: var(--text-base);
    color: var(--color-muted);
    line-height: 1.7;
    flex: 1;
  }

  .kc__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-rule);
    margin-top: auto;
  }

  .kc__date {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-neutral);
  }

  .kc__cta {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-secondary);
    text-decoration: none;
    position: relative;
    z-index: 1;
    transition: color var(--dur-micro) var(--ease-out);
  }

  .kc:hover .kc__cta { color: var(--color-ink); }

  .kc__cta span {
    display: inline-block;
    transition: transform var(--dur-short) var(--ease-out);
  }

  .kc:hover .kc__cta span { transform: translateX(4px); }
</style>
