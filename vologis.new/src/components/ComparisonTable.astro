---
interface Row {
  feature: string;
  vologis: string;
  other: string;
}
interface Props {
  rows: Row[];
  leftHeader?: string;
  rightHeader?: string;
}
const { rows, leftHeader = "VOLOGIS", rightHeader = "WŁASNY DZIAŁ / DUŻY KONSULTING" } = Astro.props;
---

<div class="cmp" role="table" aria-label="Porównanie Vologis z alternatywami">
  <div class="cmp__row cmp__row--head" role="row">
    <span class="cmp__cell cmp__cell--feat" role="columnheader"></span>
    <span class="cmp__cell cmp__head cmp__head--us" role="columnheader">{leftHeader}</span>
    <span class="cmp__cell cmp__head cmp__head--them" role="columnheader">{rightHeader}</span>
  </div>

  {rows.map((r) => (
    <div class="cmp__row" role="row">
      <span class="cmp__cell cmp__cell--feat" role="rowheader">{r.feature}</span>
      <span class="cmp__cell cmp__cell--us" role="cell">
        <svg class="cmp__ico cmp__ico--yes" viewBox="0 0 20 20" width="19" height="19" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m4 10.5 4 4 8-9" /></svg>
        <span>{r.vologis}</span>
      </span>
      <span class="cmp__cell cmp__cell--them" role="cell">
        <svg class="cmp__ico cmp__ico--no" viewBox="0 0 20 20" width="19" height="19" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 6l8 8M14 6l-8 8" /></svg>
        <span>{r.other}</span>
      </span>
    </div>
  ))}
</div>

<style>
  .cmp {
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-paper);
  }

  .cmp__row {
    display: grid;
    grid-template-columns: 1.1fr 1.4fr 1.4fr;
    border-bottom: 1px solid var(--color-rule);
  }

  .cmp__row:last-child { border-bottom: none; }

  .cmp__cell {
    display: flex;
    align-items: flex-start;
    gap: var(--space-xs);
    padding: var(--space-md) var(--space-lg);
    font-size: var(--text-base);
    line-height: 1.5;
  }

  .cmp__cell--feat {
    font-weight: 600;
    color: var(--color-ink);
    background: var(--color-paper-2);
    align-items: center;
  }

  .cmp__cell--us { color: var(--color-ink); }
  .cmp__cell--them { color: var(--color-muted); }

  /* header row */
  .cmp__row--head .cmp__cell { padding-block: var(--space-md); }
  .cmp__head {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-sm);
    letter-spacing: 0.04em;
    align-items: center;
  }
  .cmp__head--us { background: var(--color-paper-dark); color: var(--color-ink-on-dark); }
  .cmp__head--them { background: var(--color-paper-2); color: var(--color-ink); }

  .cmp__ico { flex-shrink: 0; width: 1.15rem; height: 1.15rem; margin-top: 0.15rem; }
  .cmp__ico--yes { color: var(--color-blue); }
  .cmp__ico--no { color: var(--color-neutral); }

  /* Mobile: horizontal scroll with sticky feature column */
  @media (max-width: 48rem) {
    .cmp { overflow-x: auto; }
    .cmp__row {
      grid-template-columns: 9rem 14rem 14rem;
      min-width: 37rem;
    }
    .cmp__cell--feat {
      position: sticky;
      left: 0;
      z-index: 1;
    }
    .cmp__cell { font-size: var(--text-sm); }
  }
</style>
