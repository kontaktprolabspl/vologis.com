---
/**
 * Reusable service card.
 * Used on the services hub (/pl/uslugi) and the homepage services section.
 */
interface Props {
  icon: string;          // inline SVG markup
  number: string;        // "01"–"05"
  title: string;
  subtitle: string;
  bullets: string[];
  href: string;
  accentColor?: string;  // left-border / icon accent; defaults to navy
}

const {
  icon,
  number,
  title,
  subtitle,
  bullets,
  href,
  accentColor = "var(--color-ink)",
} = Astro.props;
---

<article class="svc-card" style={`--card-accent: ${accentColor};`}>
  <div class="svc-card__head">
    <span class="svc-card__icon" aria-hidden="true" set:html={icon}></span>
    <span class="svc-card__num tnum" aria-hidden="true">{number}</span>
  </div>

  <h3 class="svc-card__title">{title}</h3>
  <p class="svc-card__subtitle">{subtitle}</p>

  <ul class="svc-card__bullets" role="list">
    {bullets.map((b) => (
      <li class="svc-card__bullet">
        <svg
          class="svc-card__check"
          viewBox="0 0 20 20"
          width="19"
          height="19"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="m4 10.5 4 4 8-9" />
        </svg>
        <span>{b}</span>
      </li>
    ))}
  </ul>

  <a class="svc-card__cta" href={href}>
    Dowiedz się więcej <span aria-hidden="true">→</span>
  </a>
</article>

<style>
  .svc-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-left: 4px solid var(--card-accent);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    box-shadow: var(--shadow-sm);
    transition:
      border-color var(--dur-short) var(--ease-out),
      transform var(--dur-short) var(--ease-out),
      box-shadow var(--dur-short) var(--ease-out);
  }

  .svc-card:hover {
    border-color: var(--color-blue);
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  /* Keep keyboard focus visible (stretched-link below removes default outline reach) */
  .svc-card:focus-within {
    border-color: var(--color-blue);
    box-shadow: var(--shadow-md);
  }

  .svc-card__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .svc-card__icon {
    display: grid;
    place-items: center;
    width: 3.25rem;
    height: 3.25rem;
    border-radius: var(--radius-md);
    background: var(--color-blue-tint);
    color: var(--card-accent);
  }

  .svc-card__icon :global(svg) {
    width: 1.6rem;
    height: 1.6rem;
  }

  .svc-card__num {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--color-neutral);
  }

  .svc-card__title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--color-ink);
  }

  .svc-card__subtitle {
    font-size: var(--text-base);
    color: var(--color-muted);
    line-height: 1.55;
    margin-top: calc(var(--space-md) * -1 + var(--space-2xs));
  }

  .svc-card__bullets {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    list-style: none;
  }

  .svc-card__bullet {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-ink);
    line-height: 1.5;
  }

  .svc-card__check {
    flex-shrink: 0;
    width: 1.15rem;
    height: 1.15rem;
    margin-top: 0.15rem;
    color: var(--color-blue);
  }

  .svc-card__cta {
    margin-top: auto;
    align-self: flex-start;
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-blue);
    text-decoration: none;
    padding-top: var(--space-2xs);
    transition: color var(--dur-micro) var(--ease-out);
  }

  .svc-card__cta span {
    display: inline-block;
    transition: transform var(--dur-short) var(--ease-out);
  }

  /* Stretched link — whole card is clickable, CTA keeps the semantics */
  .svc-card__cta::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
  }

  .svc-card:hover .svc-card__cta { color: var(--color-ink); }
  .svc-card:hover .svc-card__cta span { transform: translateX(4px); }
</style>
