---
import BaseLayout from "./BaseLayout.astro";
import Eyebrow from "../components/Eyebrow.astro";

interface BreadcrumbItem {
  name: string;
  href?: string;
}

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  /** Optional hero background image path, e.g. "/services/posrednictwo-logistyczne.png" */
  heroImage?: string;
  /** Alt text for the hero image */
  heroImageAlt?: string;
  eyebrow?: string;
  h1: string;
  lead: string;
  trustItems?: string[];
  ctaPrimaryLabel?: string;
  ctaPrimaryHref?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryHref?: string;
  breadcrumbs?: BreadcrumbItem[];
}

const {
  title,
  description,
  canonical,
  ogImage,
  heroImage,
  heroImageAlt = "",
  eyebrow = "Usługi",
  h1,
  lead,
  trustItems = [],
  ctaPrimaryLabel = "Zapytaj o usługę",
  ctaPrimaryHref = "/pl/kontakt",
  ctaSecondaryLabel,
  ctaSecondaryHref,
  breadcrumbs = [],
} = Astro.props;

const SITE = "https://vologis.com";

const allBreadcrumbs = [
  { name: "Strona główna", href: `${SITE}/pl/` },
  { name: "Usługi", href: `${SITE}/pl/uslugi` },
  ...breadcrumbs,
];

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": allBreadcrumbs.map((b, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": b.name,
    ...(b.href ? { "item": b.href } : {}),
  })),
};
---

<BaseLayout {title} {description} {canonical} {ogImage} preloadImage={heroImage}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />

  <!-- ── Service hero (dark navy) ────────────────────────── -->
  <section
    class:list={["spl-hero", { "spl-hero--has-img": !!heroImage }]}
    style={heroImage ? `background-image: url('${heroImage}')` : undefined}
    aria-labelledby="spl-h1"
  >
    <div class="container">

      <nav class="spl-bc" aria-label="Breadcrumb">
        <ol class="spl-bc__list" role="list">
          {allBreadcrumbs.map((b, i) => (
            <>
              {i > 0 && <li class="spl-bc__sep" aria-hidden="true">›</li>}
              <li>
                {b.href && i < allBreadcrumbs.length - 1
                  ? <a href={b.href.replace(SITE, "")}>{b.name}</a>
                  : <span aria-current={i === allBreadcrumbs.length - 1 ? "page" : undefined}>{b.name}</span>
                }
              </li>
            </>
          ))}
        </ol>
      </nav>

      <Eyebrow text={eyebrow} />
      <h1 id="spl-h1" class="spl-h1">{h1}</h1>
      <p class="spl-lead">{lead}</p>

      <div class="spl-actions">
        <a href={ctaPrimaryHref} class="spl-btn spl-btn--accent">
          {ctaPrimaryLabel} <span aria-hidden="true">→</span>
        </a>
        {ctaSecondaryLabel && ctaSecondaryHref && (
          <a href={ctaSecondaryHref} class="spl-btn spl-btn--glass">
            {ctaSecondaryLabel}
          </a>
        )}
      </div>

      {trustItems.length > 0 && (
        <ul class="spl-trust" role="list" aria-label="Zakres usługi">
          {trustItems.map((item) => (
            <li class="spl-trust__item">
              <svg class="spl-trust__icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m4 10.5 4 4 8-9" />
              </svg>
              {item}
            </li>
          ))}
        </ul>
      )}

    </div>
  </section>

  <!-- ── Page content ─────────────────────────────────────── -->
  <slot />

</BaseLayout>

<style>
  /* ─── Hero ──────────────────────────────────────────────── */
  .spl-hero {
    background: var(--color-paper-dark);
    color: var(--color-ink-on-dark);
    padding-top: calc(var(--space-3xl) + 5rem);
    padding-bottom: var(--space-3xl);
    position: relative;
    overflow: hidden;
  }

  /* Background image — same technique as homepage hero */
  .spl-hero--has-img {
    background-size: cover;
    background-position: bottom right;
    background-repeat: no-repeat;
  }

  /* Gradient overlay: navy fully opaque left → transparent right.
     Mirrors the homepage ::before pattern, keeps text readable. */
  .spl-hero--has-img::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      oklch(26% 0.060 257 / 1.00)  0%,
      oklch(26% 0.060 257 / 1.00) 32%,
      oklch(26% 0.060 257 / 0.88) 52%,
      oklch(26% 0.060 257 / 0.30) 72%,
      oklch(26% 0.060 257 / 0.00) 100%
    );
    pointer-events: none;
  }

  /* All direct children above the overlay */
  .spl-hero--has-img > * { position: relative; }

  /* Breadcrumb */
  .spl-bc { margin-bottom: var(--space-xl); }

  .spl-bc__list {
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
    list-style: none;
    flex-wrap: wrap;
    font-size: var(--text-sm);
    color: var(--color-muted-on-dark);
  }

  .spl-bc__list a {
    color: var(--color-muted-on-dark);
    text-decoration: none;
    transition: color var(--dur-micro) var(--ease-out);
  }

  .spl-bc__list a:hover { color: var(--color-ink-on-dark); }
  .spl-bc__list [aria-current="page"] { color: var(--color-blue-on-dark); font-weight: 500; }
  .spl-bc__sep { color: var(--color-muted-on-dark); opacity: 0.5; user-select: none; }

  /* Eyebrow */
  .spl-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-blue-on-dark);
    margin-bottom: var(--space-md);
  }

  /* H1 */
  .spl-h1 {
    font-family: var(--font-display);
    font-size: var(--text-display-s);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.08;
    color: var(--color-ink-on-dark);
    margin-bottom: var(--space-lg);
    max-width: 22ch;
  }

  /* Lead */
  .spl-lead {
    font-size: var(--text-md);
    color: var(--color-muted-on-dark);
    line-height: 1.65;
    max-width: 60ch;
    margin-bottom: var(--space-xl);
  }

  /* CTA buttons */
  .spl-actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-2xl);
  }

  .spl-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    padding: var(--space-sm) var(--space-xl);
    border-radius: var(--radius-pill);
    text-decoration: none;
    cursor: pointer;
    border: 1px solid transparent;
    white-space: nowrap;
    transition:
      background var(--dur-micro) var(--ease-out),
      border-color var(--dur-micro) var(--ease-out),
      color var(--dur-micro) var(--ease-out);
  }

  .spl-btn--accent {
    background: var(--color-accent);
    color: #fff;
  }

  .spl-btn--accent:hover { background: var(--color-accent-hover); }

  .spl-btn--glass {
    background: var(--color-glass-dark);
    color: var(--color-ink-on-dark);
    border-color: var(--color-glass-border);
  }

  .spl-btn--glass:hover {
    background: oklch(100% 0 0 / 0.12);
    border-color: oklch(100% 0 0 / 0.2);
  }

  /* Trust strip */
  .spl-trust {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm) var(--space-xl);
    list-style: none;
    border-top: 1px solid var(--color-glass-border);
    padding-top: var(--space-xl);
  }

  .spl-trust__item {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    color: var(--color-muted-on-dark);
    line-height: 1.4;
  }

  .spl-trust__icon {
    flex-shrink: 0;
    width: 1rem;
    height: 1rem;
    color: var(--color-blue-on-dark);
  }

  /* ─── Responsive ──────────────────────────────────────── */
  @media (max-width: 40rem) {
    .spl-hero { padding-bottom: var(--space-2xl); }
    .spl-h1 { font-size: clamp(1.75rem, 5vw + 0.5rem, 2.5rem); }
    .spl-lead { font-size: var(--text-base); }
    .spl-actions { flex-direction: column; }
    .spl-btn { width: 100%; justify-content: center; }
    /* On mobile extend overlay to cover full width */
    .spl-hero--has-img::before {
      background: linear-gradient(
        to right,
        oklch(26% 0.060 257 / 1.00) 0%,
        oklch(26% 0.060 257 / 0.92) 100%
      );
    }
  }
</style>
