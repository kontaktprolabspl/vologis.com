---
import "../styles/global.css";
import { SITE } from "../config/site";
import { orgSchema } from "../utils/schema";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noIndex?: boolean;
  /** Pass an absolute EN URL when this page has an English equivalent. */
  hreflangEN?: string;
  /** Above-fold image to preload — pass per-page hero path here */
  preloadImage?: string;
}

const {
  title = SITE.defaults.pl.title,
  description = SITE.defaults.pl.description,
  ogImage = SITE.ogImage,
  canonical,
  noIndex = false,
  hreflangEN,
  preloadImage,
} = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, "https://vologis.com").href;

const currentLang = Astro.url.pathname.startsWith("/en") ? "en" : "pl";
const plPath = currentLang === "en" ? Astro.url.pathname.replace(/^\/en/, "/pl") : Astro.url.pathname;
const enPath = currentLang === "en" ? Astro.url.pathname : Astro.url.pathname.replace(/^\/pl/, "/en");
const plURL = new URL(plPath, "https://vologis.com").href;
const enURL = new URL(enPath, "https://vologis.com").href;

const serviceLinks = [
  { label: "Pośrednictwo logistyczne i fulfillment", href: "/pl/uslugi/posrednictwo-logistyczne", desc: "Jeden partner zamiast dziesiątek rozmów z operatorami." },
  { label: "Doradztwo operacyjne i audyt", href: "/pl/uslugi/doradztwo-operacyjne", desc: "Sprawdzimy gdzie tracisz pieniądze, czas i ludzi." },
  { label: "Projekty Greenfield", href: "/pl/uslugi/projekty-greenfield", desc: "Od pustej działki do gotowej operacji." },
  { label: "Usługi dronowe", href: "/pl/uslugi/uslugi-dronowe", desc: "Pomiary, ortofotomapy, inspekcje i materiały z powietrza." },
  { label: "Interim Management", href: "/pl/uslugi/interim-management", desc: "Wsparcie zarządcze i gaszenie pożarów od zaraz." },
];
const navItems = [
  { label: "Proces",      href: "/pl/proces",      match: "/pl/proces"      },
  { label: "Wiedza",      href: "/pl/wiedza",      match: "/pl/wiedza"      },
  { label: "O nas",       href: "/pl/o-nas",       match: "/pl/o-nas"       },
  { label: "Współpraca",  href: "/pl/wspolpraca",  match: "/pl/wspolpraca"  },
];
const navPath = Astro.url.pathname;
const isActive = (m: string) => navPath === m || navPath.startsWith(m + "/");

/* Organization schema uses SITE config as single source of truth */
const schemaOrg = orgSchema();

const ogLocale = currentLang === "en" ? SITE.defaults.en.locale : SITE.defaults.pl.locale;
---

<!doctype html>
<html lang={currentLang} dir="ltr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- Google Search Console verification -->
  <meta name="google-site-verification" content="PmUjYUC4MOQ_6C5EF33coJsiUG1ZcnqaOp3Vu2iUJXk" />

  <meta name="generator" content={Astro.generator} />

  <!-- SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta name="robots" content={noIndex ? "noindex, follow" : "index, follow"} />

  <!-- hreflang — EN alternate only when the page has an English equivalent -->
  <link rel="alternate" hreflang="pl-PL" href={plURL} />
  {hreflangEN && <link rel="alternate" hreflang="en" href={hreflangEN} />}
  <link rel="alternate" hreflang="x-default" href={plURL} />

  <!-- GEO -->
  <meta name="geo.region" content="PL-WP" />
  <meta name="geo.placename" content="Jarocin, Polska" />
  <meta name="geo.position" content="51.9694;17.4975" />
  <meta name="ICBM" content="51.9694, 17.4975" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  {ogImage && <meta property="og:image" content={new URL(ogImage, SITE.url).href} />}
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:locale" content={ogLocale} />
  <meta property="og:site_name" content={SITE.name} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  {ogImage && <meta name="twitter:image" content={new URL(ogImage, SITE.url).href} />}
  {ogImage && <meta property="og:image:width" content="1200" />}
  {ogImage && <meta property="og:image:height" content="630" />}

  <!-- Favicons -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="apple-touch-icon" href="/favicon.svg" />
  <meta name="theme-color" content="#0d1b2a" />

  <!-- Fonts self-hosted via @fontsource-variable (no external requests, no render-blocking) -->

  <!-- Preload critical above-fold image (page-specific, passed via preloadImage prop) -->
  {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}

  <!-- Schema: Organization -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />

  <!-- Google Analytics 4 — replace G-XXXXXXXXXX -->
  <!-- <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-XXXXXXXXXX');</script> -->

  <!-- Microsoft Clarity — replace with your project ID -->
  <!-- <script>(function(c,l,a,r,i,t,y){...})(window, document, "clarity", "script", "YOUR_ID");</script> -->

  <!-- Google Search Console verification — replace content -->
  <!-- <meta name="google-site-verification" content="YOUR_VERIFICATION_CODE" /> -->

  <!-- Calendly widget — load on demand only (avoids third-party cookies and render-blocking) -->
  <script>
    function loadCalendly(cb) {
      if (window.Calendly) { if (cb) cb(); return; }
      var css = document.createElement('link');
      css.rel = 'stylesheet';
      css.href = 'https://assets.calendly.com/assets/external/widget.css';
      document.head.appendChild(css);
      var s = document.createElement('script');
      s.src = 'https://assets.calendly.com/assets/external/widget.js';
      s.onload = cb;
      document.head.appendChild(s);
    }
    document.addEventListener('click', function(e) {
      var t = e.target.closest('[data-calendly]');
      if (!t) return;
      e.preventDefault();
      loadCalendly(function() {
        Calendly.initPopupWidget({ url: 'https://calendly.com/vologis/30min' });
      });
    }, true);
  </script>

</head>

<body>

  <!-- ════ Site header ════════════════════════════════ -->
  <header class="hd" role="banner">
    <div class="hd__bar container">
      <a href="/pl/" class="hd__brand" aria-label="Vologis — strona główna">VOLOGIS</a>

      <nav class="hd__nav" aria-label="Nawigacja główna">
        <ul class="hd__list" role="list">
          <li class="hd__item has-mega">
            <a
              href="/pl/uslugi"
              class="hd__link"
              aria-current={navPath.startsWith("/pl/uslugi") ? "page" : undefined}
              aria-haspopup="true"
            >Usługi</a>
            <div class="mega" role="menu" aria-label="Usługi">
              <div class="mega__grid">
                {serviceLinks.map((s) => (
                  <a class="mega__card" href={s.href} role="menuitem" aria-current={navPath === s.href ? "page" : undefined}>
                    <span class="mega__card-title">{s.label}</span>
                    <span class="mega__card-desc">{s.desc}</span>
                  </a>
                ))}
              </div>
              <a class="mega__foot" href="/pl/uslugi">Zobacz wszystkie usługi <span aria-hidden="true">→</span></a>
            </div>
          </li>
          {navItems.map((item) => (
            <li class="hd__item">
              <a class="hd__link" href={item.href} aria-current={isActive(item.match) ? "page" : undefined}>{item.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="hd__actions">
        <div class="hd__lang" aria-label="Język / Language">
          <a href={plPath} hreflang="pl" title="Polski" aria-current={currentLang === "pl" ? "true" : undefined}>PL</a>
          <span aria-hidden="true">/</span>
          <a href={enPath} hreflang="en" title="English" aria-current={currentLang === "en" ? "true" : undefined}>EN</a>
        </div>

        <a href="/pl/kontakt" class="btn btn--ghost hd__ghost">Kontakt</a>

        <button
          type="button"
          class="btn btn--solid"
          data-calendly="popup"
        >Umów spotkanie</button>

        <button class="burger" id="burger" aria-label="Otwórz menu" aria-expanded="false" aria-controls="mobile-nav">
          <span></span>
          <span></span>
        </button>
      </div>
    </div>
  </header>

  <!-- ════ Mobile nav (full-screen) ═══════════════════ -->
  <div class="mnav" id="mobile-nav" aria-hidden="true">
    <div class="mnav__panel">
      <div class="mnav__scroll">
        <ul class="mnav__list" role="list">
          <li class="mnav__item">
            <button class="mnav__row mnav__row--toggle" aria-expanded="false" aria-controls="msub-uslugi">
              Usługi
              <svg class="mnav__chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 6 6 6-6 6"/></svg>
            </button>
            <ul class="mnav__sub" id="msub-uslugi" role="list">
              <li><a class="mnav__sublink" href="/pl/uslugi">Wszystkie usługi</a></li>
              {serviceLinks.map((s) => (
                <li><a class="mnav__sublink" href={s.href}>{s.label}</a></li>
              ))}
            </ul>
          </li>
          <li class="mnav__item"><a class="mnav__row" href="/pl/proces">Proces</a></li>
          <li class="mnav__item"><a class="mnav__row" href="/pl/wiedza">Wiedza</a></li>
          <li class="mnav__item"><a class="mnav__row" href="/pl/o-nas">O nas</a></li>
          <li class="mnav__item"><a class="mnav__row" href="/pl/wspolpraca">Współpraca</a></li>
          <li class="mnav__item"><a class="mnav__row" href="/pl/kontakt">Kontakt</a></li>
        </ul>

        <div class="mnav__lang" aria-label="Język / Language">
          <a href={plPath} hreflang="pl" aria-current={currentLang === "pl" ? "true" : undefined}>Polski</a>
          <span aria-hidden="true">/</span>
          <a href={enPath} hreflang="en" aria-current={currentLang === "en" ? "true" : undefined}>English</a>
        </div>
      </div>

      <div class="mnav__foot">
        <a href="/pl/kontakt" class="btn btn--ghost btn--block">Kontakt</a>
        <button
          type="button"
          class="btn btn--solid btn--block"
          data-calendly="popup"
        >Umów spotkanie</button>
      </div>
    </div>
  </div>

  <main id="main-content">
    <slot />
  </main>

  <!-- Ft1 Mast-headed footer ──────────────────────── -->
  <footer class="footer" role="contentinfo">
    <div class="container">
      <div class="footer-inner">

        <div class="footer-brand">
          <p class="footer-wordmark">VOLOGIS</p>
          <p class="footer-tagline">Doradztwo logistyczne dla firm z ambicjami.</p>
        </div>

        <nav class="footer-col" aria-label="Usługi">
          <h3 class="footer-col-title">Usługi</h3>
          <ul class="footer-col-list" role="list">
            {serviceLinks.map((s) => (
              <li><a href={s.href}>{s.label}</a></li>
            ))}
            <li><a href="/pl/uslugi">Wszystkie usługi</a></li>
          </ul>
        </nav>

        <nav class="footer-col" aria-label="Firma">
          <h3 class="footer-col-title">Firma</h3>
          <ul class="footer-col-list" role="list">
            <li><a href="/pl/o-nas">O nas</a></li>
            <li><a href="/pl/proces">Jak pracujemy</a></li>
            <li><a href="/pl/wiedza">Wiedza</a></li>
            <li><a href="/pl/wspolpraca">Współpraca</a></li>
            <li><a href="/pl/kontakt">Kontakt</a></li>
          </ul>
        </nav>

        <div class="footer-meta">
          <address class="footer-nap">
            Vologis Sp. z o.o.<br>
            ul. Wrocławska 79B, 63-200 Jarocin<br>
            <a href="mailto:biuro@vologis.com">biuro@vologis.com</a>
          </address>
          <nav class="footer-links" aria-label="Linki stopki">
            <a href="/pl/polityka-prywatnosci">Polityka prywatności</a>
            <a href="/pl/regulamin">Regulamin</a>
          </nav>
          <p class="footer-copy">&copy; 2026 Vologis Sp. z o.o.</p>
        </div>

      </div>
    </div>
  </footer>

  <!-- Microsoft Clarity — heatmaps & session recording, deferred to after render -->
  <script type="text/javascript" defer>
    window.addEventListener('load', function() {
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "wyaq74tm7t");
    });
  </script>
</body>
</html>

<style>
  /* ════ Site header ════════════════════════════════ */
  .hd {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-sticky);
    background: var(--color-paper-glass);
    backdrop-filter: blur(12px) saturate(1.4);
    -webkit-backdrop-filter: blur(12px) saturate(1.4);
    border-top: 3px solid var(--color-accent);
    border-bottom: 1px solid var(--color-rule);
    transition:
      background var(--dur-long) var(--ease-out),
      border-bottom-color var(--dur-long) var(--ease-out),
      backdrop-filter var(--dur-long) var(--ease-out);
  }

  .hd__bar {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    height: 4.25rem;
  }

  .hd__brand {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-md);
    letter-spacing: 0.06em;
    color: var(--color-ink);
    text-decoration: none;
    white-space: nowrap;
  }

  /* Primary nav */
  .hd__list {
    display: flex;
    align-items: center;
    gap: var(--space-3xs);
    list-style: none;
  }

  .hd__link {
    display: block;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    white-space: nowrap;
    padding: var(--space-2xs) var(--space-sm);
    border-radius: var(--radius-pill);
    transition:
      color var(--dur-micro) var(--ease-out),
      background var(--dur-micro) var(--ease-out);
  }

  .hd__link:hover,
  .hd__link[aria-current="page"] {
    color: var(--color-ink);
    background: var(--color-paper-2);
  }

  /* Mega menu */
  .has-mega { position: relative; }

  /* invisible bridge so the panel stays open across the gap */
  .has-mega::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    height: var(--space-sm);
  }

  .mega {
    position: absolute;
    top: calc(100% + var(--space-sm));
    left: 0;
    width: 42rem;
    max-width: 92vw;
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    padding: var(--space-sm);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition:
      opacity var(--dur-short) var(--ease-out),
      transform var(--dur-short) var(--ease-out),
      visibility var(--dur-short);
    z-index: var(--z-dropdown);
  }

  .has-mega:hover .mega,
  .has-mega:focus-within .mega {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .mega__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xs);
  }

  .mega__card {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background var(--dur-micro) var(--ease-out);
  }

  .mega__card:hover,
  .mega__card[aria-current="page"] { background: var(--color-paper-2); }

  .mega__card-title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-ink);
  }

  .mega__card-desc {
    font-size: var(--text-xs);
    color: var(--color-muted);
    line-height: 1.4;
  }

  .mega__foot {
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
    margin-top: var(--space-2xs);
    padding: var(--space-sm) var(--space-md);
    border-top: 1px solid var(--color-rule);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-secondary);
    text-decoration: none;
  }

  .mega__foot span { transition: transform var(--dur-short) var(--ease-out); }
  .mega__foot:hover span { transform: translateX(4px); }

  /* Right-side actions */
  .hd__actions {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .hd__lang {
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    margin-right: var(--space-2xs);
  }

  .hd__lang a {
    color: var(--color-muted);
    text-decoration: none;
    padding: 2px 4px;
    border-radius: 4px;
    transition: color var(--dur-micro) var(--ease-out);
  }

  .hd__lang a:hover { color: var(--color-ink); }
  .hd__lang a[aria-current="true"] { color: var(--color-ink); font-weight: 700; }
  .hd__lang span { color: var(--color-neutral); user-select: none; }

  /* ── Buttons (ghost + solid) ─────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2xs);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    line-height: 1;
    border-radius: var(--radius-pill);
    padding: var(--space-xs) var(--space-md);
    text-decoration: none;
    white-space: nowrap;
    cursor: pointer;
    border: 1px solid transparent;
    transition:
      background var(--dur-micro) var(--ease-out),
      border-color var(--dur-micro) var(--ease-out),
      color var(--dur-micro) var(--ease-out);
  }

  .btn--ghost {
    color: var(--color-ink);
    background: var(--color-paper-2);
  }

  .btn--ghost:hover {
    background: var(--color-paper);
    border-color: var(--color-rule);
  }

  .btn--solid {
    color: var(--color-ink-on-dark);
    background: var(--color-ink);
  }

  .btn--solid:hover { background: oklch(40% 0.06 257); }

  .btn--block { flex: 1; padding-block: var(--space-sm); font-size: var(--text-base); }

  /* ── Burger (mobile-first: visible by default, hidden on desktop) ── */
  .burger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 0;
    background: none;
    border: none;
    cursor: pointer;
  }

  .burger span {
    display: block;
    width: 22px;
    height: 2px;
    margin-inline: auto;
    background: var(--color-ink);
    border-radius: 2px;
    transition: transform var(--dur-short) var(--ease-out);
  }

  .burger.is-open span:nth-child(1) { transform: translateY(3.5px) rotate(45deg); }
  .burger.is-open span:nth-child(2) { transform: translateY(-3.5px) rotate(-45deg); }

  /* ════ Mobile nav (full-screen) ═══════════════════ */
  .mnav {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    top: calc(4.25rem + 3px);
    z-index: calc(var(--z-sticky) - 1);
    background: oklch(26% 0.060 257 / 0.55);
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--dur-short) var(--ease-out), visibility var(--dur-short);
  }

  .mnav.is-open { opacity: 1; visibility: visible; }

  .mnav__panel {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    background: var(--color-paper);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    transform: translateY(12px);
    transition: transform var(--dur-long) var(--ease-out);
  }

  .mnav.is-open .mnav__panel { transform: translateY(0); }

  .mnav__scroll {
    flex: 1;
    overflow-y: auto;
    padding: var(--space-xs) var(--space-lg) var(--space-lg);
  }

  .mnav__list { list-style: none; }

  .mnav__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    width: 100%;
    padding: var(--space-md) 0;
    font-family: var(--font-display);
    font-size: var(--text-md);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    text-decoration: none;
    background: none;
    border: none;
    border-bottom: 1px solid var(--color-rule);
    cursor: pointer;
    text-align: left;
  }

  .mnav__chev {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    color: var(--color-neutral);
    transition: transform var(--dur-short) var(--ease-out);
  }

  .mnav__item.is-open .mnav__chev { transform: rotate(90deg); }

  .mnav__sub {
    list-style: none;
    overflow: hidden;
    max-height: 0;
    transition: max-height var(--dur-long) var(--ease-out);
  }

  .mnav__item.is-open .mnav__sub { max-height: 32rem; }

  .mnav__sublink {
    display: block;
    padding: var(--space-sm) 0 var(--space-sm) var(--space-md);
    font-size: var(--text-base);
