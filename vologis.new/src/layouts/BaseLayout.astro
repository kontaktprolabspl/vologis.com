<script>
  const burger = document.getElementById('burger') as HTMLButtonElement | null;
  const mnav = document.getElementById('mobile-nav') as HTMLElement | null;

  if (burger && mnav) {
    const setOpen = (open: boolean) => {
      mnav.classList.toggle('is-open', open);
      burger.classList.toggle('is-open', open);
      burger.setAttribute('aria-expanded', String(open));
      mnav.setAttribute('aria-hidden', String(!open));
      burger.setAttribute('aria-label', open ? 'Zamknij menu' : 'Otwórz menu');
      document.body.style.overflow = open ? 'hidden' : '';
    };

    burger.addEventListener('click', () => setOpen(!mnav.classList.contains('is-open')));

    // Accordion (submenu rows)
    mnav.querySelectorAll('.mnav__row--toggle').forEach((btn) => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.mnav__item');
        const open = item?.classList.toggle('is-open') ?? false;
        btn.setAttribute('aria-expanded', String(open));
      });
    });

    // Close on any navigational link click
    mnav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

    // Escape closes the menu
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && mnav.classList.contains('is-open')) setOpen(false);
    });
  }
</script>
