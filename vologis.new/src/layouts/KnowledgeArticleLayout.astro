---
import BaseLayout from "./BaseLayout.astro";
import { articleSchema } from "../utils/schema";

interface TocItem {
  id: string;
  label: string;
}

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  /** Optional hero background image path, e.g. "/knowledge/art-v1.png" */
  heroImage?: string;
  /** Alt text for the hero image (required when heroImage is set) */
  heroImageAlt?: string;
  category?: string;
  readTime?: string;
  updatedAt?: string;
  /** ISO 8601 date string for Article schema, e.g. "2025-01-15" */
  datePublished?: string;
  /** ISO 8601 date string for Article schema; defaults to datePublished */
  dateModified?: string;
  h1: string;
  lead: string;
  toc?: TocItem[];
  ctaPrimaryLabel?: string;
  ctaSecondary?: { label: string; href: string };
}

const {
  title,
  description,
  canonical,
  ogImage,
  heroImage,
  heroImageAlt = "",
  category = "Wiedza",
  readTime,
  updatedAt,
  datePublished,
  dateModified,
  h1,
  lead,
  toc = [],
  ctaPrimaryLabel = "Umów konsultację",
  ctaSecondary,
} = Astro.props;

const pageUrl = canonical ?? `https://vologis.com${Astro.url.pathname}`;

const schemaArticle = datePublished
  ? articleSchema({
      headline: h1,
      description,
      url: pageUrl,
      datePublished,
      dateModified,
      inLanguage: "pl-PL",
      image: heroImage ?? ogImage,
    })
  : null;

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://vologis.com/pl/" },
    { "@type": "ListItem", "position": 2, "name": "Wiedza", "item": "https://vologis.com/pl/wiedza" },
    { "@type": "ListItem", "position": 3, "name": h1, "item": pageUrl },
  ],
};
---

<BaseLayout {title} {description} {canonical} {ogImage} preloadImage={heroImage}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  {schemaArticle && <script type="application/ld+json" set:html={JSON.stringify(schemaArticle)} />}

  <!-- ── Article Hero ──────────────────────────────────────── -->
  <section
    class:list={["art-hero", { "art-hero--has-bg": !!heroImage }]}
    aria-labelledby="art-h1"
  >
    {heroImage && (
      <img
        src={heroImage}
        alt={heroImageAlt}
        class="art-hero__img"
        fetchpriority="high"
        loading="eager"
        decoding="async"
        width="1600"
        height="640"
      />
    )}

    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol class="bc-list" role="list">
          <li><a href="/pl/">Strona główna</a></li>
          <li class="bc-sep" aria-hidden="true">›</li>
          <li><a href="/pl/wiedza">Wiedza</a></li>
          <li class="bc-sep" aria-hidden="true">›</li>
          <li aria-current="page">{category}</li>
        </ol>
      </nav>

      <div class="art-meta">
        <span class="art-cat">{category}</span>
        {readTime && (
          <>
            <span class="art-sep" aria-hidden="true">·</span>
            <span class="art-time">{readTime} czytania</span>
          </>
        )}
        {updatedAt && (
          <>
            <span class="art-sep" aria-hidden="true">·</span>
            <time class="art-date" datetime={dateModified ?? datePublished ?? updatedAt}>Aktualizacja: {updatedAt}</time>
          </>
        )}
      </div>

      <h1 id="art-h1" class="art-h1" data-speakable="headline">{h1}</h1>
      <p class="art-lead" data-speakable="summary">{lead}</p>

      <div class="art-hero-actions">
        <a
          href="#calendly"
          class="kbtn kbtn--dark"
          data-calendly="popup"
        >
          {ctaPrimaryLabel}
        </a>
        {ctaSecondary && (
          <a href={ctaSecondary.href} class="kbtn kbtn--ghost">
            {ctaSecondary.label} <span aria-hidden="true">↓</span>
          </a>
        )}
      </div>
    </div>
  </section>

  <!-- ── Article body: main content + sticky ToC ──────────── -->
  <div class="art-grid container">
    <article class="art-content" id="art-content">
      <slot />
    </article>

    {toc.length > 0 && (
      <aside class="art-toc" id="art-toc" aria-label="Spis treści">
        <div class="art-toc-box">
          <p class="art-toc-label">Spis treści</p>
          <nav aria-label="Nawigacja po artykule">
            <ol class="art-toc-list" role="list">
              {toc.map((item) => (
                <li>
                  <a class="art-toc-link" href={`#${item.id}`} data-id={item.id}>
                    {item.label}
                  </a>
                </li>
              ))}
            </ol>
          </nav>
          <div class="art-toc-cta">
            <a
              href="#calendly"
              class="kbtn kbtn--dark kbtn--full"
              data-calendly="popup"
            >
              Umów konsultację
            </a>
          </div>
        </div>
      </aside>
    )}
  </div>
</BaseLayout>

<style>
  /* ─── Hero ──────────────────────────────────────────────── */
  .art-hero {
    background: var(--color-paper-2);
    border-bottom: 1px solid var(--color-rule);
    padding-top: calc(4.25rem + 3px + var(--space-2xl));
    padding-bottom: var(--space-2xl);
    position: relative;
    overflow: hidden;
  }

  /* Hero image — absolutely positioned behind overlay */
  .art-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center right;
    z-index: 0;
  }

  /* Left-to-right overlay keeps text readable */
  .art-hero--has-bg::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      oklch(94% 0.020 160 / 1.00)  0%,
      oklch(94% 0.020 160 / 1.00) 30%,
      oklch(94% 0.020 160 / 0.88) 52%,
      oklch(94% 0.020 160 / 0.28) 72%,
      oklch(94% 0.020 160 / 0.00) 100%
    );
    pointer-events: none;
  }

  /* All direct children (except the bg img) above the overlay */
  .art-hero--has-bg > :not(.art-hero__img) { position: relative; }

  /* Breadcrumb */
  .bc-list {
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
    list-style: none;
    flex-wrap: wrap;
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-bottom: var(--space-lg);
  }

  .bc-list a {
    color: var(--color-muted);
    text-decoration: none;
    transition: color var(--dur-micro) var(--ease-out);
  }

  .bc-list a:hover { color: var(--color-ink); }
  .bc-list [aria-current="page"] { color: var(--color-ink); }
  .bc-sep { color: var(--color-neutral); user-select: none; }

  /* Meta row */
  .art-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-bottom: var(--space-lg);
  }

  .art-cat {
    display: inline-flex;
    align-items: center;
    padding: 2px var(--space-sm);
    border-radius: var(--radius-pill);
    background: var(--color-blue-tint);
    color: var(--color-secondary);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .art-sep { color: var(--color-neutral); user-select: none; }
  .art-time, .art-date { font-size: var(--text-sm); color: var(--color-muted); }

  /* H1 */
  .art-h1 {
    font-size: var(--text-display-s);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--color-ink);
    margin-bottom: var(--space-lg);
    max-width: 28ch;
  }

  /* Lead */
  .art-lead {
    font-size: var(--text-md);
    color: var(--color-muted);
    line-height: 1.65;
    max-width: 58ch;
    margin-bottom: var(--space-xl);
  }

  /* Hero actions */
  .art-hero-actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  /* Shared button primitive for the layout */
  .kbtn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    padding: var(--space-sm) var(--space-lg);
    border-radius: var(--radius-pill);
    text-decoration: none;
    cursor: pointer;
    border: 1px solid transparent;
    white-space: nowrap;
    transition:
      background var(--dur-micro) var(--ease-out),
      border-color var(--dur-micro) var(--ease-out),
      color var(--dur-micro) var(--ease-out);
  }

  .kbtn--dark {
    background: var(--color-ink);
    color: var(--color-ink-on-dark);
  }

  .kbtn--dark:hover { background: oklch(40% 0.06 257); }

  .kbtn--ghost {
    background: var(--color-paper);
    color: var(--color-ink);
    border-color: var(--color-rule);
  }

  .kbtn--ghost:hover {
    background: var(--color-paper-2);
    border-color: var(--color-blue);
  }

  .kbtn--full { width: 100%; }

  /* ─── Article grid ────────────────────────────────────── */
  .art-grid {
    display: grid;
    grid-template-columns: 1fr 17rem;
    gap: var(--space-3xl);
    align-items: start;
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-4xl);
  }

  .art-content { min-width: 0; }

  /* ─── ToC sidebar ─────────────────────────────────────── */
  .art-toc {
    position: sticky;
    top: calc(4.25rem + 3px + var(--space-lg));
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--color-rule) transparent;
  }

  .art-toc-box {
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-lg);
    background: var(--color-paper);
    overflow: hidden;
  }

  .art-toc-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-neutral);
    padding: var(--space-md) var(--space-lg) var(--space-sm);
    border-bottom: 1px solid var(--color-rule);
  }

  .art-toc-list {
    list-style: none;
    padding: var(--space-xs) 0;
  }

  .art-toc-link {
    display: block;
    padding: var(--space-xs) var(--space-lg);
    font-size: var(--text-sm);
    color: var(--color-muted);
    text-decoration: none;
    border-left: 2px solid transparent;
    line-height: 1.4;
    transition:
      color var(--dur-micro) var(--ease-out),
      background var(--dur-micro) var(--ease-out),
      border-color var(--dur-micro) var(--ease-out);
  }

  .art-toc-link:hover {
    color: var(--color-ink);
    background: var(--color-paper-2);
    border-left-color: var(--color-blue);
  }

  .art-toc-link.is-active {
    color: var(--color-ink);
    font-weight: 600;
    background: var(--color-paper-2);
    border-left-color: var(--color-accent);
  }

  .art-toc-cta {
    padding: var(--space-md) var(--space-lg);
    border-top: 1px solid var(--color-rule);
  }

  /* ─── Responsive ──────────────────────────────────────── */
  @media (max-width: 64rem) {
    .art-grid {
      grid-template-columns: 1fr;
    }
    .art-toc { display: none; }
  }

  @media (max-width: 40rem) {
    .art-hero {
      padding-top: calc(4.25rem + 3px + var(--space-xl));
      padding-bottom: var(--space-xl);
    }
    .art-h1 { font-size: clamp(1.75rem, 5vw + 0.5rem, 2.5rem); }
    .art-lead { font-size: var(--text-base); }
    .art-hero-actions {
      flex-direction: column;
    }
    .kbtn { width: 100%; }
  }
</style>

<script>
  // Highlight active ToC link based on scroll position
  const links = document.querySelectorAll<HTMLAnchorElement>('.art-toc-link[data-id]');

  if (links.length > 0) {
    const ids = Array.from(links).map((l) => l.dataset.id!);
    const sections = ids
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => el !== null);

    const highlight = (activeId: string) => {
      links.forEach((l) => l.classList.toggle('is-active', l.dataset.id === activeId));
    };

    const tick = () => {
      const y = window.scrollY + 140;
      let cur = ids[0];
      for (const sec of sections) {
        if (sec.offsetTop <= y) cur = sec.id;
      }
      highlight(cur);
    };

    window.addEventListener('scroll', tick, { passive: true });
    tick();
  }
</script>
